# ═══════════════════════════════════════════════════════════
# BYT Website — Environment Variables
# ═══════════════════════════════════════════════════════════
#
# Copy this file to .env.local (gitignored) and fill in secrets.
# Non-secret identifiers are pre-filled from confirmed accounts.
#
# .env.local is read by Astro at dev/build time.
# These same values must also be set in Cloudflare Pages
# dashboard under Settings → Environment Variables for
# production builds.
# ═══════════════════════════════════════════════════════════

# ── Sanity ────────────────────────────────────────────────
# Project: Better You Therapy (byt)
# Dashboard: https://www.sanity.io/manage/personal/project/bpjtbps6
PUBLIC_SANITY_PROJECT_ID="bpjtbps6"
PUBLIC_SANITY_DATASET="production"

# Read token — required only if/when SSR or Visual Editing is enabled.
# For static-only builds (our current mode), leave blank.
# Generate at: sanity.io/manage → byt project → API → Tokens → Add API token
# Permissions: Viewer (read-only is sufficient for frontend builds)
SANITY_API_READ_TOKEN=""

# ── Site ──────────────────────────────────────────────────
# Production URL — used for canonical URLs, sitemap, schema markup, OG tags.
# In dev: http://localhost:4321 (Astro default)
# In Cloudflare preview deploys: auto-detected
PUBLIC_SITE_URL="https://getbetteryou.com"

# ── Formspree ─────────────────────────────────────────────
# Contact form — /contact/ page
# Dashboard: https://formspree.io/forms
PUBLIC_FORMSPREE_CONTACT_ID="xvzloqya"

# Referral form — /referral/ page
# Create at: https://formspree.io → New form → "Referral"
# Then paste the endpoint ID here (last segment of the form URL)
PUBLIC_FORMSPREE_REFERRAL_ID=""

# ── Cloudflare ────────────────────────────────────────────
# Account ID (not a secret — used for wrangler CLI config)
# Dashboard: https://dash.cloudflare.com/e5bc55bdcb6c538072ab31d0615e2c6b
CLOUDFLARE_ACCOUNT_ID="e5bc55bdcb6c538072ab31d0615e2c6b"

# API token — required for wrangler CLI deploys from CI.
# Generate at: dash.cloudflare.com → My Profile → API Tokens
# → Create Token → "Edit Cloudflare Workers" template
# Only needed if deploying via CLI/CI. Cloudflare Pages
# auto-deploys from GitHub without this.
CLOUDFLARE_API_TOKEN=""

# ── Analytics ─────────────────────────────────────────────
# GA4 Measurement ID — added in Phase 7 (pre-launch hardening)
# Get from: Google Analytics → Admin → Data Streams → your stream
PUBLIC_GA4_MEASUREMENT_ID=""

# Google Search Console verification tag — added in Phase 7
# Get from: GSC → Settings → Ownership verification → HTML tag
PUBLIC_GSC_VERIFICATION=""
