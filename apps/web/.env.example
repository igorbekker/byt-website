# Formspree form IDs — get these from formspree.io/forms
PUBLIC_FORMSPREE_BOOK_ID=
PUBLIC_FORMSPREE_REFERRAL_ID=
PUBLIC_FORMSPREE_APPLY_ID=
PUBLIC_FORMSPREE_CONTACT_ID=

# Sanity write token — needed for redirect hit tracking in middleware
# Get from sanity.io/manage → project → API → Tokens → Add API token (Editor or Write role)
# Also add to Cloudflare Pages → Settings → Environment variables
SANITY_WRITE_TOKEN=
