          </div>
          <div class="approach-body">
            {
              pp[2]?.body ??
                'For facility patients, we coordinate with nursing and wellness staff, share progress reporting, and align with treatment plans. For teletherapy clients, we communicate with primary care and psychiatry on request.'
            }
          </div>
        </div>
        <div class="approach-row">
          <div class="approach-num">{pp[3]?.number ?? '04'} — {pp[3]?.label ?? 'ACCESS'}</div>
          <div class="approach-title">
            {pp[3]?.heading ?? 'No waitlist. First session this week.'}
          </div>
