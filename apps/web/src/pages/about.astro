---
/**
 * Purpose: About page — mission, founder story, principles, practice pillars, CTA
 * Context: Route /about/
 * Source: design-source/pages/About.html
 * Schema: apps/studio/schemas/singletons/aboutPage.ts
 */

import { sanityClient } from 'sanity:client';
import { PortableText } from 'astro-portabletext';
import BaseLayout from '../layouts/BaseLayout.astro';
import { ABOUT_PAGE_QUERY } from '../lib/queries';

interface CtaLink {
  label: string;
  href: string;
  variant?: string;
}

interface ImageWithAlt {
  asset?: { url: string };
  alt?: string;
}

interface SeoFields {
  metaTitle?: string;
  metaDescription?: string;
}

interface Principle {
  number: string;
  heading: string;
  body?: string;
}

interface PracticePillar {
  number: string;
  label: string;
  heading: string;
  body?: string;
}

interface AboutPage {
  heroHeading?: string;
  heroSubhead?: string;
  missionEyebrow?: string;
  missionQuote?: string;
  missionBody?: string;
  storyEyebrow?: string;
  storyHeading?: string;
  storyBody?: unknown[];
  founderName?: string;
  founderCredential?: string;
  founderPhoto?: ImageWithAlt;
  principlesEyebrow?: string;
  principlesHeading?: string;
  principlesSubhead?: string;
  principles?: Principle[];
  practiceEyebrow?: string;
  practiceHeading?: string;
  practicePillars?: PracticePillar[];
  ctaHeading?: string;
  ctaSubhead?: string;
  ctaPrimary?: CtaLink;
  ctaSecondary?: CtaLink;
  ctaBackgroundImage?: ImageWithAlt;
  seo?: SeoFields;
}

const page = await sanityClient.fetch<AboutPage>(ABOUT_PAGE_QUERY);
---

<BaseLayout seo={page?.seo ?? null}>
  <!-- ══════════════════════ Hero ══════════════════════ -->
  <section class="about-hero">
    <div class="about-hero-content">
      {page?.heroHeading && <h1 set:html={page.heroHeading} />}
      {page?.heroSubhead && <p>{page.heroSubhead}</p>}
    </div>
    <div class="about-hero-image" aria-hidden="true"></div>
  </section>

  <!-- ══════════════════════ Mission Band ══════════════════════ -->
  <section class="mission-band">
    <div class="mission-inner">
      {page?.missionEyebrow && <p class="eyebrow">{page.missionEyebrow}</p>}
      <div class="mission-rule" aria-hidden="true"></div>
      {page?.missionQuote && <h2>{page.missionQuote}</h2>}
      {page?.missionBody && <p>{page.missionBody}</p>}
    </div>
  </section>

  <!-- ══════════════════════ Story ══════════════════════ -->
  <section class="story">
    <div class="story-inner">
      {
        page?.founderPhoto?.asset?.url ? (
          <div class="story-image">
            <img
              src={page.founderPhoto.asset.url}
              alt={page.founderPhoto.alt ?? ''}
              loading="lazy"
            />
          </div>
        ) : (
          <div class="story-image" aria-hidden="true" />
        )
      }
      <div class="story-content">
        {page?.storyEyebrow && <p class="eyebrow">{page.storyEyebrow}</p>}
        {page?.storyHeading && <h2>{page.storyHeading}</h2>}
        {
          page?.storyBody && page.storyBody.length > 0 && (
            <div class="story-body">
              <PortableText value={page.storyBody} />
            </div>
          )
        }
        {
          (page?.founderName || page?.founderCredential) && (
            <div class="story-signature">
              {page.founderName && (
                <div class="story-signature-avatar" aria-hidden="true">
                  {page.founderName
                    .split(' ')
                    .map((n: string) => n[0])
                    .join('')
                    .slice(0, 2)}
                </div>
              )}
              <div class="story-signature-text">
                {page.founderName && <div class="name">{page.founderName}</div>}
                {page.founderCredential && <div class="role">{page.founderCredential}</div>}
              </div>
            </div>
          )
        }
      </div>
    </div>
  </section>

  <!-- ══════════════════════ Values / Principles ══════════════════════ -->
  <section class="values">
    <div class="values-inner">
      <div class="values-header">
        {page?.principlesEyebrow && <p class="eyebrow">{page.principlesEyebrow}</p>}
        {page?.principlesHeading && <h2>{page.principlesHeading}</h2>}
        {page?.principlesSubhead && <p>{page.principlesSubhead}</p>}
      </div>
      {
        page?.principles && page.principles.length > 0 && (
          <div class="values-grid">
            {page.principles.map((item: Principle) => (
              <article class="value-card">
                {item.number && <span class="value-num">{item.number}</span>}
                {item.heading && <h3>{item.heading}</h3>}
                {item.body && <p>{item.body}</p>}
              </article>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <!-- ══════════════════════ Practice / Approach ══════════════════════ -->
  <section class="approach">
    <div class="approach-inner">
      <div class="approach-header">
        {page?.practiceEyebrow && <p class="eyebrow">{page.practiceEyebrow}</p>}
        {page?.practiceHeading && <h2>{page.practiceHeading}</h2>}
      </div>
      {
        page?.practicePillars && page.practicePillars.length > 0 && (
          <div class="approach-list">
            {page.practicePillars.map((pillar: PracticePillar) => (
              <div class="approach-row">
                <div class="approach-num">
                  {pillar.number}
                  {pillar.label ? ` — ${pillar.label}` : ''}
                </div>
                {pillar.heading && <div class="approach-title">{pillar.heading}</div>}
                {pillar.body && <div class="approach-body">{pillar.body}</div>}
              </div>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <!-- ══════════════════════ CTA ══════════════════════ -->
  <section class="about-cta">
    {
      page?.ctaBackgroundImage?.asset?.url && (
        <div
          class="about-cta-bg"
          style={`background-image:url('${page.ctaBackgroundImage.asset.url}')`}
          role="img"
          aria-label={page.ctaBackgroundImage.alt ?? ''}
        />
      )
    }
    <div class="about-cta-overlay" aria-hidden="true"></div>
    <div class="about-cta-inner">
      {page?.ctaHeading && <h2>{page.ctaHeading}</h2>}
      {page?.ctaSubhead && <p>{page.ctaSubhead}</p>}
      {
        (page?.ctaPrimary || page?.ctaSecondary) && (
          <div class="about-cta-actions">
            {page.ctaPrimary && (
              <a
                href={page.ctaPrimary.href}
                class={`btn btn-${page.ctaPrimary.variant ?? 'coral'}`}
              >
                {page.ctaPrimary.label}
              </a>
            )}
            {page.ctaSecondary && (
              <a
                href={page.ctaSecondary.href}
                class={`btn btn-${page.ctaSecondary.variant ?? 'outline-white'}`}
              >
                {page.ctaSecondary.label}
              </a>
            )}
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  /* ══════════════════════════════════════════════
   ABOUT PAGE — scoped styles
   Source: design-source/pages/About.html
══════════════════════════════════════════════ */

  /* ── Hero ── */
  .about-hero {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    min-height: 70vh;
    max-height: 640px;
    background: var(--cream);
  }
  .about-hero-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 5rem 4rem;
  }
  .about-hero-content .eyebrow {
    margin-bottom: 1.5rem;
  }
  .about-hero-content h1 {
    font-size: clamp(2.4rem, 4vw, 3.4rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--navy-deep);
    margin-bottom: 1.5rem;
  }
  .about-hero-content h1 :global(em) {
    font-style: normal;
    color: var(--coral);
  }
  .about-hero-content p {
    color: var(--slate);
    font-size: 18px;
    line-height: 1.6;
    max-width: 520px;
  }
  .about-hero-image {
    position: relative;
    overflow: hidden;
    background: var(--navy);
  }
  .about-hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* ── Mission Band ── */
  .mission-band {
    background: var(--white);
    padding: var(--pad-s) var(--pad-x);
    border-bottom: 1px solid var(--border);
  }
  .mission-inner {
    max-width: 880px;
    margin: 0 auto;
    text-align: center;
  }
  .mission-rule {
    width: 48px;
    height: 2px;
    background: var(--coral);
    margin: 0 auto 1.75rem;
    border-radius: 2px;
  }
  .mission-band .eyebrow {
    margin-bottom: 1rem;
  }
  .mission-band h2 {
    font-size: clamp(1.9rem, 3vw, 2.5rem);
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--navy-deep);
    margin-bottom: 1.25rem;
  }
  .mission-band p {
    color: var(--slate);
    font-size: 17px;
    line-height: 1.7;
    max-width: 700px;
    margin: 0 auto;
  }

  /* ── Story ── */
  .story {
    background: var(--off-white);
    padding: var(--pad-s) var(--pad-x);
  }
  .story-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 4rem;
    align-items: center;
  }
  .story-image {
    border-radius: var(--r-card);
    overflow: hidden;
    aspect-ratio: 4/5;
    background: var(--border);
    box-shadow: var(--shadow-md);
  }
  .story-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .story-content .eyebrow {
    margin-bottom: 1rem;
  }
  .story-content h2 {
    font-size: clamp(2rem, 3.2vw, 2.6rem);
    color: var(--navy-deep);
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .story-body :global(p) {
    color: var(--slate);
    font-size: 16px;
    line-height: 1.7;
    margin-bottom: 1.1rem;
  }
  .story-body :global(p:last-child) {
    margin-bottom: 0;
  }
  .story-signature {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 2.25rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--border);
  }
  .story-signature-avatar {
    width: 52px;
    height: 52px;
    border-radius: var(--r-pill);
    background: var(--coral-light);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 800;
    color: var(--coral);
    font-size: 17px;
    flex-shrink: 0;
  }
  .story-signature-text .name {
    font-family: var(--font-heading);
    font-weight: 800;
    color: var(--navy-deep);
    font-size: 15px;
    letter-spacing: -0.01em;
  }
  .story-signature-text .role {
    color: var(--slate);
    font-size: 13px;
    margin-top: 2px;
  }

  /* ── Values / Principles ── */
  .values {
    background: var(--white);
    padding: var(--pad-s) var(--pad-x);
  }
  .values-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }
  .values-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }
  .values-header .eyebrow {
    margin-bottom: 1rem;
  }
  .values-header h2 {
    color: var(--navy-deep);
    font-size: clamp(2rem, 3.2vw, 2.6rem);
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }
  .values-header p {
    color: var(--slate);
    font-size: 17px;
    line-height: 1.6;
    max-width: 580px;
    margin: 0 auto;
  }
  .values-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .value-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--r-card);
    padding: 2.25rem 2rem;
    transition:
      border-color var(--t-hover),
      box-shadow var(--t-hover),
      transform var(--t-hover);
  }
  .value-card:hover {
    border-color: var(--coral);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .value-num {
    font-family: var(--font-heading);
    font-weight: 800;
    color: var(--coral);
    font-size: 14px;
    letter-spacing: 0.18em;
    margin-bottom: 1.5rem;
    display: block;
  }
  .value-card h3 {
    font-size: 1.35rem;
    color: var(--navy-deep);
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }
  .value-card p {
    color: var(--slate);
    font-size: 15px;
    line-height: 1.6;
  }

  /* ── Approach / Practice ── */
  .approach {
    background: var(--off-white);
    padding: var(--pad-s) var(--pad-x);
    border-top: 1px solid var(--border);
  }
  .approach-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }
  .approach-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }
  .approach-header .eyebrow {
    margin-bottom: 1rem;
  }
  .approach-header h2 {
    color: var(--navy-deep);
    font-size: clamp(2rem, 3.2vw, 2.6rem);
    letter-spacing: -0.02em;
  }
  .approach-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--border);
  }
  .approach-row {
    display: grid;
    grid-template-columns: 220px 1fr 1fr;
    gap: 2rem;
    padding: 2rem 0;
    border-bottom: 1px solid var(--border);
    align-items: start;
  }
  .approach-num {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--coral);
    padding-top: 3px;
  }
  .approach-title {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.05rem;
    color: var(--navy-deep);
    line-height: 1.3;
    letter-spacing: -0.01em;
  }
  .approach-body {
    color: var(--slate);
    font-size: 15px;
    line-height: 1.65;
  }

  /* ── CTA ── */
  .about-cta {
    background: var(--navy-deep);
    padding: var(--pad-s) var(--pad-x);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .about-cta-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0.22;
  }
  .about-cta-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(10, 45, 82, 0.92) 0%, rgba(16, 67, 120, 0.85) 100%);
  }
  .about-cta-inner {
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .about-cta .eyebrow {
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 1rem;
  }
  .about-cta h2 {
    color: var(--white);
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }
  .about-cta p {
    color: rgba(255, 255, 255, 0.82);
    font-size: 17px;
    line-height: 1.65;
    margin-bottom: 2rem;
    max-width: 560px;
    margin-inline: auto;
    margin-bottom: 2rem;
  }
  .about-cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .approach-row {
      grid-template-columns: 200px 1fr;
      gap: 1.25rem;
    }
    .approach-body {
      grid-column: 2 / -1;
    }
  }

  @media (max-width: 768px) {
    .about-hero {
      grid-template-columns: 1fr;
      max-height: none;
      min-height: 0;
    }
    .about-hero-image {
      height: 360px;
      order: -1;
    }
    .about-hero-content {
      padding: 3rem 2.5rem;
    }
    .story-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .story-image {
      aspect-ratio: 16/10;
      max-height: 440px;
    }
    .values-grid {
      grid-template-columns: 1fr;
    }
    .approach-row {
      grid-template-columns: 1fr;
      gap: 0.5rem;
      padding: 1.5rem 0;
    }
    .approach-body {
      grid-column: 1;
    }
    .approach-num {
      font-size: 12px;
    }
  }

  @media (max-width: 480px) {
    .about-hero-image {
      height: 260px;
    }
    .about-hero-content {
      padding: 2.5rem 1.75rem;
    }
  }
</style>
