---
/**
 * Purpose: Communities page — raw HTML injection from design-source/pages/Communities.html
 * Context: Route /communities/
 * Source: design-source/pages/Communities.html, apps/studio/schemas/singletons/communitiesPage.ts
 */

import { sanityClient } from 'sanity:client';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  COMMUNITIES_PAGE_QUERY,
  CONDITIONS_COMMUNITIES_QUERY,
  SITE_SETTINGS_QUERY,
} from '../lib/queries';

interface CtaLink {
  label: string;
  href: string;
  variant?: string;
}

interface ImageWithAlt {
  asset?: { url: string };
  alt?: string;
}

interface ProcessStep {
  stepNumber?: number;
  heading?: string;
  body?: string;
}

interface HandlesItem {
  heading?: string;
  body?: string;
}

interface SeoFields {
  metaTitle?: string;
  metaDescription?: string;
}

interface CommunitiesPage {
  heroHeading?: string;
  heroSubhead?: string;
  heroCta?: CtaLink;
  heroImage?: ImageWithAlt;
  processEyebrow?: string;
  processHeading?: string;
  processSubhead?: string;
  processSteps?: ProcessStep[];
  handlesEyebrow?: string;
  handlesHeading?: string;
  handlesSubhead?: string;
  handlesItems?: HandlesItem[];
  conditionsEyebrow?: string;
  conditionsHeading?: string;
  conditionsSubhead?: string;
  serviceAreaHeading?: string;
  serviceAreaLede?: string;
  ctaHeading?: string;
  ctaSubhead?: string;
  ctaCta?: CtaLink;
  seo?: SeoFields;
}

interface Condition {
  _id: string;
  tagline?: string;
  heading?: string;
  body?: string;
}

interface SiteSettings {
  phone?: string;
}

const [page, conditionsData, siteSettings] = await Promise.all([
  sanityClient.fetch<CommunitiesPage>(COMMUNITIES_PAGE_QUERY),
  sanityClient.fetch<Condition[]>(CONDITIONS_COMMUNITIES_QUERY),
  sanityClient.fetch<SiteSettings>(SITE_SETTINGS_QUERY),
]);
---

<style is:global>
  /* ════════════════════════════════════════════════════════════════════
   Faithful HTML port of the 6 uploaded Relume components for /communities/:
   Navbar1 → Header84 → Layout521 → Layout16 → Layout526 → Layout192 → Cta25 → Footer3
   STRUCTURE/UX is unchanged from Relume. Only the visual tokens
   (colors, fonts, headings) have been swapped to the BYT design system.
════════════════════════════════════════════════════════════════════ */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    /* BYT design system tokens */
    --byt-navy: #104378;
    --byt-navy-deep: #0a2d52;
    --byt-navy-footer: #2d2d52;
    --byt-coral: #e05555;
    --byt-coral-hover: #c94444;
    --byt-coral-light: #fce8e8;
    --byt-sage: #9caf88;
    --byt-sage-light: #e8efe3;
    --byt-slate: #5a7194;
    --byt-mist: #8fa3bf;
    --byt-border: #e4eaf0;
    --byt-off-white: #f5f7fa;
    --byt-cream: #fffcf0;

    /* Radii */
    --r-btn: 6px;
    --r-card: 12px;
    --r-pill: 999px;

    /* Shadows */
    --shadow-sm: 0 1px 2px rgba(16, 67, 120, 0.04);
    --shadow-md: 0 4px 12px rgba(16, 67, 120, 0.08);
    --shadow-lg: 0 8px 24px rgba(16, 67, 120, 0.1);

    /* Relume token names mapped to BYT palette */
    --bg-primary: #ffffff;
    --bg-alt: #f5f7fa;
    --text-primary: #0a2d52;
    --text-alt: #ffffff;
    --border-primary: #e4eaf0;
  }

  html {
    -webkit-text-size-adjust: 100%;
  }
  body {
    font-family:
      'Montserrat',
      system-ui,
      -apple-system,
      Segoe UI,
      Roboto,
      sans-serif;
    color: var(--byt-slate);
    background: var(--bg-primary);
    line-height: 1.5;
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family:
      'Manrope',
      system-ui,
      -apple-system,
      sans-serif;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--byt-navy-deep);
  }
  img {
    display: block;
    max-width: 100%;
  }
  a {
    color: inherit;
    text-decoration: none;
  }
  button {
    font: inherit;
    cursor: pointer;
    border: 0;
    background: transparent;
    color: inherit;
  }
  ul {
    list-style: none;
  }

  /* Container */
  .container {
    width: 100%;
    margin-inline: auto;
    max-width: 80rem;
  }
  .section {
    padding: 64px 5%;
  }
  @media (min-width: 768px) {
    .section {
      padding: 96px 5%;
    }
  }
  @media (min-width: 1024px) {
    .section {
      padding: 112px 5%;
    }
  }

  /* Type scale */
  .text-md {
    font-size: 1.125rem;
    line-height: 1.5;
  }
  .text-sm {
    font-size: 0.875rem;
    line-height: 1.4;
  }
  .text-xl {
    font-size: 1.25rem;
    line-height: 1.4;
  }
  .text-2xl {
    font-size: 1.5rem;
    line-height: 1.3;
  }
  .text-4xl {
    font-size: 2.25rem;
    line-height: 1.2;
  }
  .text-5xl {
    font-size: 3rem;
    line-height: 1.1;
  }
  .font-bold {
    font-weight: 700;
  }
  .font-semibold {
    font-weight: 600;
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border: 1.5px solid var(--byt-navy);
    font-family: 'Montserrat', sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: 0.01em;
    background: var(--bg-primary);
    color: var(--byt-navy-deep);
    border-radius: var(--r-btn);
    transition:
      background-color 0.15s,
      color 0.15s,
      border-color 0.15s,
      box-shadow 0.15s,
      transform 0.15s;
    white-space: nowrap;
  }
  .btn:hover {
    transform: translateY(-1px);
  }
  .btn-primary {
    background: var(--byt-coral);
    color: #fff;
    border-color: var(--byt-coral);
  }
  .btn-primary:hover {
    background: var(--byt-coral-hover);
    border-color: var(--byt-coral-hover);
    box-shadow: var(--shadow-md);
  }
  .btn-secondary {
    background: transparent;
    color: var(--byt-navy-deep);
    border-color: var(--byt-navy-deep);
  }
  .btn-secondary:hover {
    background: var(--byt-navy-deep);
    color: #fff;
  }
  .btn-secondary-alt {
    background: transparent;
    color: #fff;
    border-color: #fff;
  }
  .btn-secondary-alt:hover {
    background: #fff;
    color: var(--byt-navy-deep);
  }
  .btn-link {
    background: transparent;
    border: 0;
    padding: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    color: var(--byt-coral);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }
  .btn-link:hover {
    color: var(--byt-coral-hover);
  }
  .btn-link.alt {
    color: #fff;
  }
  .btn-link.alt:hover {
    color: rgba(255, 255, 255, 0.8);
  }
  .btn-link svg {
    width: 1em;
    height: 1em;
  }

  /* ════════════════════════════════════════════════════════════════
   NAV — synced with Homepage.html / Providers.html
══════════════════════════════════════════════════════════════════ */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #fff;
    height: 84px;
    display: flex;
    align-items: center;
    padding: 0 5%;
    border-bottom: 1px solid var(--byt-border);
    box-shadow: var(--shadow-sm);
  }
  .nav-inner {
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    height: 68px;
  }
  .nav-logo img {
    height: 64px;
    width: auto;
    display: block;
  }
  .nav-links {
    display: flex;
    gap: 2rem;
  }
  .nav-links a {
    color: var(--byt-navy-deep);
    font-size: 15px;
    font-weight: 500;
    transition: color 0.2s;
    letter-spacing: 0.01em;
  }
  .nav-links a:hover,
  .nav-links a.active {
    color: var(--byt-coral);
  }
  .nav-actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }
  .nav-cta {
    border: none;
    background: var(--byt-coral);
    color: #fff;
    padding: 12px 20px;
    border-radius: var(--r-btn);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.01em;
    font-family: inherit;
    cursor: pointer;
    transition: background-color 0.2s;
  }
  .nav-cta:hover {
    background: var(--byt-coral-hover);
  }
  .nav-cta-secondary {
    border: none;
    background: transparent;
    color: var(--byt-navy-deep);
    font-size: 14px;
    font-weight: 500;
    padding: 12px 20px;
    border-radius: var(--r-btn);
    font-family: inherit;
    cursor: pointer;
    transition: color 0.2s;
  }
  .nav-cta-secondary:hover {
    color: var(--byt-coral);
  }

  .nav-hamburger {
    display: none;
    background: transparent;
    border: none;
    cursor: pointer;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    padding: 0;
    margin-right: -8px;
    color: var(--byt-navy-deep);
  }
  .nav-hamburger svg {
    width: 26px;
    height: 26px;
  }

  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: none;
    background: rgba(10, 45, 82, 0.5);
    backdrop-filter: blur(4px);
  }
  .mobile-menu.open {
    display: block;
  }
  .mobile-menu-panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(86vw, 360px);
    background: #fff;
    padding: 20px 24px 32px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    box-shadow: -8px 0 32px rgba(10, 45, 82, 0.15);
    animation: mmSlide 0.25s ease-out;
  }
  @keyframes mmSlide {
    from {
      transform: translateX(100%);
    }
    to {
      transform: none;
    }
  }
  .mobile-menu-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 16px;
    margin-bottom: 12px;
    border-bottom: 1px solid var(--byt-border);
  }
  .mobile-menu-close {
    background: transparent;
    border: none;
    cursor: pointer;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--byt-navy-deep);
    margin-right: -8px;
  }
  .mobile-menu-close svg {
    width: 22px;
    height: 22px;
  }
  .mobile-menu a.mm-link {
    display: block;
    padding: 14px 4px;
    font-family: 'Manrope', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: var(--byt-navy-deep);
    border-bottom: 1px solid var(--byt-border);
    transition: color 0.2s;
  }
  .mobile-menu a.mm-link:hover {
    color: var(--byt-coral);
  }
  .mobile-menu-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 20px;
  }
  .mobile-menu-actions .btn {
    width: 100%;
    justify-content: center;
  }

  .mobile-cta-bar {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 99;
    background: #fff;
    border-top: 1px solid var(--byt-border);
    box-shadow: 0 -4px 20px rgba(10, 45, 82, 0.08);
    padding: 10px 12px calc(10px + env(safe-area-inset-bottom, 0px));
    gap: 8px;
    align-items: stretch;
  }
  .mobile-cta-bar .btn {
    flex: 1;
    justify-content: center;
    padding: 14px 12px;
    font-size: 14px;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .nav {
      height: 72px !important;
      padding: 0 32px;
    }
    .nav-logo {
      height: 52px !important;
    }
    .nav-logo img {
      height: 48px !important;
      width: auto !important;
      max-width: none !important;
    }
    .nav-links {
      display: none !important;
    }
    .nav-actions {
      display: none !important;
    }
    .nav-hamburger {
      display: flex !important;
      margin-left: auto !important;
      margin-right: -8px !important;
    }
  }
  @media (max-width: 768px) {
    body {
      padding-bottom: 78px;
    }
    .nav {
      height: 64px !important;
      padding: 0 20px;
    }
    .nav-logo {
      height: 48px !important;
    }
    .nav-logo img {
      height: 44px !important;
      width: auto !important;
      max-width: none !important;
    }
    .nav-actions {
      display: none !important;
    }
    .nav-hamburger {
      display: flex !important;
    }
    .mobile-cta-bar {
      display: flex !important;
    }
  }

  /* ════════════════════════════════════════════════════════════════
   Header84 — split hero (text left, image right) inside bordered card
══════════════════════════════════════════════════════════════════ */
  .h84 {
    padding: 0;
  }
  .h84 > .container {
    max-width: none;
    padding: 0;
  }

  .h84-grid {
    display: grid;
    grid-auto-columns: 1fr;
    grid-template-columns: 1fr;
    overflow: hidden;
    border-radius: 0;
    border: 0;
  }
  @media (min-width: 1024px) {
    .h84-grid {
      grid-template-columns: 1fr 1fr;
      min-height: 640px;
    }
  }
  @media (min-width: 1280px) {
    .h84-grid {
      min-height: 720px;
    }
  }

  .h84-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2rem;
  }
  @media (min-width: 768px) {
    .h84-text {
      padding: 3rem;
    }
  }
  @media (min-width: 1024px) {
    .h84-text {
      padding: 4rem;
    }
  }

  .h84-eyebrow {
    display: inline-block;
    align-self: flex-start;
    margin-bottom: 1.25rem;
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--byt-coral);
  }

  .h84 h1 {
    margin-bottom: 1.25rem;
    font-size: 2.5rem;
    line-height: 1.05;
    font-weight: 800;
    letter-spacing: -0.02em;
  }
  @media (min-width: 768px) {
    .h84 h1 {
      margin-bottom: 1.5rem;
      font-size: 3.5rem;
    }
  }
  @media (min-width: 1024px) {
    .h84 h1 {
      font-size: 4.25rem;
    }
  }

  .h84 .lede {
    color: var(--byt-slate);
    font-size: 1.0625rem;
    line-height: 1.55;
    max-width: 34rem;
  }
  @media (min-width: 768px) {
    .h84 .lede {
      font-size: 1.125rem;
    }
  }

  .h84-actions {
    margin-top: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.875rem;
  }
  @media (min-width: 768px) {
    .h84-actions {
      margin-top: 2rem;
    }
  }

  .h84-image {
    position: relative;
    display: flex;
    align-items: stretch;
    justify-content: stretch;
    background: linear-gradient(135deg, var(--byt-navy-deep) 0%, var(--byt-navy) 100%);
    min-height: 320px;
  }
  @media (min-width: 1024px) {
    .h84-image {
      min-height: auto;
    }
  }
  .h84-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .h84-image::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(180deg, rgba(10, 45, 82, 0.08) 0%, rgba(10, 45, 82, 0) 35%);
  }

  /* ════════════════════════════════════════════════════════════════
   Layout521 — 4-step process with image-bg dark cards
══════════════════════════════════════════════════════════════════ */
  #l521-section {
    background: var(--byt-off-white);
  }

  .l521-head {
    margin-inline: auto;
    margin-bottom: 48px;
    width: 100%;
    max-width: 48rem;
    text-align: center;
  }
  @media (min-width: 768px) {
    .l521-head {
      margin-bottom: 72px;
    }
  }
  @media (min-width: 1024px) {
    .l521-head {
      margin-bottom: 80px;
    }
  }
  .l521-eyebrow {
    display: inline-block;
    margin-bottom: 1rem;
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--byt-coral);
  }
  .l521-head h2 {
    margin-bottom: 1.25rem;
    font-size: 2.25rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
  @media (min-width: 768px) {
    .l521-head h2 {
      margin-bottom: 1.5rem;
      font-size: 2.75rem;
    }
  }
  @media (min-width: 1024px) {
    .l521-head h2 {
      font-size: 3.25rem;
    }
  }
  .l521-head .text-md {
    color: var(--byt-slate);
  }

  .l521-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) {
    .l521-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (min-width: 768px) {
    .l521-grid {
      gap: 2rem;
    }
  }
  @media (min-width: 1024px) {
    .l521-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .l521-card {
    position: relative;
    border-radius: var(--r-card);
    overflow: hidden;
    min-height: 360px;
    color: #fff;
    box-shadow: var(--shadow-md);
    transition:
      transform 0.25s,
      box-shadow 0.25s;
  }
  .l521-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }
  .l521-card-img {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .l521-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .l521-card-img::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10, 45, 82, 0.45) 0%,
      rgba(10, 45, 82, 0.7) 60%,
      rgba(10, 45, 82, 0.92) 100%
    );
  }
  .l521-card-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    height: 100%;
    min-height: 360px;
    padding: 1.5rem;
  }
  @media (min-width: 768px) {
    .l521-card-content {
      padding: 2rem;
    }
  }

  .l521-step {
    position: absolute;
    top: 1.25rem;
    left: 1.5rem;
    z-index: 1;
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 0.875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.85);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .l521-step .num {
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    border: 1.5px solid rgba(255, 255, 255, 0.6);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    letter-spacing: 0;
    color: #fff;
  }
  @media (min-width: 768px) {
    .l521-step {
      top: 1.5rem;
      left: 2rem;
    }
  }

  .l521-icon {
    margin-bottom: 0.875rem;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.25);
  }
  .l521-icon svg {
    width: 1.25rem;
    height: 1.25rem;
  }
  .l521-card h3 {
    margin-bottom: 0.625rem;
    font-size: 1.25rem;
    font-weight: 800;
    line-height: 1.2;
    color: #fff;
    letter-spacing: -0.01em;
  }
  @media (min-width: 768px) {
    .l521-card h3 {
      font-size: 1.375rem;
    }
  }
  .l521-card p {
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.9375rem;
    line-height: 1.5;
  }

  /* ════════════════════════════════════════════════════════════════
