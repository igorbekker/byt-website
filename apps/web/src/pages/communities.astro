  <section id="cta" class="section cta25-section">
    <div class="container">
      <div class="cta25-inner">
        <h2>{page?.ctaHeading ?? 'Ready to start'}</h2>
        <p>
          {
            page?.ctaSubhead ??
              'Submit a resident referral. We handle scheduling, credentialing, and billing from day one.'
          }
        </p>
        <div class="cta25-actions">
          <button class="btn btn-primary" onclick="openModal('refer')"
            >{page?.ctaCta?.label ?? 'Refer a Resident'}</button
          >
          <a
            href={`tel:${(siteSettings?.phone ?? '7549990011').replace(/\D/g, '')}`}
            class="btn btn-secondary-alt">Call {siteSettings?.phone ?? '754-999-0011'}</a
          >
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      const root = document.getElementById('l505');
      if (!root) return;
      const triggers = root.querySelectorAll('.l505-trigger');
      const panels = root.querySelectorAll('.l505-panel');
      triggers.forEach(function (btn) {
        btn.addEventListener('click', function () {
          const key = btn.getAttribute('data-tab');
          triggers.forEach(function (b) {
            b.classList.toggle('active', b === btn);
          });
          panels.forEach(function (p) {
            p.classList.toggle('active', p.getAttribute('data-panel') === key);
          });
        });
      });
    })();
  </script>
</BaseLayout>
