---
/**
 * Purpose: Blog index page — raw HTML injection from design-source/pages/Blog.html
 * Context: Route /blog/
 * Source: design-source/pages/Blog.html, apps/studio/schemas/singletons/blogIndexPage.ts
 */

import { sanityClient } from 'sanity:client';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  BLOG_INDEX_PAGE_QUERY,
  BLOG_CATEGORIES_QUERY,
  BLOG_POSTS_ALL_QUERY,
  BLOG_FEATURED_POST_QUERY,
} from '../../lib/queries';

interface BlogIndexPage {
  heroHeading?: string;
  heroSubhead?: string;
  featuredLabel?: string;
  browseByTopicHeading?: string;
  browseByTopicSubhead?: string;
  recentlyPublishedHeading?: string;
  newsletterHeading?: string;
  newsletterSubhead?: string;
}

interface BlogCategory {
  _id: string;
  title: string;
  slug: { current: string };
  description?: string;
  icon?: string;
  postCount?: number;
}

interface BlogPostCard {
  _id: string;
  title: string;
  slug: { current: string };
  publishedAt?: string;
  readingTimeMinutes?: number;
  excerpt?: string;
  category?: { title: string; slug: { current: string } };
  author?: { name: string; credentials?: string; initials?: string };
}

const [page, categories, posts, featured] = await Promise.all([
  sanityClient.fetch<BlogIndexPage>(BLOG_INDEX_PAGE_QUERY),
  sanityClient.fetch<BlogCategory[]>(BLOG_CATEGORIES_QUERY),
  sanityClient.fetch<BlogPostCard[]>(BLOG_POSTS_ALL_QUERY),
  sanityClient.fetch<BlogPostCard>(BLOG_FEATURED_POST_QUERY),
]);

function fmtDate(iso: string | undefined): string {
  if (!iso) return '';
  return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}
---

<style is:global>
  /* ════════════════════════════════════════════════
   BETTER YOU THERAPY — Shared base
   Nav + Footer + tokens + buttons (used by all blog pages)
════════════════════════════════════════════════ */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --navy: #104378;
    --navy-deep: #0a2d52;
    --navy-footer: #2d2d52;
    --white: #ffffff;
    --off-white: #f5f7fa;
    --cream: #fffcf0;
    --slate: #5a7194;
    --mist: #8fa3bf;
    --border: #e4eaf0;
    --coral: #e05555;
    --coral-hover: #c94444;
    --coral-light: #fce8e8;
    --sage: #9caf88;
    --sage-hover: #7a9468;
    --sage-light: #e8efe3;

    --r-btn: 6px;
    --r-card: 12px;
    --r-lg: 12px;
    --r-pill: 999px;

    --shadow-sm: 0 1px 2px rgba(16, 67, 120, 0.04);
    --shadow-md: 0 4px 12px rgba(16, 67, 120, 0.08);
    --shadow-lg: 0 8px 24px rgba(16, 67, 120, 0.1);

    --t-hover: 150ms ease;

    --max-w: 1200px;
    --pad-x: 64px;
    --pad-s: 80px;
  }

  html {
    scroll-behavior: smooth;
  }
  body {
    font-family:
      'Montserrat',
      system-ui,
      -apple-system,
      sans-serif;
    color: var(--slate);
    background: var(--white);
    line-height: 1.55;
    font-size: 15px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
  }
  img {
    display: block;
    max-width: 100%;
  }
  a {
    text-decoration: none;
    color: inherit;
  }
  h1,
  h2,
  h3,
  h4,
  h5 {
    font-family:
      'Manrope',
      system-ui,
      -apple-system,
      sans-serif;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--navy-deep);
    text-wrap: balance;
  }
  p {
    text-wrap: pretty;
  }

  .eyebrow {
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--coral);
  }
  .max-w {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .fade-up {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.6s ease,
      transform 0.6s ease;
  }
  .fade-up.visible {
    opacity: 1;
    transform: none;
  }

  /* BUTTONS */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 14px 24px;
    border-radius: var(--r-btn);
    font-family: 'Montserrat', sans-serif;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition:
      background-color var(--t-hover),
      border-color var(--t-hover),
      color var(--t-hover);
    border: 1.5px solid transparent;
    white-space: nowrap;
    line-height: 1;
  }
  .btn-coral {
    background: var(--coral);
    color: #fff;
    border-color: var(--coral);
  }
  .btn-coral:hover {
    background: var(--coral-hover);
    border-color: var(--coral-hover);
  }
  .btn-ink {
    background: var(--navy);
    color: #fff;
    border-color: var(--navy);
  }
  .btn-ink:hover {
    background: var(--navy-deep);
    border-color: var(--navy-deep);
  }
  .btn-outline-white {
    background: transparent;
    color: #fff;
    border-color: rgba(255, 255, 255, 0.5);
  }
  .btn-outline-white:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: #fff;
  }
  .btn-outline-ink {
    background: transparent;
    color: var(--navy);
    border-color: var(--navy);
  }
  .btn-outline-ink:hover {
    background: var(--navy);
    color: #fff;
  }
  .btn-outline-navy {
    background: transparent;
    color: var(--navy-deep);
    border-color: var(--navy-deep);
  }
  .btn-outline-navy:hover {
    background: var(--navy-deep);
    color: #fff;
  }
  .btn-outline-coral {
    background: transparent;
    color: var(--coral);
    border-color: var(--coral);
  }
  .btn-outline-coral:hover {
    background: var(--coral);
    color: #fff;
  }

  /* NAV */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--white);
    height: 84px;
    display: flex;
    align-items: center;
    padding: 0 var(--pad-x);
    border-bottom: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
  }
  .nav-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    height: 68px;
  }
  .nav-logo img {
    height: 64px;
    width: auto;
    display: block;
  }
  .nav-links {
    display: flex;
    gap: 2rem;
  }
  .nav-links a {
    color: var(--navy-deep);
    font-size: 15px;
    font-weight: 500;
    transition: color var(--t-hover);
    letter-spacing: 0.01em;
  }
  .nav-links a:hover {
    color: var(--coral);
  }
  .nav-actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }
  .nav-cta {
    background: var(--coral);
    color: #fff;
    padding: 12px 20px;
    border-radius: var(--r-btn);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.01em;
    transition: background-color var(--t-hover);
  }
  .nav-cta:hover {
    background: var(--coral-hover);
  }
  .nav-cta-secondary {
    color: var(--navy-deep);
    font-size: 14px;
    font-weight: 500;
    padding: 12px 20px;
    border-radius: var(--r-btn);
    transition: color var(--t-hover);
  }
  .nav-cta-secondary:hover {
    color: var(--coral);
  }
  .nav-hamburger {
    display: none;
    background: transparent;
    border: none;
    cursor: pointer;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    padding: 0;
    margin-right: -8px;
    color: var(--navy-deep);
  }
  .nav-hamburger svg {
    width: 26px;
    height: 26px;
  }

  /* Mobile menu */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: none;
    background: rgba(10, 45, 82, 0.5);
    backdrop-filter: blur(4px);
  }
  .mobile-menu.open {
    display: block;
  }
  .mobile-menu-panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(86vw, 360px);
    background: #fff;
    padding: 20px 24px 32px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    box-shadow: -8px 0 32px rgba(10, 45, 82, 0.15);
    animation: mmSlide 0.25s ease-out;
  }
  @keyframes mmSlide {
    from {
      transform: translateX(100%);
    }
    to {
      transform: none;
    }
  }
  .mobile-menu-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 16px;
    margin-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }
  .mobile-menu-close {
    background: transparent;
    border: none;
    cursor: pointer;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--navy-deep);
    margin-right: -8px;
  }
  .mobile-menu-close svg {
    width: 22px;
    height: 22px;
  }
  .mobile-menu a.mm-link {
    display: block;
    padding: 14px 4px;
    font-family: 'Manrope', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: var(--navy-deep);
    border-bottom: 1px solid var(--border);
    transition: color var(--t-hover);
  }
  .mobile-menu a.mm-link:hover {
    color: var(--coral);
  }
  .mobile-menu-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 20px;
  }
  .mobile-menu-actions .btn {
    width: 100%;
    justify-content: center;
  }

  /* FOOTER */
  .footer {
    background: var(--navy-deep);
    color: rgba(255, 255, 255, 0.68);
    padding: 4rem var(--pad-x) 2rem;
  }
  .footer-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.2fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }
  .footer-logo {
    margin-bottom: 1rem;
    display: block;
  }
  .footer-logo img {
    height: 100px;
    width: auto;
    display: block;
  }
  .footer-tagline {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.65;
    margin-bottom: 1.5rem;
    max-width: 360px;
  }
  .footer-contact {
    font-size: 14px;
    line-height: 1.85;
    color: rgba(255, 255, 255, 0.6);
  }
  .footer-contact a {
    color: rgba(255, 255, 255, 0.6);
    transition: color var(--t-hover);
  }
  .footer-contact a:hover {
    color: #fff;
  }
  .footer-grid h4 {
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }
  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .footer-links a {
    color: rgba(255, 255, 255, 0.6);
    font-size: 14px;
    transition: color var(--t-hover);
  }
  .footer-links a:hover {
    color: #fff;
  }

  /* ── Footer Newsletter (column variant) ───────── */
  .footer-newsletter-pitch {
    font-size: 14px;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.62);
    margin: -0.25rem 0 1rem;
  }
  .footer-newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .footer-newsletter-form input {
    width: 100%;
    min-width: 0;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.16);
    color: #fff;
    font-size: 14px;
    font-family: inherit;
    padding: 11px 14px;
    border-radius: var(--r-btn);
    transition:
      border-color var(--t-hover),
      background-color var(--t-hover);
  }
  .footer-newsletter-form input::placeholder {
    color: rgba(255, 255, 255, 0.42);
  }
  .footer-newsletter-form input:focus {
    outline: none;
    border-color: var(--coral);
    background: rgba(255, 255, 255, 0.1);
  }
  .footer-newsletter-form button {
    width: 100%;
    padding: 11px 16px;
    font-size: 14px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
  }
  .footer-newsletter-form button:disabled {
    opacity: 0.85;
    cursor: default;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  /* ──────────────────────────────────────────────── */

  .footer-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
    margin-bottom: 1.5rem;
  }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.45);
  }
  .footer-legal {
    display: flex;
    gap: 1.5rem;
  }
  .footer-legal a {
    color: rgba(255, 255, 255, 0.45);
    transition: color var(--t-hover);
  }
  .footer-legal a:hover {
    color: #fff;
  }
  .social-links {
    display: flex;
    gap: 0.6rem;
    margin-top: 1.25rem;
  }
  .social-link {
    width: 36px;
    height: 36px;
    border-radius: var(--r-btn);
    border: 1px solid rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--t-hover);
    color: rgba(255, 255, 255, 0.55);
  }
  .social-link:hover {
    border-color: rgba(255, 255, 255, 0.4);
    color: #fff;
    background: rgba(255, 255, 255, 0.06);
  }

  /* Mobile sticky CTA */
  .mobile-cta-bar {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 99;
    background: #fff;
    border-top: 1px solid var(--border);
    box-shadow: 0 -4px 20px rgba(10, 45, 82, 0.08);
    padding: 10px 12px calc(10px + env(safe-area-inset-bottom, 0px));
    gap: 8px;
    align-items: stretch;
  }
  .mobile-cta-bar .btn {
    flex: 1;
    justify-content: center;
    padding: 14px 12px;
    font-size: 14px;
    margin: 0;
  }

  /* RESPONSIVE — nav/footer */
  @media (max-width: 1024px) {
    :root {
      --pad-x: 32px;
      --pad-s: 64px;
    }
    .nav {
      height: 72px !important;
    }
    .nav-logo {
      height: 52px !important;
    }
    .nav-logo img {
      height: 48px !important;
      width: auto !important;
      max-width: none !important;
    }
    .nav-links {
      display: none !important;
    }
    .nav-actions {
      display: none !important;
    }
    .nav-hamburger {
      display: flex !important;
      margin-left: auto !important;
      margin-right: -8px !important;
    }
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }
  }
  @media (max-width: 768px) {
    :root {
      --pad-x: 20px;
      --pad-s: 56px;
    }
    body {
      padding-bottom: 78px;
    }
    .nav {
      height: 64px !important;
    }
    .nav-logo {
      height: 48px !important;
    }
    .nav-logo img {
      height: 44px !important;
      width: auto !important;
      max-width: none !important;
    }
    .mobile-cta-bar {
      display: flex !important;
    }
    .footer-grid {
      grid-template-columns: 1fr;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 1rem;
    }
  }

  /* ════════════════════════════════════════════════
   BLOG SYSTEM — shared across all blog pages
════════════════════════════════════════════════ */

  /* Image placeholder system — striped SVG with a label */
  .img-ph {
    background-color: var(--off-white);
    background-image: repeating-linear-gradient(
      135deg,
      rgba(16, 67, 120, 0.06) 0,
      rgba(16, 67, 120, 0.06) 1px,
      transparent 1px,
      transparent 12px
    );
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--mist);
    font-family: 'JetBrains Mono', 'Menlo', monospace;
    font-size: 11px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    overflow: hidden;
  }
  .img-ph::before {
    content: attr(data-label);
    background: rgba(255, 255, 255, 0.85);
    padding: 4px 10px;
    border-radius: 4px;
    border: 1px solid var(--border);
    white-space: nowrap;
  }
  .img-ph-coral {
    background-color: #fcecec;
    background-image: repeating-linear-gradient(
      135deg,
      rgba(224, 85, 85, 0.08) 0,
      rgba(224, 85, 85, 0.08) 1px,
      transparent 1px,
      transparent 12px
    );
  }
  .img-ph-sage {
    background-color: #eef2e8;
    background-image: repeating-linear-gradient(
      135deg,
      rgba(122, 148, 104, 0.1) 0,
      rgba(122, 148, 104, 0.1) 1px,
      transparent 1px,
      transparent 12px
    );
  }
  .img-ph-navy {
    background-color: #e7edf5;
    background-image: repeating-linear-gradient(
      135deg,
      rgba(16, 67, 120, 0.1) 0,
      rgba(16, 67, 120, 0.1) 1px,
      transparent 1px,
      transparent 12px
    );
  }

  /* ── BREADCRUMB ── */
  .crumb {
    background: var(--off-white);
    border-bottom: 1px solid var(--border);
    padding: 28px var(--pad-x);
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    letter-spacing: 0.02em;
  }
  .crumb-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--slate);
    flex-wrap: wrap;
  }
  .crumb a {
    color: var(--slate);
    transition: color var(--t-hover);
  }
  .crumb a:hover {
    color: var(--coral);
  }
  .crumb .sep {
    color: var(--mist);
  }
  .crumb .here {
    color: var(--navy-deep);
    font-weight: 600;
  }

  /* ── BLOG HERO (smaller than page heroes) ── */
  .blog-hero {
    background: var(--navy-deep);
    padding: clamp(3.5rem, 6vh, 5rem) var(--pad-x) clamp(3rem, 5vh, 4.5rem);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .blog-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(60% 80% at 50% 0%, rgba(224, 85, 85, 0.1) 0%, transparent 60%),
      radial-gradient(40% 60% at 80% 100%, rgba(255, 255, 255, 0.04) 0%, transparent 70%);
    pointer-events: none;
  }
  .blog-hero::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 1.25rem;
    width: 1px;
    height: 36px;
    background: var(--coral);
    opacity: 0.8;
  }
  .blog-hero-inner {
    max-width: 880px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .blog-hero .eyebrow {
    color: var(--coral);
    margin-bottom: 1.5rem;
  }
  .blog-hero h1 {
    color: #fff;
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin-bottom: 1.25rem;
    text-wrap: balance;
  }
  .blog-hero h1 em {
    color: var(--coral);
    font-style: normal;
  }
  .blog-hero p {
    color: rgba(255, 255, 255, 0.72);
    font-size: 17px;
    line-height: 1.6;
    max-width: 620px;
    margin: 0 auto;
    text-wrap: balance;
  }

  /* ── ARTICLE CARDS ── */
  .article-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--r-card);
    overflow: hidden;
    text-decoration: none;
    transition:
      border-color var(--t-hover),
      box-shadow var(--t-hover),
      transform var(--t-hover);
    height: 100%;
  }
  .article-card:hover {
    border-color: var(--coral);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .article-card-img {
    aspect-ratio: 16/10;
    background: var(--off-white);
  }
  .article-card-body {
    padding: 1.5rem 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.75rem;
  }
  .article-card-meta {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    color: var(--slate);
    font-weight: 500;
  }
  .article-card-cat {
    color: var(--coral);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 11px;
  }
  .article-card-meta .dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--mist);
  }
  .article-card h3 {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 1.2rem;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--navy-deep);
    margin: 0;
  }
  .article-card-snippet {
    color: var(--slate);
    font-size: 14px;
    line-height: 1.6;
    margin: 0;
  }
  .article-card-author {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    font-size: 13px;
    color: var(--slate);
  }
  .article-card-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--coral-light);
    color: var(--coral);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 0.02em;
    flex-shrink: 0;
  }
  .article-card-author strong {
    color: var(--navy-deep);
    font-weight: 600;
  }

  /* ── FILTER PILLS ── */
  .pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }
  .pill {
    display: inline-flex;
    align-items: center;
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 500;
    padding: 8px 14px;
    border-radius: var(--r-pill);
    border: 1px solid var(--border);
    background: #fff;
    color: var(--slate);
    cursor: pointer;
    transition: all var(--t-hover);
    letter-spacing: 0.01em;
  }
  .pill:hover {
    border-color: var(--coral);
    color: var(--coral);
  }
  .pill.active {
    background: var(--navy-deep);
    color: #fff;
    border-color: var(--navy-deep);
  }

  /* ── NEWSLETTER ── */
  .newsletter {
    background: var(--cream);
    padding: var(--pad-s) var(--pad-x);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .newsletter-inner {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }
  .newsletter .eyebrow {
    margin-bottom: 1rem;
  }
  .newsletter h2 {
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    color: var(--navy-deep);
  }
  .newsletter p {
    color: var(--slate);
    font-size: 17px;
    line-height: 1.6;
    margin-bottom: 2rem;
  }
  .newsletter-form {
    display: flex;
    gap: 0.5rem;
    max-width: 460px;
    margin: 0 auto;
  }
  .newsletter-form input {
    flex: 1;
    padding: 14px 16px;
    border: 1.5px solid var(--border);
    border-radius: var(--r-btn);
    font-family: 'Montserrat', sans-serif;
    font-size: 15px;
    background: #fff;
    color: var(--navy-deep);
    transition: border-color var(--t-hover);
  }
  .newsletter-form input:focus {
    outline: none;
    border-color: var(--coral);
  }
  .newsletter-form button {
    border: none;
    cursor: pointer;
    flex-shrink: 0;
  }
  .newsletter-tiny {
    font-size: 12px;
    color: var(--mist);
    margin-top: 0.85rem;
    margin-bottom: 0;
  }

  /* ── RESPONSIVE — blog ── */
  @media (max-width: 768px) {
    .newsletter-form {
      flex-direction: column;
    }
  }

  /* ── BLOG HOMEPAGE ── */
  .featured {
    padding: clamp(3rem, 5vh, 4.5rem) var(--pad-x) clamp(2rem, 4vh, 3rem);
    background: var(--white);
  }
  .featured-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }
  .featured-card {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 0;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--r-card);
    overflow: hidden;
    transition:
      border-color var(--t-hover),
      box-shadow var(--t-hover);
  }
  .featured-card:hover {
    border-color: var(--coral);
    box-shadow: var(--shadow-lg);
  }
  .featured-img {
    min-height: 380px;
  }
  .featured-body {
    padding: 2.5rem 2.75rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
  }
  .featured-meta {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    color: var(--slate);
    font-weight: 500;
    flex-wrap: wrap;
  }
  .featured-tag {
    background: var(--coral);
    color: #fff;
    padding: 4px 10px;
    border-radius: var(--r-pill);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .featured-meta .dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--mist);
  }
  .featured-card h2 {
    font-size: clamp(1.6rem, 2.6vw, 2.2rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--navy-deep);
  }
  .featured-card h2 em {
    color: var(--coral);
    font-style: normal;
  }
  .featured-card p {
    color: var(--slate);
    font-size: 16px;
    line-height: 1.6;
  }
  .featured-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
    margin-top: 0.5rem;
    font-size: 14px;
    color: var(--slate);
  }
  .featured-author strong {
    color: var(--navy-deep);
    font-weight: 700;
  }
  .featured-author-sub {
    font-size: 12px;
    color: var(--mist);
    margin-top: 2px;
  }

  /* CATEGORIES */
  .categories {
    padding: var(--pad-s) var(--pad-x);
    background: var(--off-white);
  }
  .categories-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }
  .categories-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .categories-header .eyebrow {
    margin-bottom: 1rem;
  }
  .categories-header h2 {
    font-size: clamp(1.9rem, 3.2vw, 2.6rem);
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }
  .categories-header p {
    color: var(--slate);
    font-size: 17px;
    line-height: 1.6;
    max-width: 540px;
    margin: 0 auto;
  }
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .cat-tile {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--r-card);
    padding: 1.5rem;
    transition:
      border-color var(--t-hover),
      box-shadow var(--t-hover),
      transform var(--t-hover);
    position: relative;
    text-decoration: none;
  }
  .cat-tile:hover {
    border-color: var(--coral);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .cat-tile-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--r-btn);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .cat-tile-icon svg {
    width: 20px;
    height: 20px;
  }
  .cat-tile-body {
    flex: 1;
  }
  .cat-tile-body h3 {
    font-family: 'Manrope', sans-serif;
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--navy-deep);
    margin-bottom: 0.35rem;
  }
  .cat-tile-body p {
    font-size: 13px;
    color: var(--slate);
    line-height: 1.5;
    margin-bottom: 0.5rem;
  }
  .cat-tile-count {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--coral);
  }
  .cat-tile-arrow {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    color: var(--mist);
    font-size: 18px;
    transition:
      color var(--t-hover),
      transform var(--t-hover);
  }
  .cat-tile:hover .cat-tile-arrow {
    color: var(--coral);
    transform: translateX(3px);
  }

  /* LATEST */
  .latest {
    padding: var(--pad-s) var(--pad-x);
    background: var(--white);
  }
  .latest-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }
  .latest-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .latest-header .eyebrow {
    margin-bottom: 0.75rem;
  }
  .latest-header h2 {
    font-size: clamp(1.9rem, 3.2vw, 2.6rem);
    letter-spacing: -0.02em;
  }
  .latest-view-all {
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: var(--coral);
    transition: color var(--t-hover);
  }
  .latest-view-all:hover {
    color: var(--coral-hover);
  }
  .latest-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 3rem;
  }
  .load-more {
    display: flex;
    justify-content: center;
  }

  @media (max-width: 1024px) {
    .featured-card {
      grid-template-columns: 1fr;
    }
    .featured-img {
      min-height: 280px;
      aspect-ratio: 16/9;
    }
    .featured-body {
      padding: 2rem;
    }
    .cat-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .latest-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 768px) {
    .cat-grid {
      grid-template-columns: 1fr;
    }
    .latest-grid {
      grid-template-columns: 1fr;
    }
    .featured-body {
      padding: 1.5rem;
    }
    .featured-img {
      min-height: 220px;
    }
  }
</style>

<BaseLayout title="Blog | Better You Therapy">
  <section class="blog-hero">
    <div class="blog-hero-inner">
      <p class="eyebrow">The Better You Blog</p>
      <h1
        set:html={page?.heroHeading ??
          'Practical guidance for therapists, families, &amp; <em>the people we serve</em>.'}
      />
      <p>
        {
          page?.heroSubhead ??
            'Clinical insights, caregiver resources, and stories from our work with senior living communities across Florida.'
        }
      </p>
    </div>
  </section>

  <!-- ── BREADCRUMB ── -->
  <nav class="crumb">
    <div class="crumb-inner">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <span class="here">Blog</span>
    </div>
  </nav>

  <!-- ── FEATURED ── -->
  <section class="featured">
    <div class="featured-inner">
      <a href={`/blog/${featured?.slug?.current ?? '#'}/`} class="featured-card fade-up">
        <div class="featured-img img-ph img-ph-coral" data-label="Featured · senior reading"></div>
        <div class="featured-body">
          <div class="featured-meta">
            <span class="featured-tag">{page?.featuredLabel ?? 'Featured Article'}</span>
            <span class="dot"></span>
            <span>{fmtDate(featured?.publishedAt) || 'April 24, 2026'}</span>
            <span class="dot"></span>
            <span>{featured?.readingTimeMinutes ?? 9} min read</span>
          </div>
          <h2
            set:html={featured?.title ??
              'Why employers continue background checks <em>after</em> you&#39;re hired — and what it means for clinicians.'}
          />
          <p>
            {
              featured?.excerpt ??
                "Continuous monitoring is becoming the norm in healthcare hiring. Here's what licensed therapists need to know about staying compliant, what gets flagged, and how to protect your professional standing without losing sleep."
            }
          </p>
        </div>
      </a>
    </div>
  </section>

  <!-- ── CATEGORIES ── -->
  <section class="categories">
    <div class="categories-inner">
      <div class="categories-header fade-up">
        <p class="eyebrow">Browse by Topic</p>
        <h2>{page?.browseByTopicHeading ?? 'Find what you came for.'}</h2>
        <p>
          {
            page?.browseByTopicSubhead ??
              'Eight focus areas covering clinical practice, caregiver guidance, and the operational side of senior mental health.'
          }
        </p>
      </div>
      <div class="cat-grid">
        {
          categories?.map((cat) => (
            <a href={`/blog/${cat.slug.current}/`} class="cat-tile fade-up">
              <div class="cat-tile-icon" style="background:var(--coral-light); color:var(--coral)">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <>
                    <circle cx="11" cy="11" r="8" />
                    <path d="m21 21-4.3-4.3" />
                  </>
                </svg>
              </div>
              <div class="cat-tile-body">
                <h3>{cat.title}</h3>
                <p>{cat.description ?? ''}</p>
                <span class="cat-tile-count">{cat.postCount ?? 0} articles</span>
              </div>
              <span class="cat-tile-arrow">&rarr;</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── LATEST ARTICLES ── -->
  <section class="latest">
    <div class="latest-inner">
      <div class="latest-header fade-up">
        <div>
          <p class="eyebrow">Recently Published</p>
          <h2>{page?.recentlyPublishedHeading ?? 'Latest articles.'}</h2>
        </div>
        <a href="#" class="latest-view-all">View all articles &rarr;</a>
      </div>

      <div class="pill-row fade-up">
        <button class="pill active" data-cat="all">All Topics</button>
        {
          categories?.map((cat) => (
            <button class="pill" data-cat={cat.slug.current}>
              {cat.title}
            </button>
          ))
        }
      </div>

      <div class="latest-grid">
        {
          posts?.map((post) => (
            <a
              href={`/blog/${post.slug.current}/`}
              class="article-card fade-up"
              data-cat={post.category?.slug?.current ?? 'all'}
            >
              <div class="article-card-img img-ph img-ph-sage" data-label="Care setting" />
              <div class="article-card-body">
                <div class="article-card-meta">
                  <span class="article-card-cat">{post.category?.title ?? ''}</span>
                  <span class="dot" />
                  <span>{fmtDate(post.publishedAt)}</span>
                </div>
                <h3>{post.title}</h3>
                <p class="article-card-snippet">{post.excerpt}</p>
              </div>
            </a>
          ))
        }
      </div>

      <div class="load-more fade-up">
        <button type="button" class="btn btn-outline-navy">Load more articles</button>
      </div>
    </div>
  </section>

  <!-- ── NEWSLETTER ── -->
  <section class="newsletter">
    <div class="newsletter-inner fade-up">
      <p class="eyebrow">Stay in the loop</p>
      <h2>{page?.newsletterHeading ?? 'One thoughtful email a month.'}</h2>
      <p>
        {
          page?.newsletterSubhead ??
            'New articles, clinical resources, and the occasional behind-the-scenes note. No fluff, easy to unsubscribe.'
        }
      </p>
      <form
        class="newsletter-form"
        onsubmit="event.preventDefault(); this.innerHTML='<p style=padding:14px;color:var(--sage-hover);font-weight:600;>You\'re subscribed. Welcome.</p>';"
      >
        <input type="email" placeholder="you@example.com" required />
        <button type="submit" class="btn btn-coral">Subscribe</button>
      </form>
      <p class="newsletter-tiny">We never share your email. Unsubscribe in one click.</p>
    </div>
  </section>

  <script is:inline>
    const fadeObs = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            fadeObs.unobserve(e.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -40px 0px' },
    );
    document.querySelectorAll('.fade-up').forEach((el) => fadeObs.observe(el));
  </script>
</BaseLayout>
