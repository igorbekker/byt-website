</style>

<BaseLayout title={`${category?.title ?? 'Category'} | Better You Therapy Blog`}>
  <section class="blog-hero cat-hero">
    <div class="blog-hero-inner">
      <p class="eyebrow">Category</p>
      <h1 set:html={category?.title ?? 'Category'} />
      <p>{category?.description ?? ''}</p>
    </div>
  </section>

  <!-- ── BREADCRUMB ── -->
  <nav class="crumb">
    <div class="crumb-inner">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <a href="/blog/">Blog</a>
      <span class="sep">/</span>
      <span class="here">{category?.title ?? categorySlug}</span>
    </div>
  </nav>

  <!-- ── SUBCATEGORIES ── -->
  <section class="subcats">
    <div class="subcats-inner">
      <div class="subcats-header fade-up">
        <p class="eyebrow">Browse Subtopics</p>
        <h2>Pick the one that fits your situation.</h2>
      </div>

      <div class="subcat-blocks">
        {
          category?.subtopics?.map((sub, idx) => {
            const subPosts = posts?.filter((p) => p.subcategoryLabel === sub.slug) ?? [];
            const num = String(idx + 1).padStart(2, '0');
            return (
              <div class="subcat-block fade-up">
                <div class="subcat-block-head">
                  <span class="subcat-block-num">{num}</span>
                  <h3 class="subcat-block-title">
                    <a href={`/blog/${categorySlug}/${sub.slug}/`}>{sub.title}</a>
                  </h3>
                </div>
                <p class="subcat-block-desc">{sub.description ?? ''}</p>
                <ul class="subcat-block-articles">
                  {subPosts.slice(0, 6).map((p) => (
                    <li>
                      <a href={`/blog/${p.slug.current}/`}>{p.title}</a>
                    </li>
                  ))}
                </ul>
                <div class="subcat-block-foot">
                  <span class="subcat-block-count">{subPosts.length} articles</span>
                  <a href={`/blog/${categorySlug}/${sub.slug}/`} class="subcat-block-all">
                    View all &rarr;
                  </a>
                </div>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- ── ARTICLES IN THIS CATEGORY (level-1, parent-attached) ── -->
  <section class="article-list">
    <div class="article-list-inner">
      <div class="article-list-header fade-up">
        <p class="eyebrow">In this category</p>
        <h2>Articles tagged at the category level.</h2>
        <p>
          Cross-cutting pieces that don't belong to one subtopic — frameworks, overviews, and
          editorial essays that apply across the whole category. Browse the subtopics above for
          narrower threads.
        </p>
      </div>

      <div class="article-list-toolbar fade-up">
        <span class="toolbar-count">{categoryLevelPosts.length} articles</span>
        <div class="toolbar-sort">
          <label for="sort-cat">Sort</label>
          <select id="sort-cat" aria-label="Sort articles">
            <option>Most recent</option>
            <option>Most read</option>
            <option>Editor's picks</option>
          </select>
        </div>
      </div>

      <ul class="article-list-items">
        {
          categoryLevelPosts.map((post) => (
            <li class="article-row fade-up">
              <a
                href={`/blog/${post.slug.current}/`}
                class="article-row-img img-ph img-ph-coral"
                data-label="Article"
              />
              <div class="article-row-body">
                <div class="article-card-meta">
                  <span class="article-card-cat">{post.category?.title ?? ''}</span>
                  <span class="dot" />
                  <span>{fmtDate(post.publishedAt)}</span>
                  {post.readingTimeMinutes && (
                    <>
                      <span class="dot" />
                      <span>{post.readingTimeMinutes} min read</span>
                    </>
                  )}
                </div>
                <h3>
                  <a href={`/blog/${post.slug.current}/`}>{post.title}</a>
                </h3>
                <p>{post.excerpt}</p>
                <div class="article-row-foot">
                  <a href={`/blog/${post.slug.current}/`} class="article-row-cta">
                    Read article &rarr;
                  </a>
                </div>
              </div>
            </li>
          ))
        }
      </ul>

      <div class="pagination fade-up">
        <button class="page-btn" disabled>&larr; Previous</button>
        <span class="page-info">Page <strong>1</strong> of 1</span>
        <button class="page-btn" disabled>Next &rarr;</button>
      </div>
    </div>
  </section>

  <!-- ── NEWSLETTER ── -->
  <section class="newsletter">
    <div class="newsletter-inner fade-up">
      <p class="eyebrow">Stay in the loop</p>
      <h2>One thoughtful email a month.</h2>
      <p>
        New articles, clinical resources, and the occasional behind-the-scenes note. No fluff, easy
        to unsubscribe.
      </p>
      <form
        class="newsletter-form"
        onsubmit="event.preventDefault(); this.innerHTML='<p style=padding:14px;color:var(--sage-hover);font-weight:600;>You\'re subscribed. Welcome.</p>';"
      >
        <input type="email" placeholder="you@example.com" required />
        <button type="submit" class="btn btn-coral">Subscribe</button>
      </form>
      <p class="newsletter-tiny">We never share your email. Unsubscribe in one click.</p>
    </div>
  </section>

  <script is:inline>
    const fadeObs = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            fadeObs.unobserve(e.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -40px 0px' },
    );
    document.querySelectorAll('.fade-up').forEach((el) => fadeObs.observe(el));
  </script>
</BaseLayout>
