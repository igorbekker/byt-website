---
/**
 * Purpose: Blog category page — raw HTML injection from design-source/pages/Blog Category.html
 * Context: Route /blog/[category]/
 * Source: design-source/pages/Blog Category.html, apps/studio/schemas/documents/blogCategory.ts
 */

import { sanityClient } from 'sanity:client';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import {
  BLOG_CATEGORY_QUERY,
  BLOG_CATEGORY_POSTS_QUERY,
  BLOG_CATEGORY_PATHS_QUERY,
} from '../../../lib/queries';

interface BlogCategory {
  _id: string;
  title: string;
  slug: { current: string };
  description?: string;
  subtopics?: Array<{ title: string; slug: string; description?: string }>;
}

interface BlogPostCard {
  _id: string;
  title: string;
  slug: { current: string };
  publishedAt?: string;
  readingTimeMinutes?: number;
  excerpt?: string;
  subcategoryLabel?: string;
  category?: { title: string; slug: { current: string } };
}

export async function getStaticPaths() {
  const paths = await sanityClient.fetch<Array<{ slug: string }>>(BLOG_CATEGORY_PATHS_QUERY);
  return paths.map((p) => ({ params: { category: p.slug } }));
}

const { category: categorySlug } = Astro.params;

const [category, posts] = await Promise.all([
  sanityClient.fetch<BlogCategory>(BLOG_CATEGORY_QUERY, { categorySlug }),
  sanityClient.fetch<BlogPostCard[]>(BLOG_CATEGORY_POSTS_QUERY, { categorySlug }),
]);

function fmtDate(iso: string | undefined): string {
  if (!iso) return '';
  return new Date(iso).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}

// Posts not assigned to any subtopic appear in the category-level article list
const categoryLevelPosts = posts?.filter((p) => !p.subcategoryLabel) ?? [];
---

<style is:global>
  /* ════════════════════════════════════════════════
   BETTER YOU THERAPY — Shared base
   Nav + Footer + tokens + buttons (used by all blog pages)
════════════════════════════════════════════════ */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --navy: #104378;
    --navy-deep: #0a2d52;
    --navy-footer: #2d2d52;
    --white: #ffffff;
    --off-white: #f5f7fa;
    --cream: #fffcf0;
    --slate: #5a7194;
    --mist: #8fa3bf;
    --border: #e4eaf0;
    --coral: #e05555;
    --coral-hover: #c94444;
    --coral-light: #fce8e8;
    --sage: #9caf88;
    --sage-hover: #7a9468;
    --sage-light: #e8efe3;

    --r-btn: 6px;
    --r-card: 12px;
    --r-lg: 12px;
    --r-pill: 999px;

    --shadow-sm: 0 1px 2px rgba(16, 67, 120, 0.04);
    --shadow-md: 0 4px 12px rgba(16, 67, 120, 0.08);
    --shadow-lg: 0 8px 24px rgba(16, 67, 120, 0.1);

    --t-hover: 150ms ease;

    --max-w: 1200px;
    --pad-x: 64px;
    --pad-s: 80px;
  }

  html {
    scroll-behavior: smooth;
  }
  body {
    font-family:
      'Montserrat',
      system-ui,
      -apple-system,
      sans-serif;
    color: var(--slate);
    background: var(--white);
    line-height: 1.55;
    font-size: 15px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
  }
  img {
    display: block;
    max-width: 100%;
  }
  a {
    text-decoration: none;
    color: inherit;
  }
  h1,
  h2,
  h3,
  h4,
  h5 {
    font-family:
      'Manrope',
      system-ui,
      -apple-system,
      sans-serif;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--navy-deep);
    text-wrap: balance;
  }
  p {
    text-wrap: pretty;
  }

  .eyebrow {
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--coral);
  }
  .max-w {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .fade-up {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.6s ease,
      transform 0.6s ease;
  }
  .fade-up.visible {
    opacity: 1;
    transform: none;
  }

  /* BUTTONS */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 14px 24px;
    border-radius: var(--r-btn);
    font-family: 'Montserrat', sans-serif;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition:
      background-color var(--t-hover),
      border-color var(--t-hover),
      color var(--t-hover);
    border: 1.5px solid transparent;
    white-space: nowrap;
    line-height: 1;
  }
  .btn-coral {
    background: var(--coral);
    color: #fff;
    border-color: var(--coral);
  }
  .btn-coral:hover {
    background: var(--coral-hover);
    border-color: var(--coral-hover);
  }
  .btn-ink {
    background: var(--navy);
    color: #fff;
    border-color: var(--navy);
  }
  .btn-ink:hover {
    background: var(--navy-deep);
    border-color: var(--navy-deep);
  }
  .btn-outline-white {
    background: transparent;
    color: #fff;
    border-color: rgba(255, 255, 255, 0.5);
  }
  .btn-outline-white:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: #fff;
  }
  .btn-outline-ink {
    background: transparent;
    color: var(--navy);
    border-color: var(--navy);
  }
  .btn-outline-ink:hover {
    background: var(--navy);
    color: #fff;
  }
  .btn-outline-navy {
    background: transparent;
    color: var(--navy-deep);
    border-color: var(--navy-deep);
  }
  .btn-outline-navy:hover {
    background: var(--navy-deep);
    color: #fff;
  }
  .btn-outline-coral {
    background: transparent;
    color: var(--coral);
    border-color: var(--coral);
  }
  .btn-outline-coral:hover {
    background: var(--coral);
    color: #fff;
  }

  /* NAV */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--white);
    height: 84px;
    display: flex;
    align-items: center;
    padding: 0 var(--pad-x);
    border-bottom: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
  }
  .nav-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    height: 68px;
  }
  .nav-logo img {
    height: 64px;
    width: auto;
    display: block;
  }
  .nav-links {
    display: flex;
    gap: 2rem;
  }
  .nav-links a {
    color: var(--navy-deep);
    font-size: 15px;
    font-weight: 500;
    transition: color var(--t-hover);
    letter-spacing: 0.01em;
  }
  .nav-links a:hover {
    color: var(--coral);
  }
  .nav-actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }
  .nav-cta {
    background: var(--coral);
    color: #fff;
    padding: 12px 20px;
    border-radius: var(--r-btn);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.01em;
    transition: background-color var(--t-hover);
  }
  .nav-cta:hover {
    background: var(--coral-hover);
  }
  .nav-cta-secondary {
    color: var(--navy-deep);
    font-size: 14px;
    font-weight: 500;
    padding: 12px 20px;
    border-radius: var(--r-btn);
    transition: color var(--t-hover);
  }
  .nav-cta-secondary:hover {
    color: var(--coral);
  }
  .nav-hamburger {
    display: none;
    background: transparent;
    border: none;
    cursor: pointer;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    padding: 0;
    margin-right: -8px;
    color: var(--navy-deep);
  }
  .nav-hamburger svg {
    width: 26px;
    height: 26px;
  }

  /* Mobile menu */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: none;
    background: rgba(10, 45, 82, 0.5);
    backdrop-filter: blur(4px);
  }
  .mobile-menu.open {
    display: block;
  }
  .mobile-menu-panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(86vw, 360px);
    background: #fff;
    padding: 20px 24px 32px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    box-shadow: -8px 0 32px rgba(10, 45, 82, 0.15);
    animation: mmSlide 0.25s ease-out;
  }
  @keyframes mmSlide {
    from {
      transform: translateX(100%);
    }
    to {
      transform: none;
    }
  }
  .mobile-menu-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 16px;
    margin-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }
  .mobile-menu-close {
    background: transparent;
    border: none;
    cursor: pointer;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--navy-deep);
    margin-right: -8px;
  }
  .mobile-menu-close svg {
    width: 22px;
    height: 22px;
  }
  .mobile-menu a.mm-link {
    display: block;
    padding: 14px 4px;
    font-family: 'Manrope', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: var(--navy-deep);
    border-bottom: 1px solid var(--border);
    transition: color var(--t-hover);
  }
  .mobile-menu a.mm-link:hover {
    color: var(--coral);
  }
  .mobile-menu-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 20px;
  }
  .mobile-menu-actions .btn {
    width: 100%;
    justify-content: center;
  }

  /* FOOTER */
  .footer {
    background: var(--navy-deep);
    color: rgba(255, 255, 255, 0.68);
    padding: 4rem var(--pad-x) 2rem;
  }
  .footer-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.2fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }
  .footer-logo {
    margin-bottom: 1rem;
    display: block;
  }
  .footer-logo img {
    height: 100px;
    width: auto;
    display: block;
  }
  .footer-tagline {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.65;
    margin-bottom: 1.5rem;
    max-width: 360px;
  }
  .footer-contact {
    font-size: 14px;
    line-height: 1.85;
    color: rgba(255, 255, 255, 0.6);
  }
  .footer-contact a {
    color: rgba(255, 255, 255, 0.6);
    transition: color var(--t-hover);
  }
  .footer-contact a:hover {
    color: #fff;
  }
  .footer-grid h4 {
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }
  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .footer-links a {
    color: rgba(255, 255, 255, 0.6);
    font-size: 14px;
    transition: color var(--t-hover);
  }
  .footer-links a:hover {
    color: #fff;
  }

  /* ── Footer Newsletter (column variant) ───────── */
  .footer-newsletter-pitch {
    font-size: 14px;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.62);
    margin: -0.25rem 0 1rem;
  }
  .footer-newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .footer-newsletter-form input {
    width: 100%;
    min-width: 0;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.16);
    color: #fff;
    font-size: 14px;
    font-family: inherit;
    padding: 11px 14px;
    border-radius: var(--r-btn);
    transition:
      border-color var(--t-hover),
      background-color var(--t-hover);
  }
  .footer-newsletter-form input::placeholder {
    color: rgba(255, 255, 255, 0.42);
  }
  .footer-newsletter-form input:focus {
    outline: none;
    border-color: var(--coral);
    background: rgba(255, 255, 255, 0.1);
  }
  .footer-newsletter-form button {
    width: 100%;
    padding: 11px 16px;
    font-size: 14px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
  }
  .footer-newsletter-form button:disabled {
    opacity: 0.85;
    cursor: default;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  /* ──────────────────────────────────────────────── */

  .footer-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
    margin-bottom: 1.5rem;
  }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.45);
  }
  .footer-legal {
    display: flex;
    gap: 1.5rem;
  }
  .footer-legal a {
    color: rgba(255, 255, 255, 0.45);
    transition: color var(--t-hover);
  }
  .footer-legal a:hover {
    color: #fff;
  }
  .social-links {
    display: flex;
    gap: 0.6rem;
    margin-top: 1.25rem;
  }
  .social-link {
    width: 36px;
    height: 36px;
    border-radius: var(--r-btn);
    border: 1px solid rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--t-hover);
    color: rgba(255, 255, 255, 0.55);
  }
  .social-link:hover {
    border-color: rgba(255, 255, 255, 0.4);
    color: #fff;
    background: rgba(255, 255, 255, 0.06);
  }

  /* Mobile sticky CTA */
  .mobile-cta-bar {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 99;
    background: #fff;
    border-top: 1px solid var(--border);
    box-shadow: 0 -4px 20px rgba(10, 45, 82, 0.08);
    padding: 10px 12px calc(10px + env(safe-area-inset-bottom, 0px));
    gap: 8px;
    align-items: stretch;
  }
  .mobile-cta-bar .btn {
    flex: 1;
    justify-content: center;
    padding: 14px 12px;
    font-size: 14px;
    margin: 0;
  }

  /* RESPONSIVE — nav/footer */
  @media (max-width: 1024px) {
    :root {
      --pad-x: 32px;
      --pad-s: 64px;
    }
    .nav {
      height: 72px !important;
    }
    .nav-logo {
      height: 52px !important;
    }
    .nav-logo img {
      height: 48px !important;
      width: auto !important;
      max-width: none !important;
    }
    .nav-links {
      display: none !important;
    }
    .nav-actions {
      display: none !important;
    }
    .nav-hamburger {
      display: flex !important;
      margin-left: auto !important;
      margin-right: -8px !important;
    }
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }
  }
  @media (max-width: 768px) {
    :root {
      --pad-x: 20px;
      --pad-s: 56px;
    }
    body {
      padding-bottom: 78px;
    }
    .nav {
      height: 64px !important;
    }
    .nav-logo {
      height: 48px !important;
    }
    .nav-logo img {
      height: 44px !important;
      width: auto !important;
      max-width: none !important;
    }
    .mobile-cta-bar {
      display: flex !important;
    }
    .footer-grid {
      grid-template-columns: 1fr;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 1rem;
    }
  }

  /* ════════════════════════════════════════════════
   BLOG SYSTEM — shared across all blog pages
════════════════════════════════════════════════ */

  /* Image placeholder system — striped SVG with a label */
  .img-ph {
    background-color: var(--off-white);
    background-image: repeating-linear-gradient(
      135deg,
      rgba(16, 67, 120, 0.06) 0,
      rgba(16, 67, 120, 0.06) 1px,
      transparent 1px,
      transparent 12px
    );
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--mist);
    font-family: 'JetBrains Mono', 'Menlo', monospace;
    font-size: 11px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    overflow: hidden;
  }
  .img-ph::before {
    content: attr(data-label);
    background: rgba(255, 255, 255, 0.85);
    padding: 4px 10px;
    border-radius: 4px;
    border: 1px solid var(--border);
    white-space: nowrap;
  }
  .img-ph-coral {
    background-color: #fcecec;
    background-image: repeating-linear-gradient(
      135deg,
      rgba(224, 85, 85, 0.08) 0,
      rgba(224, 85, 85, 0.08) 1px,
      transparent 1px,
      transparent 12px
    );
  }
  .img-ph-sage {
    background-color: #eef2e8;
    background-image: repeating-linear-gradient(
      135deg,
      rgba(122, 148, 104, 0.1) 0,
      rgba(122, 148, 104, 0.1) 1px,
      transparent 1px,
      transparent 12px
    );
  }
  .img-ph-navy {
    background-color: #e7edf5;
    background-image: repeating-linear-gradient(
      135deg,
      rgba(16, 67, 120, 0.1) 0,
      rgba(16, 67, 120, 0.1) 1px,
      transparent 1px,
      transparent 12px
    );
  }

  /* ── BREADCRUMB ── */
  .crumb {
    background: var(--off-white);
    border-bottom: 1px solid var(--border);
    padding: 28px var(--pad-x);
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    letter-spacing: 0.02em;
  }
  .crumb-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--slate);
    flex-wrap: wrap;
  }
  .crumb a {
    color: var(--slate);
    transition: color var(--t-hover);
  }
  .crumb a:hover {
    color: var(--coral);
  }
  .crumb .sep {
    color: var(--mist);
  }
  .crumb .here {
    color: var(--navy-deep);
    font-weight: 600;
  }

  /* ── BLOG HERO (smaller than page heroes) ── */
  .blog-hero {
    background: var(--navy-deep);
    padding: clamp(3.5rem, 6vh, 5rem) var(--pad-x) clamp(3rem, 5vh, 4.5rem);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .blog-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(60% 80% at 50% 0%, rgba(224, 85, 85, 0.1) 0%, transparent 60%),
      radial-gradient(40% 60% at 80% 100%, rgba(255, 255, 255, 0.04) 0%, transparent 70%);
    pointer-events: none;
  }
  .blog-hero::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 1.25rem;
    width: 1px;
    height: 36px;
    background: var(--coral);
    opacity: 0.8;
  }
  .blog-hero-inner {
    max-width: 880px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .blog-hero .eyebrow {
    color: var(--coral);
    margin-bottom: 1.5rem;
  }
  .blog-hero h1 {
    color: #fff;
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin-bottom: 1.25rem;
    text-wrap: balance;
  }
  .blog-hero h1 em {
    color: var(--coral);
    font-style: normal;
  }
  .blog-hero p {
    color: rgba(255, 255, 255, 0.72);
    font-size: 17px;
    line-height: 1.6;
    max-width: 620px;
    margin: 0 auto;
    text-wrap: balance;
  }

  /* ── ARTICLE CARDS ── */
  .article-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--r-card);
    overflow: hidden;
    text-decoration: none;
    transition:
      border-color var(--t-hover),
      box-shadow var(--t-hover),
      transform var(--t-hover);
    height: 100%;
  }
  .article-card:hover {
    border-color: var(--coral);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .article-card-img {
    aspect-ratio: 16/10;
    background: var(--off-white);
  }
  .article-card-body {
    padding: 1.5rem 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.75rem;
  }
  .article-card-meta {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-family: 'Montserrat', sans-serif;
