---
/**
 * Purpose: Contact page — hero split layout + contact info + Formspree form
 * Context: Route /contact/
 * Source: design-source/pages/Contact.html
 * Schema: apps/studio/schemas/singletons/contactPage.ts
 */

import { sanityClient } from 'sanity:client';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_SETTINGS_QUERY, CONTACT_PAGE_QUERY } from '../lib/queries';

interface ImageWithAlt {
  asset?: { url: string };
  alt?: string;
}

interface SeoFields {
  metaTitle?: string;
  metaDescription?: string;
}

interface Address {
  street?: string;
  city?: string;
  state?: string;
  zip?: string;
}

interface SiteSettings {
  phone?: string;
  email?: string;
  fax?: string;
  address?: Address;
}

interface ContactPage {
  heroHeading?: string;
  heroSubhead?: string;
  heroImage?: ImageWithAlt;
  hoursDescription?: string;
  disclaimerCopy?: string;
  responseCopy?: string;
  seo?: SeoFields;
}

const [page, siteSettings] = await Promise.all([
  sanityClient.fetch<ContactPage>(CONTACT_PAGE_QUERY),
  sanityClient.fetch<SiteSettings>(SITE_SETTINGS_QUERY),
]);

const phoneDigits = siteSettings?.phone?.replace(/\D/g, '') ?? '';
const faxDigits = siteSettings?.fax?.replace(/\D/g, '') ?? '';
const emailDigits = siteSettings?.email ?? '';
const address = siteSettings?.address;
const cityStateZip = [address?.city, address?.state, address?.zip].filter(Boolean).join(', ');

const formspreeId = import.meta.env.PUBLIC_FORMSPREE_CONTACT_ID;
---

<BaseLayout seo={page?.seo ?? null} title={page?.seo?.metaTitle ?? 'Contact Us'}>
  <!-- ── HERO ── -->
  <section class="contact-hero">
    <div class="contact-hero-content">
      <p class="eyebrow">Contact Us</p>
      <h1>{page?.heroHeading ?? 'We’d love to hear from you.'}</h1>
      {page?.heroSubhead && <p>{page.heroSubhead}</p>}
    </div>
    <div class="contact-hero-image">
      {
        page?.heroImage?.asset?.url ? (
          <img src={page.heroImage.asset.url} alt={page.heroImage.alt ?? ''} />
        ) : null
      }
    </div>
  </section>

  <!-- ── CONTACT FORM SECTION ── -->
  <section class="contact-form-section">
    <div class="contact-form-wrap fade-up">
      <!-- Left: contact info -->
      <div class="contact-info">
        <p class="eyebrow">Get in touch</p>
        <h2>Reach our team directly.</h2>
        {page?.hoursDescription ? <p>{page.hoursDescription}</p> : null}

        <ul class="contact-info-list">
          {
            siteSettings?.phone && (
              <li class="contact-info-item">
                <div class="contact-info-icon">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z" />
                  </svg>
                </div>
                <div>
                  <div class="contact-info-label">Phone</div>
                  <div class="contact-info-value">
                    <a href={`tel:${phoneDigits}`}>{siteSettings.phone}</a>
                  </div>
                </div>
              </li>
            )
          }

          {
            siteSettings?.email && (
              <li class="contact-info-item">
                <div class="contact-info-icon">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                    <polyline points="22,6 12,13 2,6" />
                  </svg>
                </div>
                <div>
                  <div class="contact-info-label">Email</div>
                  <div class="contact-info-value">
                    <a href={`mailto:${emailDigits}`}>{siteSettings.email}</a>
                  </div>
                </div>
              </li>
            )
          }

          {
            siteSettings?.fax && (
              <li class="contact-info-item">
                <div class="contact-info-icon">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <polyline points="6 9 6 2 18 2 18 9" />
                    <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
                    <rect x="6" y="14" width="12" height="8" />
                  </svg>
                </div>
                <div>
                  <div class="contact-info-label">Fax</div>
                  <div class="contact-info-value">
                    <a href={`tel:${faxDigits}`}>{siteSettings.fax}</a>
                  </div>
                </div>
              </li>
            )
          }

          {
            address?.street && (
              <li class="contact-info-item">
                <div class="contact-info-icon">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z" />
                    <circle cx="12" cy="10" r="3" />
                  </svg>
                </div>
                <div>
                  <div class="contact-info-label">Address</div>
                  <div class="contact-info-value">
                    {address.street}
                    <br />
                    {cityStateZip}
                  </div>
                </div>
              </li>
            )
          }
        </ul>
      </div>

      <!-- Right: Formspree form -->
      <form class="contact-form" action={`https://formspree.io/f/${formspreeId}`} method="POST">
        <h2>Send us a message</h2>
        <p class="form-sub">
          Required fields are marked with <span class="req">*</span>
        </p>

        <div class="form-grid">
          <div class="form-field">
            <label for="firstName">First name <span class="req">*</span></label>
            <input id="firstName" name="firstName" type="text" required placeholder="Jane" />
          </div>
          <div class="form-field">
            <label for="lastName">Last name <span class="req">*</span></label>
            <input id="lastName" name="lastName" type="text" required placeholder="Doe" />
          </div>

          <div class="form-field">
            <label for="email">Email <span class="req">*</span></label>
            <input id="email" name="email" type="email" required placeholder="jane@email.com" />
          </div>
          <div class="form-field">
            <label for="phone">Phone</label>
            <input id="phone" name="phone" type="tel" placeholder="(555) 555-5555" />
          </div>

          <div class="form-field form-field-full">
            <label for="reason">I'm reaching out as <span class="req">*</span></label>
            <select id="reason" name="reason" required>
              <option value="" disabled selected>Select an option</option>
              <option>An adult or family seeking therapy</option>
              <option>A facility / wellness director</option>
              <option>A licensed therapist interested in joining</option>
              <option>A referring provider</option>
              <option>Press, partnership, or other</option>
            </select>
          </div>

          <div class="form-field form-field-full">
            <label for="message">How can we help? <span class="req">*</span></label>
            <textarea
              id="message"
              name="message"
              required
              placeholder="Tell us a little about what you're looking for. The more context you share, the faster we can route you to the right person."
            ></textarea>
          </div>
        </div>

        <label class="form-consent">
          <input type="checkbox" required />
          <span>
            I understand this form is not for emergencies. If you or someone you love is in crisis,
            please call <strong>988</strong> or <strong>911</strong>. By submitting, I agree to be
            contacted by {siteSettings?.businessName ?? 'Better You Therapy'}.
          </span>
        </label>

        <div class="form-actions">
          <button type="submit" class="btn btn-coral">Send Message &rarr;</button>
          <span class="form-fineprint">
            {page?.responseCopy ?? 'We respond within one business day.'}
          </span>
        </div>

        {page?.disclaimerCopy && <p class="form-disclaimer">{page.disclaimerCopy}</p>}
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── CONTACT HERO ── */
  .contact-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 56vh;
    max-height: 520px;
    background: var(--cream);
  }

  .contact-hero-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4rem 3.5rem;
    order: 1;
  }

  .contact-hero-content .eyebrow {
    margin-bottom: 1.25rem;
  }

  .contact-hero-content h1 {
    font-family: var(--font-heading);
    font-size: clamp(2.2rem, 3.4vw, 2.8rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 800;
    color: var(--navy-deep);
    margin-bottom: 1.25rem;
  }

  .contact-hero-content p {
    color: var(--slate);
    font-size: 17px;
    line-height: 1.6;
    max-width: 480px;
  }

  .contact-hero-image {
    position: relative;
    overflow: hidden;
    background: var(--navy);
    order: 2;
  }

  .contact-hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* ── CONTACT FORM SECTION ── */
  .contact-form-section {
    background: var(--white);
    padding: var(--pad-s) var(--pad-x);
  }

  .contact-form-wrap {
    max-width: 980px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: 4rem;
    align-items: start;
  }

  /* ── CONTACT INFO (left column) ── */
  .contact-info .eyebrow {
    margin-bottom: 1rem;
  }

  .contact-info h2 {
    font-size: clamp(1.6rem, 2.4vw, 2rem);
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .contact-info > p {
    color: var(--slate);
    font-size: 15px;
    line-height: 1.65;
    margin-bottom: 2rem;
  }

  .contact-info-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-info-item {
    display: flex;
    gap: 0.9rem;
    align-items: flex-start;
  }

  .contact-info-icon {
    width: 38px;
    height: 38px;
    border-radius: var(--r-btn);
    background: var(--coral-light);
    color: var(--coral);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contact-info-icon svg {
    width: 18px;
    height: 18px;
  }

  .contact-info-label {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--navy-deep);
    margin-bottom: 0.25rem;
  }

  .contact-info-value {
    font-size: 15px;
    color: var(--slate);
    line-height: 1.5;
  }

  .contact-info-value a {
    color: var(--slate);
    transition: color var(--t-hover);
  }

  .contact-info-value a:hover {
    color: var(--coral);
  }

  /* ── CONTACT FORM (right column) ── */
  .contact-form {
    background: var(--off-white);
    border: 1px solid var(--border);
    border-radius: var(--r-card);
    padding: 2.5rem;
  }

  .contact-form h2 {
    font-size: 1.4rem;
    margin-bottom: 0.4rem;
    letter-spacing: -0.01em;
  }

  .contact-form .form-sub {
    color: var(--slate);
    font-size: 14px;
    margin-bottom: 1.75rem;
  }

  .req {
    color: var(--coral);
    margin-left: 2px;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.1rem 1rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
  }

  .form-field-full {
    grid-column: 1 / -1;
  }

  .form-field label {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--navy-deep);
    margin-bottom: 0.5rem;
  }

  .form-field input,
  .form-field select,
  .form-field textarea {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--navy-deep);
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--r-btn);
    padding: 12px 14px;
    width: 100%;
    transition:
      border-color var(--t-hover),
      box-shadow var(--t-hover);
    -webkit-appearance: none;
    appearance: none;
  }

  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: var(--mist);
  }

  .form-field input:focus,
  .form-field select:focus,
  .form-field textarea:focus {
    outline: none;
    border-color: var(--coral);
    box-shadow: 0 0 0 3px rgba(224, 85, 85, 0.12);
  }

  .form-field select {
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8' fill='none' stroke='%235A7194' stroke-width='2' stroke-linecap='round'><path d='M1 1l5 5 5-5'/></svg>");
    background-repeat: no-repeat;
    background-position: right 14px center;
    padding-right: 36px;
  }

  .form-field textarea {
    resize: vertical;
    min-height: 130px;
    line-height: 1.5;
  }

  .form-consent {
    display: flex;
    gap: 0.65rem;
    align-items: flex-start;
    font-size: 13px;
    color: var(--slate);
    line-height: 1.55;
    margin-top: 1.25rem;
  }

  .form-consent input[type='checkbox'] {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    margin-top: 2px;
    accent-color: var(--coral);
  }

  .form-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }

  .form-fineprint {
    font-size: 13px;
    color: var(--mist);
  }

  .form-disclaimer {
    font-size: 13px;
    color: var(--mist);
    line-height: 1.55;
    margin-top: 1rem;
    border-top: 1px solid var(--border);
    padding-top: 1rem;
  }

  /* ── SCROLL FADE ── */
  .fade-up {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.6s ease,
      transform 0.6s ease;
  }

  .fade-up.visible {
    opacity: 1;
    transform: none;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 1024px) {
    .contact-hero {
      grid-template-columns: 1fr;
      max-height: none;
      min-height: 0;
    }

    .contact-hero-image {
      height: 340px;
      order: 1;
    }

    .contact-hero-content {
      order: 2;
      padding: 3rem 2.5rem;
    }

    .contact-form-wrap {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  @media (max-width: 768px) {
    .contact-hero-image {
      height: 240px;
    }

    .contact-hero-content {
      padding: 2.5rem 1.75rem;
    }

    .contact-form {
      padding: 1.75rem;
    }

    .form-grid {
      grid-template-columns: 1fr;
    }

    .form-field-full {
      grid-column: 1;
    }
  }
</style>

<script>
  // Scroll fade-in observer
  const fadeEls = document.querySelectorAll<HTMLElement>('.fade-up');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 },
  );
  fadeEls.forEach((el) => observer.observe(el));
</script>
