      activeJobId = id;
      document.getElementById('modalTitle').textContent = job.title;
      document.getElementById('modalMeta').innerHTML = `
    <span>${ICON_PIN}${job.location}</span>
    <span>${ICON_CLOCK}${job.type}</span>
