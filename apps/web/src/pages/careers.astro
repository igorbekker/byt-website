    function updateFileLabel(input) {
      const label = document.getElementById(input.id + '-label');
      if (!label) return;
      if (input.files && input.files[0]) {
        label.innerHTML = `<strong>${input.files[0].name}</strong> · ready to submit`;
      } else {
        label.innerHTML = '<strong>Choose a file</strong> or drag &amp; drop · PDF, DOC, DOCX';
      }
    }

