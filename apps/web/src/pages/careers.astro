---
/**
 * Purpose: Careers page — hero, open positions list, general application CTA
 * Context: Route /careers/
 * Source: design-source/pages/Careers.html
 * Schema: apps/studio/schemas/singletons/careersPage.ts + documents/jobPosting.ts
 */

import { sanityClient } from 'sanity:client';
import BaseLayout from '../layouts/BaseLayout.astro';
import { CAREERS_PAGE_QUERY, JOB_POSTINGS_QUERY } from '../lib/queries';

interface SeoFields {
  metaTitle?: string;
  metaDescription?: string;
}

interface CareersPage {
  heroHeading?: string;
  heroSubhead?: string;
  openPositionsIntro?: string;
  noFitHeading?: string;
  noFitBody?: string;
  seo?: SeoFields;
}

interface JobPosting {
  _id: string;
  title: string;
  track?: 'facility' | 'teletherapy';
  status?: 'open' | 'filled' | 'paused';
  location?: string;
  slug?: { current: string };
}

const TRACK_LABELS: Record<string, string> = {
  facility: 'Facility-Based',
  teletherapy: 'Teletherapy',
};

const page = await sanityClient.fetch<CareersPage>(CAREERS_PAGE_QUERY);
const allPostings = await sanityClient.fetch<JobPosting[]>(JOB_POSTINGS_QUERY);
const jobs = allPostings.filter((j) => j.status === 'open');
---

<BaseLayout seo={page?.seo ?? null}>
  <!-- ── HERO ── -->
  <section class="about-hero careers-hero">
    <div class="about-hero-content">
      <p class="eyebrow">Careers at Better You Therapy</p>
      {page?.heroHeading && <h1 set:html={page.heroHeading} />}
      {page?.heroSubhead && <p>{page.heroSubhead}</p>}
    </div>
  </section>

  <!-- ── OPEN POSITIONS ── -->
  <section class="jobs">
    <div class="jobs-inner">
      <div class="jobs-header">
        <p class="eyebrow">Open Positions</p>
        <h2>Roles we&rsquo;re hiring for right now.</h2>
        {page?.openPositionsIntro && <p>{page.openPositionsIntro}</p>}
      </div>

      {
        jobs.length > 0 ? (
          <div class="jobs-list">
            {jobs.map((job) => (
              <div class="job-row">
                <span class="job-title">{job.title}</span>
                {job.track && (
                  <span class="job-meta">
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M20 7H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2Z" />
                      <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" />
                    </svg>
                    {TRACK_LABELS[job.track] ?? job.track}
                  </span>
                )}
                {job.location && (
                  <span class="job-meta">
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 1 1 16 0Z" />
                      <circle cx="12" cy="10" r="3" />
                    </svg>
                    {job.location}
                  </span>
                )}
                <div class="job-actions">
                  {job.slug?.current && (
                    <a href={`/careers/${job.slug.current}/`} class="job-link primary">
                      Apply Now
                      <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                        style="width:14px;height:14px;"
                      >
                        <path d="M5 12h14M13 6l6 6-6 6" />
                      </svg>
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        ) : (
          <p class="jobs-empty">No open positions at this time — check back soon.</p>
        )
      }
    </div>
  </section>

  <!-- ── GENERAL APPLICATION ── -->
  <section class="general-app">
    <div class="general-app-inner">
      <p class="eyebrow">Don&rsquo;t See a Fit?</p>
      {page?.noFitHeading && <h2>{page.noFitHeading}</h2>}
      {page?.noFitBody && <p>{page.noFitBody}</p>}
      <a href="/contact/" class="btn btn-coral">Send Us Your Resume &rarr;</a>
    </div>
  </section>
</BaseLayout>

<style>
  .jobs-empty {
    padding: 2.5rem 0;
    color: var(--slate);
    font-size: 17px;
    text-align: center;
    border-top: 1px solid var(--border);
  }
</style>
