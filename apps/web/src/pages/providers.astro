  <script is:inline>
    /* Layout506 — vertical Tabs */
    const l506 = document.getElementById('l506');
    l506.querySelectorAll('.l506-trigger').forEach((btn) => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.tab;
        l506
          .querySelectorAll('.l506-trigger')
          .forEach((b) => b.classList.toggle('active', b === btn));
        l506
          .querySelectorAll('.l506-panel')
          .forEach((p) => p.classList.toggle('active', p.dataset.panel === target));
      });
    });
  </script>
