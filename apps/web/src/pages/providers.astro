---
import { sanityClient } from 'sanity:client';
import BaseLayout from '../layouts/BaseLayout.astro';
import { PROVIDERS_PAGE_QUERY, TESTIMONIALS_THERAPIST_QUERY } from '../lib/queries';

interface ProvidersPage {
  heroHeading?: string;
  heroSubhead?: string;
  heroPrimaryCta?: { label: string; href?: string; variant?: string };
  heroImage?: { asset?: { url: string }; alt?: string };
  tracksEyebrow?: string;
  tracksHeading?: string;
  tracksSubhead?: string;
  tracks?: Array<{
    label?: string;
    heading?: string;
    body?: string;
    statusNote?: string;
    cta?: { label: string; href?: string };
  }>;
  handlesEyebrow?: string;
  handlesHeading?: string;
  handlesItems?: Array<{ heading?: string; body?: string }>;
  qualsEyebrow?: string;
  qualsHeading?: string;
  quals?: Array<{ scope?: string; body?: string }>;
  ctaHeading?: string;
  ctaSubhead?: string;
  ctaCta?: { label: string; href?: string };
  seo?: { metaTitle?: string; metaDescription?: string };
}

interface Testimonial {
  _id: string;
  quote?: string;
  authorName?: string;
  authorRole?: string;
  authorOrg?: string;
  authorInitials?: string;
}

const [page, testimonials] = await Promise.all([
  sanityClient.fetch<ProvidersPage>(PROVIDERS_PAGE_QUERY),
  sanityClient.fetch<Testimonial[]>(TESTIMONIALS_THERAPIST_QUERY),
]);
---

<BaseLayout
  title={page?.seo?.metaTitle ?? 'For Therapists | Better You Therapy'}
  description={page?.seo?.metaDescription ??
    'Join Better You Therapy as a licensed therapist. Two role tracks — facility-based in Southeast Florida or statewide teletherapy. Billing, referrals, and EHR handled for you.'}
>
  <style is:global>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --byt-navy: #104378;
      --byt-navy-deep: #0a2d52;
      --byt-navy-footer: #2d2d52;
      --byt-coral: #e05555;
      --byt-coral-hover: #c94444;
      --byt-coral-light: #fce8e8;
      --byt-sage: #9caf88;
      --byt-sage-light: #e8efe3;
      --byt-slate: #5a7194;
      --byt-mist: #8fa3bf;
      --byt-border: #e4eaf0;
      --byt-off-white: #f5f7fa;
      --byt-cream: #fffcf0;

      --r-btn: 6px;
      --r-card: 12px;
      --r-pill: 999px;

      --shadow-sm: 0 1px 2px rgba(16, 67, 120, 0.04);
      --shadow-md: 0 4px 12px rgba(16, 67, 120, 0.08);
      --shadow-lg: 0 8px 24px rgba(16, 67, 120, 0.1);

      --bg-primary: #ffffff;
      --bg-alt: #f5f7fa;
      --text-primary: #0a2d52;
      --text-alt: #ffffff;
      --border-primary: #e4eaf0;
    }

    html {
      -webkit-text-size-adjust: 100%;
    }
    body {
      font-family:
        'Montserrat',
        system-ui,
        -apple-system,
        Segoe UI,
        Roboto,
        sans-serif;
      color: var(--byt-slate);
      background: var(--bg-primary);
      line-height: 1.5;
      font-size: 16px;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
      font-family:
        'Manrope',
        system-ui,
        -apple-system,
        sans-serif;
      font-weight: 800;
      letter-spacing: -0.01em;
      color: var(--byt-navy-deep);
    }
    img {
      display: block;
      max-width: 100%;
    }
    a {
      color: inherit;
      text-decoration: none;
    }
    button {
      font: inherit;
      cursor: pointer;
      border: 0;
      background: transparent;
      color: inherit;
    }
    ul {
      list-style: none;
    }

    .container {
      width: 100%;
      margin-inline: auto;
      max-width: 80rem;
    }
    .section {
      padding: 64px 5%;
    }
    @media (min-width: 768px) {
      .section {
        padding: 96px 5%;
      }
    }
    @media (min-width: 1024px) {
      .section {
        padding: 112px 5%;
      }
    }

    .text-md {
      font-size: 1.125rem;
      line-height: 1.5;
    }
    .text-sm {
      font-size: 0.875rem;
      line-height: 1.4;
    }
    .text-xl {
      font-size: 1.25rem;
      line-height: 1.4;
    }
    .text-2xl {
      font-size: 1.5rem;
      line-height: 1.3;
    }
    .text-4xl {
      font-size: 2.25rem;
      line-height: 1.2;
    }
    .text-5xl {
      font-size: 3rem;
      line-height: 1.1;
    }
    .text-6xl {
      font-size: 3.75rem;
      line-height: 1.1;
    }
    .text-7xl {
      font-size: 4.5rem;
      line-height: 1.05;
    }
    .text-8xl {
      font-size: 6rem;
      line-height: 1;
    }
    .text-9xl {
      font-size: 8rem;
      line-height: 1;
    }
    .text-10xl {
      font-size: 10rem;
      line-height: 1;
    }
    .font-bold {
      font-weight: 700;
    }
    .font-semibold {
      font-weight: 600;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.75rem 1.5rem;
      border: 1.5px solid var(--byt-navy);
      font-family: 'Montserrat', sans-serif;
      font-size: 0.9375rem;
      font-weight: 600;
      line-height: 1.2;
      letter-spacing: 0.01em;
      background: var(--bg-primary);
      color: var(--byt-navy-deep);
      border-radius: var(--r-btn);
      transition:
        background-color 0.15s,
        color 0.15s,
        border-color 0.15s,
        box-shadow 0.15s,
        transform 0.15s;
      white-space: nowrap;
    }
    .btn:hover {
      transform: translateY(-1px);
    }
    .btn-primary:hover {
      box-shadow: var(--shadow-md);
    }
    .btn-primary {
      background: var(--byt-coral);
      color: #fff;
      border-color: var(--byt-coral);
    }
    .btn-primary:hover {
      background: var(--byt-coral-hover);
      border-color: var(--byt-coral-hover);
    }
    .btn.btn-secondary {
      background: transparent;
      color: var(--byt-navy-deep);
      border-color: var(--byt-navy-deep);
    }
    .btn.btn-secondary:hover {
      background: var(--byt-navy-deep);
      color: #fff;
    }
    .btn-secondary-alt {
      background: transparent;
      color: #fff;
      border-color: #fff;
    }
    .btn-secondary-alt:hover {
      background: #fff;
      color: var(--byt-navy-deep);
    }
    .btn-sm {
      padding: 0.5rem 1.25rem;
      font-size: 0.875rem;
    }
    .btn-link {
      background: transparent;
      border: 0;
      padding: 0;
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      font-family: 'Montserrat', sans-serif;
      font-weight: 600;
      color: var(--byt-coral);
      text-decoration: underline;
      text-underline-offset: 3px;
      transition: color 0.2s;
    }
    .btn-link:hover {
      color: var(--byt-coral-hover);
    }
    .btn-link.alt {
      color: #fff;
    }
    .btn-link.alt:hover {
      color: rgba(255, 255, 255, 0.8);
    }
    .btn-link svg {
      width: 1em;
      height: 1em;
    }

    .nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: #fff;
      height: 84px;
      display: flex;
      align-items: center;
      padding: 0 5%;
      border-bottom: 1px solid var(--byt-border);
      box-shadow: var(--shadow-sm);
    }
    .nav-inner {
      max-width: 1400px;
      margin: 0 auto;
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-logo {
      display: flex;
      align-items: center;
      text-decoration: none;
      height: 68px;
    }
    .nav-logo img {
      height: 64px;
      width: auto;
      display: block;
    }
    .nav-links {
      display: flex;
      gap: 2rem;
    }
    .nav-links a {
      color: var(--byt-navy-deep);
      font-size: 15px;
      font-weight: 500;
      transition: color 0.2s;
      letter-spacing: 0.01em;
    }
    .nav-links a:hover {
      color: var(--byt-coral);
    }
    .nav-actions {
      display: flex;
      gap: 0.75rem;
      align-items: center;
    }
    .nav-cta {
      background: var(--byt-coral);
      color: #fff;
      padding: 12px 20px;
      border-radius: var(--r-btn);
      font-size: 14px;
      font-weight: 600;
      letter-spacing: 0.01em;
      transition: background-color 0.2s;
    }
    .nav-cta:hover {
      background: var(--byt-coral-hover);
    }
    .nav-cta-secondary {
      color: var(--byt-navy-deep);
      font-size: 14px;
      font-weight: 500;
      padding: 12px 20px;
      border-radius: var(--r-btn);
      transition: color 0.2s;
    }
    .nav-cta-secondary:hover {
      color: var(--byt-coral);
    }

    .nav-hamburger {
      display: none;
      background: transparent;
      border: none;
      cursor: pointer;
      width: 44px;
      height: 44px;
      align-items: center;
      justify-content: center;
      padding: 0;
      margin-right: -8px;
      color: var(--byt-navy-deep);
    }
    .nav-hamburger svg {
      width: 26px;
      height: 26px;
    }

    .mobile-menu {
      position: fixed;
      inset: 0;
      z-index: 200;
      display: none;
      background: rgba(10, 45, 82, 0.5);
      backdrop-filter: blur(4px);
    }
    .mobile-menu.open {
      display: block;
    }
    .mobile-menu-panel {
      position: absolute;
      top: 0;
      right: 0;
      bottom: 0;
      width: min(86vw, 360px);
      background: #fff;
      padding: 20px 24px 32px;
      display: flex;
      flex-direction: column;
      gap: 4px;
      box-shadow: -8px 0 32px rgba(10, 45, 82, 0.15);
      animation: mmSlide 0.25s ease-out;
    }
    @keyframes mmSlide {
      from {
        transform: translateX(100%);
      }
      to {
        transform: none;
      }
    }
    .mobile-menu-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-bottom: 16px;
      margin-bottom: 12px;
      border-bottom: 1px solid var(--byt-border);
    }
    .mobile-menu-close {
      background: transparent;
      border: none;
      cursor: pointer;
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--byt-navy-deep);
      margin-right: -8px;
    }
    .mobile-menu-close svg {
      width: 22px;
      height: 22px;
    }
    .mobile-menu a.mm-link {
      display: block;
      padding: 14px 4px;
      font-family: 'Manrope', sans-serif;
      font-size: 18px;
      font-weight: 700;
      color: var(--byt-navy-deep);
      border-bottom: 1px solid var(--byt-border);
      transition: color 0.2s;
    }
    .mobile-menu a.mm-link:hover {
      color: var(--byt-coral);
    }
    .mobile-menu-actions {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-top: 20px;
    }
    .mobile-menu-actions .btn {
      width: 100%;
      justify-content: center;
    }

    .mobile-cta-bar {
      display: none;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 99;
      background: #fff;
      border-top: 1px solid var(--byt-border);
      box-shadow: 0 -4px 20px rgba(10, 45, 82, 0.08);
      padding: 10px 12px calc(10px + env(safe-area-inset-bottom, 0px));
      gap: 8px;
      align-items: stretch;
    }
    .mobile-cta-bar .btn {
      flex: 1;
      justify-content: center;
      padding: 14px 12px;
      font-size: 14px;
      margin: 0;
    }

    @media (max-width: 1024px) {
      .nav {
        height: 72px !important;
        padding: 0 32px;
      }
      .nav-logo {
        height: 52px !important;
      }
      .nav-logo img {
        height: 48px !important;
        width: auto !important;
        max-width: none !important;
      }
      .nav-links {
        display: none !important;
      }
      .nav-actions {
        display: none !important;
      }
      .nav-hamburger {
        display: flex !important;
        margin-left: auto !important;
        margin-right: -8px !important;
      }
    }
    @media (max-width: 768px) {
      body {
        padding-bottom: 78px;
      }
      .nav {
        height: 64px !important;
        padding: 0 20px;
      }
      .nav-logo {
        height: 48px !important;
      }
      .nav-logo img {
        height: 44px !important;
        width: auto !important;
        max-width: none !important;
      }
      .nav-actions {
        display: none !important;
      }
      .nav-hamburger {
        display: flex !important;
      }
      .mobile-cta-bar {
        display: flex !important;
      }
    }

    .h98 {
      padding: 0;
    }
    .h98-card {
      position: relative;
      overflow: hidden;
      border-radius: 0;
      box-shadow: none;
      width: 100%;
      max-width: none;
      margin: 0;
      padding: 0;
    }
    .h98-content {
      position: relative;
      z-index: 10;
      display: flex;
      min-height: 32rem;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem;
      text-align: center;
      color: var(--text-alt);
    }
    @media (min-width: 768px) {
      .h98-content {
        min-height: 40rem;
        padding: 4rem;
      }
    }
    @media (min-width: 1024px) {
      .h98-content {
        min-height: 44rem;
      }
    }
    .h98-content .inner {
      width: 100%;
      max-width: 56rem;
    }
    .h98-eyebrow {
      display: inline-block;
      margin-bottom: 1.25rem;
      font-family: 'Montserrat', sans-serif;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: #fff;
      padding: 0.4rem 0.9rem;
      border: 1px solid rgba(255, 255, 255, 0.4);
      border-radius: var(--r-pill);
      backdrop-filter: blur(6px);
      background: rgba(255, 255, 255, 0.06);
    }
    .h98 h1 {
      margin-bottom: 1rem;
      font-size: 2.75rem;
      line-height: 1.05;
      font-weight: 800;
      color: #fff;
      letter-spacing: -0.02em;
    }
    .h98 .h98-subhead {
      margin-bottom: 1.5rem;
      color: rgba(255, 255, 255, 0.85);
      font-size: 1.25rem;
      line-height: 1.35;
      font-weight: 500;
      letter-spacing: -0.01em;
      max-width: 36rem;
      margin-inline: auto;
    }
    @media (min-width: 768px) {
      .h98 .h98-subhead {
        font-size: 1.5rem;
        margin-bottom: 2rem;
      }
    }
    @media (min-width: 1024px) {
      .h98 .h98-subhead {
        font-size: 1.75rem;
      }
    }
    @media (min-width: 768px) {
      .h98 h1 {
        margin-bottom: 1.5rem;
        font-size: 4rem;
      }
    }
    @media (min-width: 1024px) {
      .h98 h1 {
        font-size: 5rem;
      }
    }
    .h98 h1 em {
      font-style: normal;
      color: var(--byt-coral);
      font-family: 'Manrope', serif;
      font-weight: 800;
    }
    .h98 .lede {
      color: rgba(255, 255, 255, 0.92);
      font-size: 1.0625rem;
      line-height: 1.55;
      max-width: 34rem;
      margin-inline: auto;
    }
    @media (min-width: 768px) {
      .h98 .lede {
        font-size: 1.125rem;
      }
    }
    .h98-actions {
      margin-top: 1.75rem;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
      gap: 0.875rem;
    }
    @media (min-width: 768px) {
      .h98-actions {
        margin-top: 2.25rem;
      }
    }
    .h98-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
      background: linear-gradient(135deg, #0a2d52 0%, #104378 60%, #1a4d8c 100%);
    }
    .h98-bg img {
      height: 100%;
      width: 100%;
      object-fit: cover;
      opacity: 0.55;
      mix-blend-mode: luminosity;
    }
    .h98-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(
        180deg,
        rgba(10, 45, 82, 0.55) 0%,
        rgba(10, 45, 82, 0.35) 50%,
        rgba(10, 45, 82, 0.75) 100%
      );
    }
    .h98-bg::before {
      content: '';
      position: absolute;
      inset: 0;
      z-index: 1;
      background-image: radial-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px);
      background-size: 24px 24px;
      opacity: 0.6;
    }

    .l422-head {
      margin-inline: auto;
      margin-bottom: 48px;
      width: 100%;
      max-width: 48rem;
      text-align: center;
    }
    @media (min-width: 768px) {
      .l422-head {
        margin-bottom: 72px;
      }
    }
    @media (min-width: 1024px) {
      .l422-head {
        margin-bottom: 80px;
      }
    }
    .l422-eyebrow {
      display: inline-block;
      margin-bottom: 1rem;
      font-family: 'Montserrat', sans-serif;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--byt-coral);
    }
    .l422-head h2 {
      margin-bottom: 1.25rem;
      font-size: 2.25rem;
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -0.02em;
    }
    @media (min-width: 768px) {
      .l422-head h2 {
        margin-bottom: 1.5rem;
        font-size: 2.75rem;
      }
    }
    @media (min-width: 1024px) {
      .l422-head h2 {
        font-size: 3.25rem;
      }
    }
    .l422-head .text-md {
      color: var(--byt-slate);
    }

    .l422-cards {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 1.5rem;
    }
    @media (min-width: 768px) {
      .l422-cards {
        flex-direction: row;
        gap: 2rem;
      }
    }

    .l422-card {
      position: relative;
      display: flex;
      width: 100%;
      flex-direction: column;
      overflow: hidden;
      border-radius: var(--r-card);
      box-shadow: var(--shadow-md);
      transition:
        width 0.35s cubic-bezier(0.4, 0, 0.2, 1),
        box-shadow 0.25s;
    }
    .l422-card:hover {
      box-shadow: var(--shadow-lg);
    }
    @media (min-width: 768px) {
      .l422-card {
        width: 50%;
      }
    }
    @media (min-width: 1024px) {
      .l422-card {
        height: 100%;
      }
      .l422-cards:not(:hover) > .l422-card.is-default {
        width: 70%;
      }
      .l422-cards:not(:hover) > .l422-card.is-default .l422-card-content::before {
        background: rgba(0, 0, 0, 0.5);
      }
      .l422-cards:not(:hover) > .l422-card.is-default .l422-card-body.desktop-only {
        opacity: 1;
        height: auto;
        transform: translateY(0);
      }
      .l422-cards:hover > .l422-card:hover {
        width: 70%;
      }
    }
    .l422-card-img {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }
    .l422-card-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .l422-card-img::before {
      content: '';
      position: absolute;
      inset: 0;
      z-index: 1;
      background: linear-gradient(
        180deg,
        rgba(10, 45, 82, 0.25) 0%,
        rgba(10, 45, 82, 0.55) 60%,
        rgba(10, 45, 82, 0.85) 100%
      );
    }
    .l422-card-content {
      position: relative;
      display: flex;
      height: 100%;
      min-height: 70vh;
      flex-direction: column;
      justify-content: flex-end;
      padding: 1.5rem;
      color: var(--text-alt);
    }
    @media (min-width: 768px) {
      .l422-card-content {
        padding: 2rem;
      }
    }
    @media (min-width: 1024px) {
      .l422-card-content {
        padding: 3rem;
      }
    }
    .l422-card-content::before {
      content: '';
      position: absolute;
      inset: 0;
      z-index: 0;
      transition: background-color 0.3s;
    }
    @media (min-width: 1024px) {
      .l422-card:hover .l422-card-content::before {
        background: rgba(0, 0, 0, 0.5);
      }
    }
    .l422-card-text {
      position: relative;
      z-index: 10;
    }
    .l422-card-eyebrow {
      margin-bottom: 0.75rem;
      font-family: 'Montserrat', sans-serif;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: #fff;
    }
    .l422-card h3 {
      font-size: 2.25rem;
      font-weight: 700;
      line-height: 1.2;
      color: #fff;
    }
    @media (min-width: 768px) {
      .l422-card h3 {
        font-size: 3rem;
      }
    }
