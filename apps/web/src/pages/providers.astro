---
/**
 * Purpose: Providers hub page — hero, role tracks, handles grid, qualifications, testimonials, CTA
 * Context: Route /providers/
 * Source: design-source/pages/Providers.html
 * Schema: apps/studio/schemas/singletons/providersPage.ts
 */

import { sanityClient } from 'sanity:client';
import BaseLayout from '../layouts/BaseLayout.astro';
import { PROVIDERS_PAGE_QUERY, TESTIMONIALS_THERAPIST_QUERY } from '../lib/queries';

interface CtaLink {
  label: string;
  href: string;
  variant?: string;
}

interface ImageWithAlt {
  asset?: { url: string };
  alt?: string;
}

interface SeoFields {
  metaTitle?: string;
  metaDescription?: string;
}

interface Track {
  label?: string;
  heading?: string;
  body?: string;
  statusNote?: string;
  cta?: CtaLink;
}

interface HandlesItem {
  heading?: string;
  body?: string;
}

interface Qual {
  scope?: string;
  body?: string;
}

interface ProvidersPage {
  heroHeading?: string;
  heroSubhead?: string;
  heroPrimaryCta?: CtaLink;
  heroImage?: ImageWithAlt;
  tracksEyebrow?: string;
  tracksHeading?: string;
  tracksSubhead?: string;
  tracks?: Track[];
  handlesEyebrow?: string;
  handlesHeading?: string;
  handlesItems?: HandlesItem[];
  qualsEyebrow?: string;
  qualsHeading?: string;
  quals?: Qual[];
  ctaHeading?: string;
  ctaSubhead?: string;
  ctaCta?: CtaLink;
  seo?: SeoFields;
}

interface Testimonial {
  _id: string;
  quote?: string;
  authorName?: string;
  authorRole?: string;
  authorOrg?: string;
  authorInitials?: string;
}

const SCOPE_LABELS: Record<string, string> = {
  all: 'All Tracks',
  facility: 'Facility-Based Only',
  teletherapy: 'Teletherapy Only',
};

const [page, testimonials] = await Promise.all([
  sanityClient.fetch<ProvidersPage>(PROVIDERS_PAGE_QUERY),
  sanityClient.fetch<Testimonial[]>(TESTIMONIALS_THERAPIST_QUERY),
]);
---

<BaseLayout seo={page?.seo ?? null}>
  <!-- ══════════════════════ Hero (.h98) ══════════════════════ -->
  <section class="h98">
    <div class="h98-card">
      <div class="h98-content">
        <div class="h98-inner">
          {page?.heroHeading && <h1>{page.heroHeading}</h1>}
          {page?.heroSubhead && <p class="h98-subhead">{page.heroSubhead}</p>}
          {
            page?.heroPrimaryCta && (
              <div class="h98-actions">
                <a
                  href={page.heroPrimaryCta.href}
                  class={`btn btn-${page.heroPrimaryCta.variant ?? 'primary'}`}
                >
                  {page.heroPrimaryCta.label}
                </a>
              </div>
            )
          }
        </div>
      </div>
      <div class="h98-bg" aria-hidden="true">
        {
          page?.heroImage?.asset?.url ? (
            <img src={page.heroImage.asset.url} alt={page.heroImage.alt ?? ''} loading="eager" />
          ) : null
        }
      </div>
    </div>
  </section>

  <!-- ══════════════════════ Role Tracks (.l422) ══════════════════════ -->
  {
    page?.tracks && page.tracks.length > 0 && (
      <section class="prov-tracks">
        <div class="prov-max">
          <div class="l422-head">
            {page?.tracksEyebrow && <p class="l422-eyebrow">{page.tracksEyebrow}</p>}
            {page?.tracksHeading && <h2>{page.tracksHeading}</h2>}
            {page?.tracksSubhead && <p class="l422-subhead">{page.tracksSubhead}</p>}
          </div>

          <div class="l422-cards">
            {page.tracks.map((track, idx) => (
              <div class={`l422-card${idx === 0 ? ' is-default' : ''}`}>
                <div class="l422-card-content">
                  <div class="l422-card-text">
                    {track.label && <p class="l422-card-eyebrow">{track.label}</p>}
                    {track.heading && <h3>{track.heading}</h3>}
                  </div>
                  {(track.body || track.statusNote || track.cta) && (
                    <div class="l422-card-body">
                      {track.body && <p>{track.body}</p>}
                      {track.statusNote && <p class="l422-status-note">{track.statusNote}</p>}
                      {track.cta && (
                        <div class="l422-card-cta">
                          <a href={track.cta.href} class="btn-link-alt">
                            {track.cta.label}
                            <svg
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2"
                              aria-hidden="true"
                            >
                              <path d="M9 6l6 6-6 6" />
                            </svg>
                          </a>
                        </div>
                      )}
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- ══════════════════════ Handles Grid (.l374) ══════════════════════ -->
  {
    page?.handlesItems && page.handlesItems.length > 0 && (
      <section class="prov-handles" id="l374-section">
        <div class="prov-max">
          <div class="l374-head">
            {page?.handlesEyebrow && <p class="l374-eyebrow">{page.handlesEyebrow}</p>}
            {page?.handlesHeading && <h2>{page.handlesHeading}</h2>}
          </div>

          <div class="l374-grid">
            {page.handlesItems.map((item, idx) => (
              <div class={`l374-card${idx === 0 ? ' feature' : ''}`}>
                <div class="l374-card-body">
                  {item.heading && <h3>{item.heading}</h3>}
                  {item.body && <p>{item.body}</p>}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- ══════════════════════ Qualifications (.l506) ══════════════════════ -->
  {
    page?.quals && page.quals.length > 0 && (
      <section class="prov-quals">
        <div class="prov-max">
          <div class="l506-head">
            {page?.qualsEyebrow && <p class="eyebrow">{page.qualsEyebrow}</p>}
            {page?.qualsHeading && <h2>{page.qualsHeading}</h2>}
          </div>

          <div class="l506-tabs" id="l506">
            {page.quals.map((qual, idx) => (
              <div
                class={`l506-panel${idx === 0 ? ' active' : ''}`}
                id={`qual-panel-${idx}`}
                role="tabpanel"
                aria-labelledby={`qual-tab-${idx}`}
              >
                <div class="l506-panel-inner">
                  <div class="l506-icon" aria-hidden="true">
                    <svg
                      width="22"
                      height="22"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M5 12l5 5L20 7" />
                    </svg>
                  </div>
                  {qual.scope && (
                    <p class="l506-scope-badge">{SCOPE_LABELS[qual.scope] ?? qual.scope}</p>
                  )}
                  {qual.body && <p>{qual.body}</p>}
                </div>
              </div>
            ))}

            <div class="l506-list" role="tablist">
              {page.quals.map((qual, idx) => (
                <button
                  class={`l506-trigger${idx === 0 ? ' active' : ''}`}
                  id={`qual-tab-${idx}`}
                  data-panel={`qual-panel-${idx}`}
                  role="tab"
                  aria-selected={idx === 0 ? 'true' : 'false'}
                  aria-controls={`qual-panel-${idx}`}
                >
                  {qual.scope
                    ? (SCOPE_LABELS[qual.scope] ?? qual.scope)
                    : `Qualification ${idx + 1}`}
                </button>
              ))}
            </div>
          </div>
        </div>
      </section>
    )
  }

  <!-- ══════════════════════ Testimonials (.t37-section) ══════════════════════ -->
  {
    testimonials && testimonials.length > 0 && (
      <section class="t37-section">
        <div class="prov-max">
          <div class="t37-head">
            <div class="t37-head-inner">
              <h2>What our therapists are saying</h2>
              <p class="t37-subhead">Peer proof from clinicians already working with BYT.</p>
            </div>
          </div>

          <div class="t37-grid">
            {testimonials.map((t) => (
              <div class="t37-cell t37-test">
                <div class="t37-stars" aria-label="5 stars">
                  {[0, 1, 2, 3, 4].map(() => (
                    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.27 5.82 22 7 14.14l-5-4.87 6.91-1.01z" />
                    </svg>
                  ))}
                </div>
                {t.quote && <p class="t37-quote">"{t.quote}"</p>}
                <div class="t37-meta">
                  <div class="t37-avatar t37-avatar-init" aria-hidden="true">
                    {t.authorInitials ?? ''}
                  </div>
                  <div>
                    {t.authorName && <p class="t37-name">{t.authorName}</p>}
                    {(t.authorRole || t.authorOrg) && (
                      <p class="t37-role">
                        {[t.authorRole, t.authorOrg].filter(Boolean).join(' · ')}
                      </p>
                    )}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- ══════════════════════ CTA Band (.cta36-section) ══════════════════════ -->
  {
    (page?.ctaHeading || page?.ctaCta) && (
      <section class="cta36-section">
        <div class="prov-max">
          <div class="cta36-grid">
            <div class="cta36-cell">
              <div class="cta36-icon-circle" aria-hidden="true">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                  <polyline points="14 2 14 8 20 8" />
                  <line x1="9" y1="15" x2="15" y2="15" />
                </svg>
              </div>
              {page?.ctaHeading && <h2>{page.ctaHeading}</h2>}
              {page?.ctaSubhead && <p>{page.ctaSubhead}</p>}
              {page?.ctaCta && (
                <div class="cta36-actions">
                  <a href={page.ctaCta.href} class={`btn btn-${page.ctaCta.variant ?? 'primary'}`}>
                    {page.ctaCta.label}
                  </a>
                </div>
              )}
            </div>
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  /* ── Shared layout helpers ───────────────────────────────────── */
  .prov-max {
    max-width: var(--max-w);
    margin-inline: auto;
    padding-inline: var(--pad-x);
  }

  /* ── Hero (.h98) ─────────────────────────────────────────────── */
  .h98 {
    padding: 0;
  }

  .h98-card {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .h98-content {
    position: relative;
    z-index: 10;
    display: flex;
    min-height: 32rem;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem var(--pad-x);
    text-align: center;
    color: var(--white);
  }

  @media (min-width: 768px) {
    .h98-content {
      min-height: 40rem;
      padding: 4rem var(--pad-x);
    }
  }

  @media (min-width: 1024px) {
    .h98-content {
      min-height: 44rem;
    }
  }

  .h98-inner {
    width: 100%;
    max-width: 56rem;
  }

  .h98 h1 {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--white);
    margin-bottom: 1rem;
  }

  @media (min-width: 768px) {
    .h98 h1 {
      margin-bottom: 1.5rem;
    }
  }

  .h98-subhead {
    color: rgba(255, 255, 255, 0.88);
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    line-height: 1.45;
    font-weight: 500;
    letter-spacing: -0.01em;
    max-width: 36rem;
    margin-inline: auto;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 768px) {
    .h98-subhead {
      margin-bottom: 2rem;
    }
  }

  .h98-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.875rem;
    margin-top: 0.25rem;
  }

  .h98-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy) 100%);
  }

  .h98-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0.55;
    mix-blend-mode: luminosity;
  }

  .h98-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10, 45, 82, 0.55) 0%,
      rgba(10, 45, 82, 0.35) 50%,
      rgba(10, 45, 82, 0.75) 100%
    );
  }

  /* ── Role Tracks (.prov-tracks / .l422) ─────────────────────── */
  .prov-tracks {
    padding: var(--pad-s) 0;
    background: var(--white);
  }

  .l422-head {
    margin-inline: auto;
    margin-bottom: 48px;
    width: 100%;
    max-width: 48rem;
    text-align: center;
  }

  @media (min-width: 768px) {
    .l422-head {
      margin-bottom: 72px;
    }
  }

  .l422-eyebrow {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--coral);
    display: block;
    margin-bottom: 1rem;
  }

  .l422-head h2 {
    font-size: clamp(2rem, 3.6vw, 3.25rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
  }

  .l422-subhead {
    color: var(--slate);
    font-size: 17px;
    line-height: 1.6;
    max-width: 540px;
    margin: 0 auto;
  }

  .l422-cards {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .l422-cards {
      flex-direction: row;
      gap: 2rem;
    }
  }

  .l422-card {
    position: relative;
    display: flex;
    width: 100%;
    flex-direction: column;
    overflow: hidden;
    border-radius: var(--r-card);
    box-shadow: var(--shadow-md);
    background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy) 100%);
    transition: box-shadow 0.25s;
    min-height: 360px;
  }

  .l422-card:hover {
    box-shadow: var(--shadow-lg);
  }

  @media (min-width: 768px) {
    .l422-card {
      width: 50%;
      min-height: 500px;
    }
  }

  @media (min-width: 1024px) {
    .l422-cards:not(:hover) > .l422-card.is-default {
      width: 60%;
    }

    .l422-cards:hover > .l422-card:hover {
      width: 60%;
    }

    .l422-card {
      transition:
        width 0.35s cubic-bezier(0.4, 0, 0.2, 1),
        box-shadow 0.25s;
    }
  }

  .l422-card-content {
    position: relative;
    display: flex;
    height: 100%;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.5rem;
    color: var(--white);
    z-index: 1;
    flex: 1;
  }

  @media (min-width: 768px) {
    .l422-card-content {
      padding: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .l422-card-content {
      padding: 3rem;
    }
  }

  .l422-card-eyebrow {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.78);
    margin-bottom: 0.75rem;
  }

  .l422-card h3 {
    font-size: clamp(1.75rem, 3vw, 3rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--white);
    margin-bottom: 0;
  }

  .l422-card-body {
    margin-top: 1.25rem;
  }

  .l422-card-body p {
    color: rgba(255, 255, 255, 0.88);
    line-height: 1.6;
    font-size: 15px;
  }

  @media (min-width: 768px) {
    .l422-card-body p {
      font-size: 1.0625rem;
    }
  }

  .l422-status-note {
    margin-top: 0.75rem;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.65);
    font-style: italic;
  }

  .l422-card-cta {
    margin-top: 1.5rem;
  }

  .btn-link-alt {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    color: var(--white);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--t-hover);
    background: transparent;
    border: 0;
    padding: 0;
    cursor: pointer;
  }

  .btn-link-alt:hover {
    color: rgba(255, 255, 255, 0.8);
  }

  .btn-link-alt svg {
    width: 1em;
    height: 1em;
  }

  /* ── Handles Grid (.prov-handles / .l374) ────────────────────── */
  #l374-section {
    background: var(--off-white);
  }

  .prov-handles {
    padding: var(--pad-s) 0;
  }

  .l374-head {
    margin-bottom: 48px;
    text-align: center;
  }

  @media (min-width: 768px) {
    .l374-head {
      margin-bottom: 72px;
    }
  }

  .l374-eyebrow {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--coral);
    display: block;
    margin-bottom: 1rem;
  }

  .l374-head h2 {
    font-size: clamp(2rem, 3.6vw, 3.25rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 0;
  }

  .l374-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .l374-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 768px) {
    .l374-grid {
      gap: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .l374-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .l374-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    background: var(--white);
    border-radius: var(--r-card);
    overflow: hidden;
    transition:
      border-color var(--t-hover),
      box-shadow var(--t-hover),
      transform var(--t-hover);
  }

  .l374-card:hover {
    border-color: var(--coral);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .l374-card.feature {
    grid-column: span 1;
  }

  @media (min-width: 640px) {
    .l374-card.feature {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 768px) {
    .l374-card.feature {
      flex-direction: row;
    }
  }

  .l374-card-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    justify-content: center;
    padding: 1.5rem;
  }

  @media (min-width: 768px) {
    .l374-card.feature .l374-card-body {
      padding: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .l374-card.feature .l374-card-body {
      padding: 3rem;
    }
  }

  .l374-card h3 {
    font-size: 1.125rem;
    font-weight: 800;
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin-bottom: 0.5rem;
  }

  .l374-card.feature h3 {
    font-size: clamp(1.5rem, 2.4vw, 2rem);
    margin-bottom: 1rem;
  }

  .l374-card-body p {
    color: var(--slate);
    line-height: 1.6;
    font-size: 15px;
  }

  /* ── Qualifications (.prov-quals / .l506) ────────────────────── */
  .prov-quals {
    padding: var(--pad-s) 0;
    background: var(--white);
  }

  .l506-head {
    margin-inline: auto;
    margin-bottom: 48px;
    width: 100%;
    max-width: 48rem;
    text-align: center;
  }

  @media (min-width: 768px) {
    .l506-head {
      margin-bottom: 72px;
    }
  }

  .l506-head .eyebrow {
    display: block;
    margin-bottom: 1rem;
  }

  .l506-head h2 {
    font-size: clamp(2rem, 3.6vw, 3.25rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 0;
  }

  .l506-tabs {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    border: 1px solid var(--border);
    background: var(--white);
    border-radius: var(--r-card);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  @media (min-width: 768px) {
    .l506-tabs {
      grid-template-columns: 1.5fr 1fr;
    }
  }

  .l506-panel {
    display: none;
    animation: l506fade 0.25s ease;
  }

  .l506-panel.active {
    display: block;
  }

  @keyframes l506fade {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .l506-panel-inner {
    display: flex;
    height: 100%;
    flex-direction: column;
    justify-content: center;
    padding: 1.5rem;
  }

  @media (min-width: 768px) {
    .l506-panel-inner {
      padding: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .l506-panel-inner {
      padding: 4rem;
    }
  }

  .l506-icon {
    margin-bottom: 1.25rem;
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
