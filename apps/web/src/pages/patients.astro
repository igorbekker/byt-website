    .l505-trigger.active::before {
      content: '';
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
      width: 3px;
      height: 60%;
      background: var(--coral);
      border-radius: 0 2px 2px 0;
    }
    .l505-trigger:hover:not(.active) {
      color: var(--navy-deep);
      background: var(--off-white);
    }
    .l505-panel {
      display: none;
      animation: l505fade 0.25s ease;
    }
    .l505-panel.active {
      display: block;
    }
    @keyframes l505fade {
      from {
        opacity: 0;
        transform: translateY(8px);
      }
      to {
        opacity: 1;
        transform: none;
      }
