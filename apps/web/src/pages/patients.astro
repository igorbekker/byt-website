    /* ── LAYOUT505: vertical tabs (list LEFT, panel RIGHT) ── */
    .ph-l505 {
      background: var(--off-white);
      padding: var(--pad-s) var(--pad-x);
    }
    .l505-head {
      max-width: var(--max-w);
      margin: 0 auto 3rem;
      text-align: center;
    }
    .l505-head .eyebrow {
      display: inline-block;
      margin-bottom: 1rem;
    }
    .l505-head h2 {
      font-size: clamp(2rem, 3.6vw, 3rem);
      margin-bottom: 1rem;
      letter-spacing: -0.02em;
    }
    .l505-head > p {
      color: var(--slate);
      font-size: 17px;
      line-height: 1.6;
      max-width: 640px;
      margin: 0 auto;
    }
    .l505-tabs {
      max-width: var(--max-w);
      margin: 0 auto;
      position: relative;
      display: grid;
      grid-template-columns: 1fr 1.5fr;
      background: #fff;
      border-radius: var(--r-card);
      overflow: hidden;
    }
    .l505-list {
      background: #fff;
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
    }
    .l505-trigger {
      text-align: left;
      padding: 1.25rem 1.75rem;
      font-family: 'Manrope', sans-serif;
      font-size: 1.0625rem;
      font-weight: 700;
      letter-spacing: -0.01em;
      border: 0;
      border-bottom: 1px solid var(--border);
      background: transparent;
      color: var(--mist);
      cursor: pointer;
      transition:
        background-color 0.15s,
        color 0.15s;
      position: relative;
    }
    .l505-trigger:last-child {
      border-bottom: 0;
    }
    .l505-trigger.active {
      background: var(--off-white);
      color: var(--navy-deep);
    }
    .l505-trigger.active::before {
      content: '';
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
      width: 3px;
      height: 60%;
      background: var(--coral);
      border-radius: 0 2px 2px 0;
    }
    .l505-trigger:hover:not(.active) {
      color: var(--navy-deep);
      background: var(--off-white);
    }
    .l505-panel {
      display: none;
      animation: l505fade 0.25s ease;
    }
    .l505-panel.active {
      display: block;
    }
    @keyframes l505fade {
      from {
        opacity: 0;
        transform: translateY(8px);
      }
      to {
        opacity: 1;
        transform: none;
      }
    }
    .l505-panel-inner {
      display: flex;
      height: 100%;
      flex-direction: column;
      justify-content: center;
      padding: 3rem;
    }
    .l505-icon {
      margin-bottom: 1.5rem;
      width: 48px;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--coral-light);
      color: var(--coral);
      border-radius: 12px;
    }
    .l505-panel h3 {
      margin-bottom: 1.25rem;
      font-size: clamp(1.6rem, 2.4vw, 2rem);
      font-weight: 800;
      line-height: 1.15;
      letter-spacing: -0.01em;
      color: var(--navy-deep);
    }
    .l505-panel > p {
      color: var(--slate);
      line-height: 1.65;
      font-size: 16px;
    }
    @media (max-width: 768px) {
      .l505-tabs {
        grid-template-columns: 1fr;
        display: block;
        background: transparent;
        border-radius: 0;
        overflow: visible;
      }
      .l505-list {
        display: contents;
      }
      .l505-trigger {
        width: 100%;
        display: block;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--r-card);
        margin-bottom: 0.5rem;
        padding: 1rem 1.25rem;
        font-size: 1rem;
        position: relative;
      }
      .l505-trigger.active {
        border-color: var(--coral);
        background: #fff;
      }
      .l505-trigger.active::before {
        content: '';
        position: absolute;
        left: 0;
        top: 1rem;
        bottom: 1rem;
        width: 3px;
        background: var(--coral);
        border-radius: 0 2px 2px 0;
        transform: none;
        height: auto;
      }
      .l505-trigger::after {
        content: '+';
        position: absolute;
        right: 1.25rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1.4rem;
        font-weight: 400;
        color: var(--slate);
        line-height: 1;
      }
      .l505-trigger.active::after {
        content: '–';
        color: var(--coral);
      }
      .l505-panel.active {
        display: block;
        margin: -0.5rem 0 0.75rem;
      }
      .l505-panel-inner {
        padding: 1.25rem 1.25rem 1.5rem;
        background: #fff;
        border: 1px solid var(--coral);
        border-top: 0;
        border-radius: 0 0 var(--r-card) var(--r-card);
      }
      .l505-trigger.active {
        border-bottom-left-radius: 0;
        border-bottom-right-radius: 0;
        margin-bottom: 0;
      }
    }

