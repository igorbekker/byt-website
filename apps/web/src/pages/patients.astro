  <script is:inline>
    // ── BLOCK 2: Router accordion
    function activateRouterCard(idx) {
      const isMobile = window.innerWidth <= 768;
      document.querySelectorAll('.r-card').forEach((c, i) => {
        c.classList.remove('r-active', 'r-inactive');
        c.classList.add(i === idx ? 'r-active' : 'r-inactive');
        const wc = c.querySelector('.r-wide-content');
        const wi = c.querySelector('.r-wide-image');
        const nc = c.querySelector('.r-narrow-content');
        if (isMobile) {
          // On mobile: all cards show wide-content stacked
          if (wc) wc.style.display = 'flex';
          if (wi) wi.style.display = 'none';
          if (nc) nc.style.display = 'none';
          c.style.display = 'block';
          c.style.flexDirection = '';
        } else if (i === idx) {
          if (wc) wc.style.display = 'flex';
          if (wi) wi.style.display = 'block';
          if (nc) nc.style.display = 'none';
          c.style.display = 'flex';
          c.style.flexDirection = 'row';
        } else {
          if (wc) wc.style.display = 'none';
          if (wi) wi.style.display = 'none';
          if (nc) nc.style.display = 'flex';
          c.style.display = '';
          c.style.flexDirection = '';
        }
      });
    }
    document.querySelectorAll('.r-card').forEach((c, i) => {
      c.classList.add(i === 0 ? 'r-active' : 'r-inactive');
    });
    activateRouterCard(0);
    window.addEventListener('resize', () =>
      activateRouterCard(
        [...document.querySelectorAll('.r-card')].findIndex((c) =>
          c.classList.contains('r-active'),
        ) || 0,
      ),
    );

    // ── BLOCK 5: sticky scroll image cross-fade
    const l349Imgs = document.querySelectorAll('[data-img]');
    function updateConditionImage() {
      const vh = window.innerHeight;
      const l349 = document.getElementById('l349');
      if (!l349) return;
      const rect = l349.getBoundingClientRect();
      const scrolledInto = -rect.top;
      if (scrolledInto < 0) return;
      const active = Math.min(Math.floor(scrolledInto / vh), l349Imgs.length - 1);
      l349Imgs.forEach((img, i) => {
        img.style.opacity = i === active ? '1' : '0';
        img.classList.toggle('active', i === active);
      });
    }
    l349Imgs.forEach((img, i) => {
      img.style.transition = 'opacity 0.35s ease';
      if (i > 0) img.style.opacity = '0';
    });
    window.addEventListener('scroll', updateConditionImage, { passive: true });
    updateConditionImage();

    // ── Scroll fade-up
    const fadeObs = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            fadeObs.unobserve(e.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -40px 0px' },
    );
    document.querySelectorAll('.fade-up').forEach((el) => fadeObs.observe(el));

    // ── LAYOUT505: vertical tabs
    (function () {
      const root = document.getElementById('l505');
      if (!root) return;
      const triggers = root.querySelectorAll('.l505-trigger');
      const panels = root.querySelectorAll('.l505-panel');
      const mq = window.matchMedia('(max-width: 768px)');
      function syncPanelPosition(activeBtn, activePanel) {
        if (mq.matches && activePanel && activeBtn) {
          activeBtn.insertAdjacentElement('afterend', activePanel);
        } else if (!mq.matches) {
          // restore: all panels live after .l505-list
          const list = root.querySelector('.l505-list');
          panels.forEach(function (p) {
            root.appendChild(p);
          });
          // (list stays in place because it was never moved)
          void list;
        }
      }
      triggers.forEach(function (btn) {
        btn.addEventListener('click', function () {
          const key = btn.getAttribute('data-tab');
          const isActive = btn.classList.contains('active');
          // On mobile, clicking the active trigger collapses it
          if (mq.matches && isActive) {
            btn.classList.remove('active');
            panels.forEach(function (p) {
              p.classList.remove('active');
            });
            return;
          }
          triggers.forEach(function (b) {
            b.classList.toggle('active', b === btn);
          });
          let activePanel = null;
          panels.forEach(function (p) {
            const on = p.getAttribute('data-panel') === key;
            p.classList.toggle('active', on);
            if (on) activePanel = p;
          });
          syncPanelPosition(btn, activePanel);
        });
      });
      // On viewport changes, reposition the currently-active panel
      mq.addEventListener('change', function () {
        const activeBtn = root.querySelector('.l505-trigger.active');
        const activePanel = root.querySelector('.l505-panel.active');
        syncPanelPosition(activeBtn, activePanel);
      });
      // Initial position on load
      (function init() {
        const activeBtn = root.querySelector('.l505-trigger.active');
        const activePanel = root.querySelector('.l505-panel.active');
        syncPanelPosition(activeBtn, activePanel);
      })();
    })();
  </script>
