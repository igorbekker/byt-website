---
import { sanityClient } from 'sanity:client';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_SETTINGS_QUERY } from '../lib/queries';

interface SiteSettings {
  phone?: string;
  email?: string;
  fax?: string;
}

const siteSettings = await sanityClient.fetch<SiteSettings>(SITE_SETTINGS_QUERY);
const phone = siteSettings?.phone ?? '754-999-0011';
const email = siteSettings?.email ?? 'hello@getbetteryou.com';
const fax = siteSettings?.fax ?? '754-328-4344';
const phoneDigits = phone.replace(/\D/g, '');
---

<BaseLayout
  title="Resident Referral Form | Better You Therapy"
  description="Submit a resident or patient referral securely. All information is transmitted and stored in full HIPAA compliance."
>
  <section class="rr-hero">
    <div class="rr-hero-inner">
      <h1>Resident Referral Form</h1>
      <p>
        Submit a resident or patient referral securely. All information is transmitted and stored in
        full HIPAA compliance.
      </p>
    </div>
  </section>

  <section class="rr-form-section">
    <div class="rr-form-wrap">
      <div class="rr-hipaa-badge">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
        </svg>
        <span>This form is HIPAA-compliant. All data is encrypted and transmitted securely.</span>
      </div>

      <div class="rr-form-container">
        <script
          is:inline
          id="fc0f96d5-9a30-44a9-ab91-d028aae74411-script"
          src="https://app.hipaatizer.com/shared/hipaatizer-form-renderer.js?workflowId=fc0f96d5-9a30-44a9-ab91-d028aae74411"
        ></script>
        <script is:inline>
          new Hipaatizer('fc0f96d5-9a30-44a9-ab91-d028aae74411', false, '', false).render();
        </script>
      </div>
    </div>
  </section>

  <section class="rr-alt-section">
    <div class="rr-alt-inner">
      <h2>Other Ways to Submit a Referral</h2>
      <ul class="rr-contact-list">
        <li>
          <span class="rr-contact-label">Fax</span>
          <span>{fax}</span>
        </li>
        <li>
          <span class="rr-contact-label">Email</span>
          <a href={`mailto:${email}`}>{email}</a>
        </li>
        <li>
          <span class="rr-contact-label">Phone</span>
          <a href={`tel:+1${phoneDigits}`}>{phone}</a>
        </li>
      </ul>
      <p class="rr-docs">
        Please include the completed referral form, resident face sheet, copies of insurance cards
        (front and back), and any pertinent clinical information.
      </p>
    </div>
  </section>

  <style>
    .rr-hero {
      background: var(--cream);
      padding: 5rem var(--pad-x);
      text-align: center;
      border-bottom: 1px solid var(--border);
    }
    .rr-hero-inner {
      max-width: 700px;
      margin: 0 auto;
    }
    .rr-hero h1 {
      font-family: var(--font-heading);
      font-size: clamp(2.2rem, 3.4vw, 2.8rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      line-height: 1.1;
      color: var(--navy-deep);
      margin-bottom: 1.25rem;
    }
    .rr-hero p {
      font-size: 17px;
      color: var(--slate);
      line-height: 1.6;
    }

    .rr-form-section {
      background: var(--white);
      padding: var(--pad-s) var(--pad-x);
    }
    .rr-form-wrap {
      max-width: 800px;
      margin: 0 auto;
      padding: 40px 0;
    }
    .rr-hipaa-badge {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 7px;
      margin-bottom: 2rem;
      color: var(--slate);
      font-size: 13px;
    }
    .rr-hipaa-badge svg {
      flex-shrink: 0;
    }

    .rr-alt-section {
      background: var(--cream);
      padding: var(--pad-s) var(--pad-x);
      border-top: 1px solid var(--border);
    }
    .rr-alt-inner {
      max-width: 800px;
      margin: 0 auto;
    }
    .rr-alt-inner h2 {
      font-family: var(--font-heading);
      font-size: clamp(1.4rem, 2vw, 1.75rem);
      font-weight: 700;
      color: var(--navy-deep);
      margin-bottom: 1.5rem;
    }
    .rr-contact-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
      margin-bottom: 1.75rem;
    }
    .rr-contact-list li {
      display: flex;
      align-items: center;
      gap: 1rem;
      font-size: 15px;
      color: var(--slate);
    }
    .rr-contact-label {
      font-weight: 600;
      color: var(--navy-deep);
      min-width: 56px;
    }
    .rr-contact-list a {
      color: var(--slate);
      transition: color var(--t-hover);
    }
    .rr-contact-list a:hover {
      color: var(--navy-deep);
    }
    .rr-docs {
      font-size: 14px;
      color: var(--slate);
      line-height: 1.7;
      max-width: 680px;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border);
    }

    @media (max-width: 768px) {
      .rr-hero {
        padding: 3.5rem var(--pad-x);
      }
      .rr-form-section,
      .rr-alt-section {
        padding-left: var(--pad-x);
        padding-right: var(--pad-x);
      }
    }
  </style>
</BaseLayout>
