---
import { sanityClient } from 'sanity:client';
import BaseLayout from '../layouts/BaseLayout.astro';
import { HOME_PAGE_QUERY } from '../lib/queries';

interface CtaLink {
  label: string;
  href: string;
  variant?: string;
}
interface ProcessStep {
  stepNumber: number;
  heading: string;
  body?: string;
}
interface AudienceCard {
  tagline: string;
  heading: string;
  bodyCollapsed: string;
  bodyExpanded: string;
  cta?: CtaLink;
}
interface ServiceTrack {
  label: string;
  heading: string;
  body?: string;
  cta?: CtaLink;
}
interface SeoFields {
  metaTitle?: string;
  metaDescription?: string;
}
interface HomePage {
  heroEyebrow?: string;
  heroHeadline?: string;
  heroSubhead?: string;
  heroImage?: { asset?: { url: string }; alt?: string };
  heroPrimaryCta?: CtaLink;
  heroSecondaryCta?: CtaLink;
  routerEyebrow?: string;
  routerHeading?: string;
  routerSubhead?: string;
  routerCards?: AudienceCard[];
  beliefQuote?: string;
  beliefBody?: string;
  twoWaysEyebrow?: string;
  twoWaysHeading?: string;
  twoWaysSubhead?: string;
  twoWaysTracks?: ServiceTrack[];
  conditionsEyebrow?: string;
  conditionsHeading?: string;
  conditionsSubhead?: string;
  howItWorksEyebrow?: string;
  howItWorksHeading?: string;
  teletherapyTrackLabel?: string;
  teletherapySteps?: ProcessStep[];
  teletherapyCta?: CtaLink;
  facilityTrackLabel?: string;
  facilitySteps?: ProcessStep[];
  facilityCta?: CtaLink;
  testimonialsEyebrow?: string;
  testimonialsHeading?: string;
  testimonialsSubhead?: string;
  providerTeaserEyebrow?: string;
  providerTeaserHeading?: string;
  providerTeaserBody?: string;
  providerTeaserImage?: { asset?: { url: string }; alt?: string };
  providerTeaserPrimaryCta?: CtaLink;
  providerTeaserSecondaryCta?: CtaLink;
  seo?: SeoFields;
}

const page = await sanityClient.fetch<HomePage>(HOME_PAGE_QUERY);

const heroImg =
  page?.heroImage?.asset?.url ??
  'https://images.unsplash.com/photo-1544027993-37dbfe43562a?w=1400&q=85&auto=format&fit=crop&crop=faces';

const cards = page?.routerCards ?? [];
const tracks = page?.twoWaysTracks ?? [];
const teleSteps = page?.teletherapySteps ?? [];
const facSteps = page?.facilitySteps ?? [];

const ROUTER_IMGS = [
  'https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?w=700&q=85&auto=format&fit=crop',
  'https://images.unsplash.com/photo-1527137342181-19aab11a8ee8?w=700&q=85&auto=format&fit=crop',
  'https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=700&q=85&auto=format&fit=crop',
];
---

<BaseLayout
  title={page?.seo?.metaTitle ??
    'Better You Therapy | Licensed Mental Health Care in Southeast Florida'}
  seo={page?.seo ?? null}
>
  <style is:global>
    /* ── HERO ── */
    .hero {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 88vh;
      max-height: 760px;
      background: var(--cream);
    }
    .hero-image {
      position: relative;
      overflow: hidden;
      background: var(--navy);
    }
    .hero-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
    }
    .hero-content {
      background: var(--cream);
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 4rem 3.5rem;
      position: relative;
    }
    .hero-eyebrow {
      font-family: 'Montserrat', sans-serif;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--coral);
      margin-bottom: 1.5rem;
    }
    .hero-content h1 {
      font-family: 'Manrope', sans-serif;
      color: var(--navy-deep);
      font-size: clamp(2.2rem, 3.6vw, 3rem);
      line-height: 1.08;
      letter-spacing: -0.02em;
      font-weight: 800;
      margin-bottom: 1.5rem;
    }
    .hero-subhead {
      color: var(--slate);
      font-size: 17px;
      line-height: 1.6;
      margin-bottom: 2.25rem;
      font-weight: 400;
      max-width: 520px;
    }
    .hero-actions {
      display: flex;
      flex-direction: row;
      gap: 0.75rem;
      align-items: center;
      flex-wrap: wrap;
    }
    /* ── ROUTER ── */
    .router-section {
      background: var(--navy-deep);
      padding: var(--pad-s) var(--pad-x);
    }
    .router-header {
      text-align: center;
      margin-bottom: 48px;
    }
    .router-header .eyebrow {
      color: rgba(255, 255, 255, 0.65);
      margin-bottom: 1rem;
    }
    .router-header h2 {
      font-family: 'Manrope', sans-serif;
      font-weight: 800;
      font-size: clamp(2rem, 3.5vw, 2.8rem);
      color: #fff;
      margin-bottom: 1rem;
      letter-spacing: -0.02em;
    }
    .router-header p {
      color: rgba(255, 255, 255, 0.72);
      max-width: 520px;
      margin: 0 auto;
      font-size: 17px;
      line-height: 1.6;
    }
    .router-row {
      display: flex;
      gap: 16px;
      align-items: stretch;
      height: 380px;
      max-width: var(--max-w);
      margin: 0 auto;
    }
    .r-card {
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: var(--r-card);
      overflow: hidden;
      background: var(--white);
      cursor: pointer;
      transition:
        flex 0.45s cubic-bezier(0.4, 0, 0.2, 1),
        border-color var(--t-hover),
        box-shadow var(--t-hover);
      position: relative;
    }
    .r-card:hover {
      border-color: rgba(224, 85, 85, 0.5);
      box-shadow: var(--shadow-lg);
    }
    .r-card.r-active {
      border-color: var(--coral);
      box-shadow: 0 8px 24px rgba(224, 85, 85, 0.18);
    }
    .r-card-wide {
      flex: 0 0 580px;
      display: flex;
      flex-direction: row;
    }
    .r-card-wide.r-inactive {
      flex: 1 0 0;
      display: block;
    }
    .r-card-narrow {
      flex: 1 0 0;
      min-width: 0;
    }
    .r-card-narrow.r-active {
      flex: 0 0 580px;
    }
    .r-wide-content {
      flex: 1 0 0;
      padding: 32px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      min-width: 0;
    }
    .r-wide-image {
      flex: 1 0 0;
      min-width: 0;
      background: var(--off-white) center/cover no-repeat;
    }
    .r-card-wide.r-inactive .r-wide-image {
      display: none;
    }
    .r-card-wide.r-inactive .r-wide-content {
      padding: 32px;
    }
    .r-narrow-content {
      padding: 28px;
      display: flex;
      flex-direction: column;
      gap: 14px;
      height: 100%;
      overflow: hidden;
    }
    .r-tagline {
      font-family: 'Montserrat', sans-serif;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--coral);
      margin-bottom: 0.5rem;
    }
    .r-heading {
      font-family: 'Manrope', sans-serif;
      font-size: 1.5rem;
      font-weight: 800;
      color: var(--navy-deep);
      line-height: 1.15;
      letter-spacing: -0.02em;
      margin-bottom: 0.6rem;
    }
    .r-body {
      font-size: 15px;
      color: var(--slate);
      line-height: 1.6;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .r-active .r-body {
      -webkit-line-clamp: unset;
      overflow: visible;
    }
    .r-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      background: var(--coral-light);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      margin-bottom: 4px;
    }
    .r-icon svg {
      width: 24px;
      height: 24px;
    }
    .r-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: 'Montserrat', sans-serif;
      font-size: 15px;
      font-weight: 600;
      color: #fff;
      background: var(--coral);
      letter-spacing: 0.01em;
      padding: 12px 20px;
      border-radius: var(--r-btn);
      border: none;
      cursor: pointer;
      transition: background-color var(--t-hover);
      flex-shrink: 0;
      text-decoration: none;
      margin-top: auto;
      align-self: flex-start;
    }
    .r-cta:hover {
      background: var(--coral-hover);
    }
    /* ── BELIEF ── */
    .belief {
      background: var(--cream);
      padding: var(--pad-s) var(--pad-x);
      text-align: center;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }
    .belief-inner {
      max-width: 760px;
      margin: 0 auto;
    }
    .belief-rule {
      width: 48px;
      height: 2px;
      background: var(--coral);
      margin: 0 auto 1.75rem;
      border-radius: 2px;
    }
    .belief h2 {
      color: var(--navy-deep);
      font-size: clamp(1.9rem, 3.2vw, 2.6rem);
      font-weight: 800;
      margin-bottom: 1.25rem;
      line-height: 1.15;
      letter-spacing: -0.02em;
    }
    .belief p {
      color: var(--slate);
      font-size: 17px;
      line-height: 1.7;
      font-weight: 400;
    }
    /* ── TWOWAYS ── */
    .twoways {
      background: var(--navy-deep);
      padding: var(--pad-s) var(--pad-x) 4rem;
    }
    .twoways-header {
      text-align: center;
      margin-bottom: 3rem;
    }
    .twoways-header .eyebrow {
      color: rgba(255, 255, 255, 0.65);
      margin-bottom: 1rem;
    }
    .twoways-header h2 {
      color: #fff;
      max-width: 900px;
      margin: 0 auto 1rem;
      font-size: clamp(2rem, 3.5vw, 2.8rem);
      letter-spacing: -0.02em;
    }
    .twoways-header p {
      color: rgba(255, 255, 255, 0.72);
      max-width: 560px;
      margin: 0 auto;
      font-size: 17px;
      line-height: 1.6;
    }
    .twoways-cards {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      max-width: var(--max-w);
      margin: 0 auto;
    }
    .twoways-card {
      position: relative;
      border-radius: var(--r-card);
      overflow: hidden;
      height: 440px;
      cursor: pointer;
      transition:
        transform 0.3s ease,
        box-shadow var(--t-hover);
    }
    .twoways-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-lg);
    }
    .twoways-card-bg {
      position: absolute;
      inset: 0;
      background-size: cover;
      background-position: center;
      transition: transform 0.5s ease;
    }
    .twoways-card:hover .twoways-card-bg {
      transform: scale(1.04);
    }
    .twoways-card-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(10, 45, 82, 0.96) 30%, rgba(10, 45, 82, 0.25) 100%);
    }
    .twoways-card-content {
      position: absolute;
      inset: 0;
      padding: 2.25rem 2rem;
      color: #fff;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
    }
    .twoways-card-content > .twoways-card-label {
      margin-top: auto;
      margin-bottom: 0.75rem;
    }
    .twoways-card-label {
      font-family: 'Montserrat', sans-serif;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.72);
      margin-bottom: 0.75rem;
    }
    .twoways-card h3 {
      color: #fff;
      font-size: 1.75rem;
      margin-bottom: 0.75rem;
      line-height: 1.15;
      letter-spacing: -0.02em;
      font-weight: 800;
    }
    .twoways-card p {
      color: rgba(255, 255, 255, 0.82);
      font-size: 15px;
      line-height: 1.6;
      margin-bottom: 1.5rem;
      max-width: 90%;
    }
    /* ── CONDITIONS ── */
    .l349 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      position: relative;
    }
    .l349-section-header {
      text-align: center;
      padding: 2.5rem var(--pad-x) 2rem;
      background: var(--white);
    }
    .l349-section-header .eyebrow {
      margin-bottom: 1rem;
    }
    .l349-section-header h2 {
      font-size: clamp(2rem, 3.5vw, 2.8rem);
      color: var(--navy-deep);
      margin-bottom: 1rem;
      letter-spacing: -0.02em;
    }
    .l349-section-header p {
      color: var(--slate);
      max-width: 560px;
      margin: 0 auto;
      font-size: 17px;
      line-height: 1.6;
    }
    .l349-left {
      display: flex;
      flex-direction: column;
    }
    .l349-section {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 80px clamp(3rem, 6vw, 6rem) 80px var(--pad-x);
    }
    .l349-section:nth-child(odd) {
      background: var(--white);
    }
    .l349-section:nth-child(even) {
      background: var(--off-white);
    }
    .l349-tagline {
      font-family: 'Montserrat', sans-serif;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--coral);
      margin-bottom: 1rem;
    }
    .l349-h2 {
      font-family: 'Manrope', sans-serif;
      font-size: clamp(1.8rem, 3vw, 2.4rem);
      color: var(--navy-deep);
      line-height: 1.1;
      letter-spacing: -0.02em;
      font-weight: 800;
      margin-bottom: 1.25rem;
    }
    .l349-body {
      font-size: 17px;
      color: var(--slate);
      line-height: 1.65;
      margin-bottom: 2rem;
      max-width: 460px;
    }
    .l349-actions {
      display: flex;
      gap: 20px;
      align-items: center;
      flex-wrap: wrap;
    }
    .l349-btn-outline {
      font-family: 'Montserrat', sans-serif;
      font-size: 15px;
      font-weight: 600;
      color: var(--navy-deep);
      border: 1.5px solid var(--navy-deep);
      padding: 12px 22px;
      border-radius: var(--r-btn);
      text-decoration: none;
      letter-spacing: 0.01em;
      transition:
        background-color var(--t-hover),
        color var(--t-hover);
    }
    .l349-btn-outline:hover {
      background: var(--navy-deep);
      color: #fff;
    }
    .l349-btn-ghost {
      font-family: 'Montserrat', sans-serif;
      font-size: 15px;
      font-weight: 600;
      color: var(--coral);
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      transition: color var(--t-hover);
    }
    .l349-btn-ghost:hover {
      color: var(--coral-hover);
    }
    .l349-btn-ghost svg {
      transition: transform var(--t-hover);
    }
    .l349-btn-ghost:hover svg {
      transform: translateX(3px);
    }
    .l349-right {
      position: sticky;
      top: 0;
      height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 0;
      background: var(--off-white);
      overflow: hidden;
    }
    .l349-img-wrap {
      position: relative;
      width: 100%;
      height: 100%;
      max-width: none;
    }
    .l349-img-wrap::before {
      display: none;
    }
    .l349-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border-radius: 0;
      opacity: 0;
      transition: opacity 0.4s ease;
      box-shadow: none;
      background-size: cover;
      background-position: center;
    }
    .l349-img.active {
      opacity: 1;
    }
    /* ── HOW IT WORKS ── */
    .howitworks {
      background: var(--cream);
      padding: var(--pad-s) var(--pad-x);
      border-top: 1px solid var(--border);
    }
    .howitworks-header {
      text-align: center;
      margin-bottom: 3.5rem;
    }
    .howitworks-header .eyebrow {
      margin-bottom: 1rem;
    }
    .howitworks-header h2 {
      color: var(--navy-deep);
      margin-bottom: 1rem;
      font-size: clamp(2rem, 3.5vw, 2.8rem);
      letter-spacing: -0.02em;
    }
    .howitworks-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      max-width: var(--max-w);
      margin: 0 auto;
    }
    .howitworks-track {
      display: flex;
      flex-direction: column;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--r-card);
      padding: 2.25rem 2rem;
      box-shadow: var(--shadow-sm);
      transition:
        box-shadow var(--t-hover),
        border-color var(--t-hover);
    }
    .howitworks-track:hover {
      box-shadow: var(--shadow-md);
      border-color: var(--coral);
    }
    .howitworks-track .steps-wrap {
      flex: 1;
    }
    .howitworks-track .track-cta {
      margin-top: 1.75rem;
      text-align: center;
    }
    .tele-num {
      background: var(--sage);
      color: #fff;
    }
    .facility-num {
      background: var(--coral);
      color: #fff;
    }
    .howitworks-track-label {
      font-family: 'Montserrat', sans-serif;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      margin-bottom: 1.75rem;
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }
    .howitworks-track-tele .howitworks-track-label {
      color: var(--sage-hover);
    }
    .howitworks-track-facility .howitworks-track-label {
      color: var(--coral);
    }
    .howitworks-track-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: currentColor;
      opacity: 0.25;
    }
    .step {
      display: flex;
      gap: 1rem;
      margin-bottom: 1.4rem;
      align-items: flex-start;
    }
    .step:last-child {
      margin-bottom: 0;
    }
    .step-num {
      width: 32px;
      height: 32px;
      border-radius: var(--r-pill);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Manrope', sans-serif;
      font-weight: 800;
      font-size: 0.85rem;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .step-text h4 {
      font-family: 'Manrope', sans-serif;
      font-size: 1rem;
      font-weight: 800;
      color: var(--navy-deep);
      margin-bottom: 0.3rem;
      letter-spacing: -0.01em;
    }
    .step-text p {
      font-size: 14px;
      color: var(--slate);
      line-height: 1.6;
    }
    /* ── TESTIMONIALS ── */
    .testimonials {
      background: var(--white);
      padding: var(--pad-s) var(--pad-x);
    }
    .testimonials-header {
      text-align: center;
      margin-bottom: 3rem;
    }
    .testimonials-header .eyebrow {
      margin-bottom: 1rem;
    }
    .testimonials-header h2 {
      color: var(--navy-deep);
      margin-bottom: 0.75rem;
      font-size: clamp(2rem, 3.5vw, 2.8rem);
      letter-spacing: -0.02em;
    }
    .testimonials-header p {
      color: var(--slate);
      font-size: 17px;
    }
    .testimonials-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      max-width: var(--max-w);
      margin: 0 auto;
    }
    .testimonial-card {
      background: var(--white);
      border-radius: var(--r-card);
      padding: 2.25rem;
      border: 1px solid var(--border);
      position: relative;
      box-shadow: var(--shadow-sm);
      transition:
        box-shadow var(--t-hover),
        border-color var(--t-hover);
    }
    .testimonial-card:hover {
      box-shadow: var(--shadow-md);
      border-color: var(--coral);
    }
    .testimonial-quote-mark {
      font-family: 'Manrope', sans-serif;
      font-size: 6rem;
      line-height: 0.5;
      color: var(--coral);
      opacity: 0.35;
      position: absolute;
      top: 1.25rem;
      left: 1.75rem;
      font-weight: 800;
    }
    .testimonial-text {
      color: var(--slate);
      font-size: 17px;
      line-height: 1.65;
      margin-bottom: 1.75rem;
      padding-top: 2rem;
      font-style: italic;
    }
    .testimonial-attribution {
      display: flex;
      align-items: center;
      gap: 0.875rem;
    }
    .testimonial-avatar {
      width: 44px;
      height: 44px;
      border-radius: var(--r-pill);
      background: var(--off-white);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Manrope', sans-serif;
      font-size: 0.9rem;
      font-weight: 800;
      color: var(--navy-deep);
      flex-shrink: 0;
    }
    .testimonial-name {
      font-family: 'Manrope', sans-serif;
      font-size: 15px;
      font-weight: 800;
      color: var(--navy-deep);
    }
    .testimonial-role {
      font-size: 13px;
      color: var(--slate);
    }
    /* ── PROVIDER TEASER ── */
    .provider {
      background: var(--navy-deep);
      padding: var(--pad-s) var(--pad-x);
      text-align: center;
      position: relative;
      overflow: hidden;
