---
/**
 * Purpose: Dev-only striped image placeholder with monospace label — shows content dimensions during development
 * Context: Used in place of real images during Phase 2 before media is sourced
 * Source: design-source/styles/blog.css (.img-ph, .img-ph-coral, .img-ph-sage, .img-ph-navy)
 * Note: Uses --font-mono per Q6
 */

type PlaceholderVariant = 'default' | 'coral' | 'sage' | 'navy';

interface Props {
  label?: string;
  variant?: PlaceholderVariant;
  style?: string;
}

const { label = 'Image', variant = 'default', style = '' } = Astro.props;

const variantClass =
  variant === 'coral'
    ? 'img-ph-coral'
    : variant === 'sage'
      ? 'img-ph-sage'
      : variant === 'navy'
        ? 'img-ph-navy'
        : '';
---

<div class={`img-ph${variantClass ? ' ' + variantClass : ''}`} data-label={label} style={style}>
</div>

<style>
  .img-ph {
    background-color: var(--off-white);
    background-image: repeating-linear-gradient(
      135deg,
      rgba(16, 67, 120, 0.06) 0,
      rgba(16, 67, 120, 0.06) 1px,
      transparent 1px,
      transparent 12px
    );
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--mist);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    overflow: hidden;
  }

  .img-ph::before {
    content: attr(data-label);
    background: rgba(255, 255, 255, 0.85);
    padding: 4px 10px;
    border-radius: 4px;
    border: 1px solid var(--border);
    white-space: nowrap;
  }

  .img-ph-coral {
    background-color: #fcecec;
    background-image: repeating-linear-gradient(
      135deg,
      rgba(224, 85, 85, 0.08) 0,
      rgba(224, 85, 85, 0.08) 1px,
      transparent 1px,
      transparent 12px
    );
  }

  .img-ph-sage {
    background-color: #eef2e8;
    background-image: repeating-linear-gradient(
      135deg,
      rgba(122, 148, 104, 0.1) 0,
      rgba(122, 148, 104, 0.1) 1px,
      transparent 1px,
      transparent 12px
    );
  }

  .img-ph-navy {
    background-color: #e7edf5;
    background-image: repeating-linear-gradient(
      135deg,
      rgba(16, 67, 120, 0.1) 0,
      rgba(16, 67, 120, 0.1) 1px,
      transparent 1px,
      transparent 12px
    );
  }
</style>
