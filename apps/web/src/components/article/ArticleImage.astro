---
/**
 * Purpose: Featured article image with optional caption — displayed between hero and body
 * Context: Article page layout between ArticleHero and ArticleBody
 * Source: design-source/styles/article.css (.article-image, .article-image-inner, .article-image-caption)
 */

interface Props {
  src?: string;
  alt?: string;
  caption?: string;
}

const { src = '', alt = '', caption = '' } = Astro.props;
---

<div class="article-image">
  <div class="article-image-inner">
    {
      src ? (
        <img src={src} alt={alt} style="width:100%;height:100%;object-fit:cover;" />
      ) : (
        <div class="img-ph" data-label={alt || 'Featured image'} style="width:100%;height:100%;" />
      )
    }
  </div>
  {caption && <p class="article-image-caption">{caption}</p>}
</div>

<style>
  .article-image {
    background: var(--off-white);
    padding: 2rem var(--pad-x) 0;
  }

  .article-image-inner {
    max-width: 980px;
    margin: 0 auto;
    border-radius: var(--r-card);
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .article-image-caption {
    max-width: 980px;
    margin: 0.85rem auto 0;
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--mist);
    font-style: italic;
  }

  /* img-ph reuses blog.css styles which are applied globally via ArticleBody */
  .img-ph {
    background-color: var(--off-white);
    background-image: repeating-linear-gradient(
      135deg,
      rgba(16, 67, 120, 0.06) 0,
      rgba(16, 67, 120, 0.06) 1px,
      transparent 1px,
      transparent 12px
    );
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--mist);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .img-ph::before {
    content: attr(data-label);
    background: rgba(255, 255, 255, 0.85);
    padding: 4px 10px;
    border-radius: 4px;
    border: 1px solid var(--border);
    white-space: nowrap;
  }
</style>
