---
/**
 * Purpose: Inline figure with image and caption for use within article prose
 * Context: Embedded within ArticleBody prose slot
 * Source: design-source/styles/article.css (.fig, .fig-img, .fig-caption)
 */

interface Props {
  src?: string;
  alt?: string;
  caption?: string;
}

const { src = '', alt = '', caption = '' } = Astro.props;
---

<figure class="fig">
  <div class="fig-img">
    {
      src ? (
        <img src={src} alt={alt} style="width:100%;height:100%;object-fit:cover;" />
      ) : (
        <div
          class="img-ph img-ph-navy"
          data-label={alt || 'Figure'}
          style="width:100%;height:100%;"
        />
      )
    }
  </div>
  {caption && <figcaption class="fig-caption">{caption}</figcaption>}
</figure>

<style>
  .fig {
    margin: 2.25rem 0;
  }

  .fig-img {
    aspect-ratio: 16 / 10;
    border-radius: var(--r-card);
    overflow: hidden;
  }

  .fig-caption {
    margin-top: 0.6rem;
    font-size: 13px;
    color: var(--mist);
    font-style: italic;
  }

  .img-ph {
    background-color: var(--off-white);
    background-image: repeating-linear-gradient(
      135deg,
      rgba(16, 67, 120, 0.06) 0,
      rgba(16, 67, 120, 0.06) 1px,
      transparent 1px,
      transparent 12px
    );
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--mist);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .img-ph::before {
    content: attr(data-label);
    background: rgba(255, 255, 255, 0.85);
    padding: 4px 10px;
    border-radius: 4px;
    border: 1px solid var(--border);
    white-space: nowrap;
  }
  .img-ph-navy {
    background-color: #e7edf5;
    background-image: repeating-linear-gradient(
      135deg,
      rgba(16, 67, 120, 0.1) 0,
      rgba(16, 67, 120, 0.1) 1px,
      transparent 1px,
      transparent 12px
    );
  }
</style>
