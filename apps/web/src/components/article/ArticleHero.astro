---
/**
 * Purpose: Article page hero — off-white background with category eyebrow, title, deck, and author byline
 * Context: Top of every article/blog post page
 * Source: design-source/styles/article.css (.article-hero, .article-hero-inner, .article-byline, .byline-avatar, .byline-meta, .byline-stats)
 */

interface Props {
  category?: string;
  title: string;
  deck?: string;
  authorName?: string;
  authorInitials?: string;
  authorRole?: string;
  publishDate?: string;
  readTime?: string;
}

const {
  category = 'Mental Health',
  title,
  deck = '',
  authorName = 'BYT Clinical Team',
  authorInitials = 'BT',
  authorRole = 'Licensed Clinician',
  publishDate = '',
  readTime = '',
} = Astro.props;
---

<div class="article-hero">
  <div class="article-hero-inner">
    <div class="eyebrow">
      <a href="/blog/">{category}</a>
    </div>
    <h1 set:html={title} />
    {deck && <p class="article-hero-deck">{deck}</p>}
    <div class="article-byline">
      <div class="byline-avatar">{authorInitials}</div>
      <div class="byline-meta">
        <strong>{authorName}</strong>
        <span>{authorRole}</span>
      </div>
      {
        (publishDate || readTime) && (
          <div class="byline-stats">
            {publishDate && <span>{publishDate}</span>}
            {publishDate && readTime && <span class="dot" />}
            {readTime && <span>{readTime}</span>}
          </div>
        )
      }
    </div>
  </div>
</div>

<style>
  .article-hero {
    background: var(--off-white);
    padding: clamp(2.5rem, 5vh, 4rem) var(--pad-x) clamp(2rem, 4vh, 3rem);
    border-bottom: 1px solid var(--border);
  }

  .article-hero-inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .article-hero .eyebrow {
    margin-bottom: 1.25rem;
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
    font-size: 12px;
  }

  .article-hero .eyebrow a {
    color: var(--coral);
    transition: color var(--t-hover);
  }
  .article-hero .eyebrow a:hover {
    color: var(--coral-hover);
  }

  .article-hero h1 {
    color: var(--navy-deep);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.025em;
    margin-bottom: 1.25rem;
    text-wrap: balance;
  }

  .article-hero h1 :global(em) {
    color: var(--coral);
    font-style: normal;
  }

  .article-hero-deck {
    font-size: 19px;
    line-height: 1.55;
    color: var(--slate);
    margin-bottom: 2rem;
    max-width: 640px;
    font-weight: 500;
  }

  .article-byline {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    flex-wrap: wrap;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--slate);
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
  }

  .byline-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--coral-light);
    color: var(--coral);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 14px;
    letter-spacing: 0.02em;
    flex-shrink: 0;
  }

  .byline-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .byline-meta strong {
    color: var(--navy-deep);
    font-weight: 700;
    font-size: 14px;
  }
  .byline-meta span {
    font-size: 13px;
    color: var(--mist);
  }

  .byline-stats {
    display: flex;
    gap: 0.65rem;
    align-items: center;
    margin-left: auto;
    font-size: 13px;
    color: var(--mist);
  }

  .dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--mist);
  }

  @media (max-width: 768px) {
    .article-byline {
      gap: 0.75rem;
    }
    .byline-stats {
      width: 100%;
      margin-left: 0;
      padding-top: 0.5rem;
      border-top: 1px solid var(--border);
    }
  }
</style>
