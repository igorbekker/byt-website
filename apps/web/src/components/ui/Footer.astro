---
/**
 * Purpose: Site-wide footer with 4-column grid, social links, and legal bar
 * Context: Rendered in BaseLayout at bottom of every page
 * Source: design-source/partials/footer.html, design-source/styles/base.css (.footer, .footer-grid, .footer-col, .footer-links, .footer-bottom, .footer-legal, .social-links, .social-link)
 */

interface Props {
  footerTagline: string;
  copyrightEntity: string;
  newsletterHeading: string;
  newsletterBody: string;
}

const { footerTagline, copyrightEntity, newsletterHeading, newsletterBody } = Astro.props;

const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <div>
        <a href="/" class="footer-logo" aria-label="Better You Therapy">
          <img src="/assets/logo-white.png" alt="Better You Therapy" />
        </a>
        {footerTagline && <p class="footer-tagline">{footerTagline}</p>}
      </div>

      <div class="footer-col">
        <h4>Services</h4>
        <ul class="footer-links">
          <li><a href="/patients/">For Seniors &amp; Families</a></li>
          <li><a href="/patients/">Individual Therapy</a></li>
          <li><a href="/communities/">For Facilities</a></li>
          <li><a href="/providers/">For Therapists</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Company</h4>
        <ul class="footer-links">
          <li><a href="/about/">About Us</a></li>
          <li><a href="/careers/">Careers</a></li>
          <li><a href="/contact/">Contact</a></li>
          <li>
            <a href="#" onclick="event.preventDefault();openModal('refer')">Refer a Resident</a>
          </li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>{newsletterHeading}</h4>
        {newsletterBody && <p class="footer-newsletter-pitch">{newsletterBody}</p>}
        <form class="footer-newsletter-form" id="footerNewsletterForm" novalidate>
          <label class="sr-only" for="footer-newsletter-email">Email address</label>
          <input
            id="footer-newsletter-email"
            type="email"
            required
            placeholder="you@example.com"
            autocomplete="email"
          />
          <button type="submit" class="btn btn-coral">Subscribe</button>
        </form>
      </div>
    </div>

    <div class="footer-divider"></div>

    <div class="footer-bottom">
      <span>&copy; {currentYear} {copyrightEntity}</span>
      <div class="footer-legal">
        <a href="/privacy/">Privacy Policy</a>
        <a href="/terms/">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--navy-deep);
    color: rgba(255, 255, 255, 0.68);
    padding: 4rem var(--pad-x) 2rem;
  }

  .footer-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 4rem;
    margin-bottom: 3rem;
  }

  .footer-logo {
    margin-bottom: 1rem;
    display: block;
  }
  .footer-logo img {
    height: 96px;
    width: auto;
    display: block;
  }

  .footer-tagline {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.65;
    margin-bottom: 1.5rem;
    max-width: 360px;
  }

  .footer-contact {
    font-size: 14px;
    line-height: 1.85;
    color: rgba(255, 255, 255, 0.6);
  }
  .footer-contact a {
    color: rgba(255, 255, 255, 0.6);
    transition: color var(--t-hover);
  }
  .footer-contact a:hover {
    color: #fff;
  }

  .footer-col h4 {
    color: #fff;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .footer-links a {
    color: rgba(255, 255, 255, 0.6);
    font-size: 14px;
    transition: color var(--t-hover);
  }
  .footer-links a:hover {
    color: #fff;
  }

  .footer-newsletter-pitch {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .footer-newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .footer-newsletter-form input {
    padding: 12px 14px;
    border: 1.5px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--r-btn);
    background: rgba(255, 255, 255, 0.07);
    color: #fff;
    font-family: var(--font-body);
    font-size: 14px;
    transition: border-color var(--t-hover);
  }
  .footer-newsletter-form input::placeholder {
    color: rgba(255, 255, 255, 0.35);
  }
  .footer-newsletter-form input:focus {
    outline: none;
    border-color: rgba(255, 255, 255, 0.5);
  }

  .footer-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
    margin-bottom: 1.5rem;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.45);
  }

  .footer-legal {
    display: flex;
    gap: 1.5rem;
  }
  .footer-legal a {
    color: rgba(255, 255, 255, 0.45);
    transition: color var(--t-hover);
  }
  .footer-legal a:hover {
    color: #fff;
  }

  .social-links {
    display: flex;
    gap: 0.6rem;
    margin-top: 1.25rem;
  }
  .social-link {
    width: 36px;
    height: 36px;
    border-radius: var(--r-btn);
    border: 1px solid rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--t-hover);
    color: rgba(255, 255, 255, 0.55);
  }
  .social-link:hover {
    border-color: rgba(255, 255, 255, 0.4);
    color: #fff;
    background: rgba(255, 255, 255, 0.06);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>

<script>
  const form = document.getElementById('footerNewsletterForm') as HTMLFormElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = form.querySelector('button') as HTMLButtonElement | null;
    const input = form.querySelector('input') as HTMLInputElement | null;
    if (!input?.value) return;
    if (btn) {
      btn.textContent = 'Subscribed ✓';
      btn.disabled = true;
    }
    if (input) input.value = '';
    setTimeout(() => {
      if (btn) {
        btn.textContent = 'Subscribe';
        btn.disabled = false;
      }
    }, 2400);
  });
</script>
