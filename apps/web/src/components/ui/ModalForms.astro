---
/**
 * Purpose: Site-wide modal forms — Book a Session and Refer a Resident
 * Context: Rendered in BaseLayout just before </body>; opened via openModal('book') / openModal('refer')
 * Source: design-source/pages/CTA Forms.html lines 153–472 (CSS), 560–997 (HTML + JS)
 */

interface FormOption {
  optionGroup: string;
  label: string;
  value?: string;
  order?: number;
}

interface Props {
  bookId: string;
  referralId: string;
  phone?: string;
  email?: string;
  hours?: string;
  bookEyebrow?: string;
  bookHeading?: string;
  bookValueProps?: { text: string }[];
  bookConsentText?: string;
  bookSubmitLabel?: string;
  bookFinePrint?: string;
  bookSuccessHeading?: string;
  bookSuccessBody?: string;
  referEyebrow?: string;
  referHeading?: string;
  referSubhead?: string;
  referSubmitLabel?: string;
  referSuccessHeading?: string;
  referSuccessBody?: string;
  referFaxNumber?: string;
  // Kept for BaseLayout compat — aside layout removed in new design
  referConsentText?: string;
  referAsideEyebrow?: string;
  referAsideSteps?: { stepNumber: string; text: string }[];
  referAsideContactEyebrow?: string;
  optionsByGroup?: Record<string, FormOption[]>;
}
const {
  bookId,
  referralId,
  email = 'hello@getbetteryou.com',
  bookEyebrow,
  bookHeading,
  bookValueProps,
  bookConsentText,
  bookSubmitLabel,
  bookFinePrint,
  bookSuccessHeading,
  bookSuccessBody,
  referEyebrow,
  referHeading,
  referSubhead,
  referSubmitLabel,
  referSuccessHeading,
  referSuccessBody,
  referFaxNumber,
  optionsByGroup = {},
} = Astro.props;

const defaultBookFor: FormOption[] = [
  { optionGroup: 'bookFor', label: 'For myself', value: 'self' },
  { optionGroup: 'bookFor', label: 'For a loved one', value: 'loved-one' },
  { optionGroup: 'bookFor', label: 'Couples / family', value: 'couple' },
];
const defaultConditionReasons: FormOption[] = [
  { optionGroup: 'conditionReasons', label: 'Depression or anxiety' },
  { optionGroup: 'conditionReasons', label: 'Grief, loss, or life transition' },
  { optionGroup: 'conditionReasons', label: 'Trauma / PTSD' },
  { optionGroup: 'conditionReasons', label: 'Relationships, couples, or family' },
  { optionGroup: 'conditionReasons', label: 'Caregiver stress or burnout' },
  { optionGroup: 'conditionReasons', label: 'Something else' },
  { optionGroup: 'conditionReasons', label: 'Not sure yet' },
];
const defaultPaymentMethods: FormOption[] = [
  { optionGroup: 'paymentMethods', label: 'Medicare' },
  { optionGroup: 'paymentMethods', label: 'Private insurance' },
  { optionGroup: 'paymentMethods', label: 'Cash-pay / out-of-pocket' },
  { optionGroup: 'paymentMethods', label: 'Not sure — please advise' },
];
const defaultAvailabilitySlots: FormOption[] = [
  { optionGroup: 'availabilitySlots', label: 'Weekday mornings', value: 'weekday-am' },
  { optionGroup: 'availabilitySlots', label: 'Weekday afternoons', value: 'weekday-pm' },
  { optionGroup: 'availabilitySlots', label: 'Evenings', value: 'evenings' },
  { optionGroup: 'availabilitySlots', label: 'Weekends', value: 'weekends' },
];

const bookForOpts = optionsByGroup?.bookFor?.length ? optionsByGroup.bookFor : defaultBookFor;
const conditionReasonOpts = optionsByGroup?.conditionReasons?.length
  ? optionsByGroup.conditionReasons
  : defaultConditionReasons;
const paymentMethodOpts = optionsByGroup?.paymentMethods?.length
  ? optionsByGroup.paymentMethods
  : defaultPaymentMethods;
const availabilitySlotOpts = optionsByGroup?.availabilitySlots?.length
  ? optionsByGroup.availabilitySlots
  : defaultAvailabilitySlots;
---

<style is:global>
  /* ─────────────── Form base (matches Contact/Careers) ─────────────── */
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .form-row-3 {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 1rem;
  }
  .form-field-full {
    grid-column: 1/-1;
  }
  .form-field label {
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--navy-deep);
  }
  .form-field label .req {
    color: var(--coral);
    margin-left: 2px;
  }
  .form-field .hint {
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0;
    text-transform: none;
    color: var(--mist);
    margin-top: 2px;
  }
  .form-field input,
  .form-field select,
  .form-field textarea {
    font-family: 'Montserrat', sans-serif;
    font-size: 15px;
    padding: 12px 14px;
    border: 1px solid var(--border);
    border-radius: var(--r-btn);
    background: #fff;
    color: var(--navy-deep);
    transition:
      border-color var(--t-hover),
      box-shadow var(--t-hover);
    width: 100%;
    -webkit-appearance: none;
    appearance: none;
  }
  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: var(--mist);
  }
  .form-field input:focus,
  .form-field select:focus,
  .form-field textarea:focus {
    outline: none;
    border-color: var(--coral);
    box-shadow: 0 0 0 3px rgba(224, 85, 85, 0.12);
  }
  .form-field select {
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8' fill='none' stroke='%235A7194' stroke-width='2' stroke-linecap='round'><path d='M1 1l5 5 5-5'/></svg>");
    background-repeat: no-repeat;
    background-position: right 14px center;
    padding-right: 36px;
  }
  .form-field textarea {
    resize: vertical;
    min-height: 110px;
    line-height: 1.5;
  }

  /* Pill / chip-group selectors */
  .chip-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }
  .chip-group input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 9px 14px;
    border-radius: var(--r-pill);
    border: 1px solid var(--border);
    background: #fff;
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: var(--navy-deep);
    cursor: pointer;
    transition:
      border-color var(--t-hover),
      background-color var(--t-hover),
      color var(--t-hover);
  }
  .chip:hover {
    border-color: var(--coral);
  }
  .chip input:checked + span,
  .chip.is-active {
    color: #fff;
  }
  .chip:has(input:checked) {
    background: var(--coral);
    border-color: var(--coral);
    color: #fff;
  }
  .chip.chip-sage:has(input:checked) {
    background: var(--sage);
    border-color: var(--sage);
  }

  /* Segmented toggle */
  .seg {
    display: inline-flex;
    padding: 4px;
    background: var(--off-white);
    border: 1px solid var(--border);
    border-radius: var(--r-pill);
  }
  .seg label {
    position: relative;
    padding: 8px 16px;
    cursor: pointer;
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: var(--slate);
    border-radius: var(--r-pill);
    transition:
      color var(--t-hover),
      background-color var(--t-hover);
    letter-spacing: 0;
    text-transform: none;
    margin: 0;
  }
  .seg input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .seg label:has(input:checked) {
    background: #fff;
    color: var(--navy-deep);
    box-shadow: var(--shadow-sm);
  }

  /* Consent / fineprint */
  .form-consent {
    display: flex;
    gap: 0.65rem;
    align-items: flex-start;
    font-size: 13px;
    color: var(--slate);
    line-height: 1.55;
    margin: 1.25rem 0 0;
  }
  .form-consent input[type='checkbox'] {
    width: 16px;
    height: 16px;
    margin-top: 3px;
    accent-color: var(--coral);
    flex-shrink: 0;
    -webkit-appearance: auto;
    appearance: auto;
  }
  .form-consent strong {
    color: var(--navy-deep);
  }

  .form-actions {
    margin-top: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: space-between;
  }
  .form-actions .btn {
    padding: 14px 28px;
  }
  .form-fineprint {
    font-size: 12px;
    color: var(--mist);
  }

  /* Crisis callout — sits inside form */
  .crisis-note {
    display: flex;
    gap: 0.7rem;
    align-items: flex-start;
    background: var(--coral-light);
    border: 1px solid rgba(224, 85, 85, 0.25);
    border-radius: var(--r-btn);
    padding: 0.85rem 1rem;
    font-size: 13px;
    color: var(--navy-deep);
    line-height: 1.55;
    margin-bottom: 1.25rem;
  }
  .crisis-note svg {
    width: 18px;
    height: 18px;
    color: var(--coral);
    flex-shrink: 0;
    margin-top: 1px;
  }
  .crisis-note strong {
    color: var(--coral);
  }

  /* Trust strip inside modal header */
  .trust-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    color: var(--slate);
    font-weight: 500;
  }
  .trust-strip span {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .trust-strip svg {
    width: 14px;
    height: 14px;
    color: var(--sage-hover);
  }

  /* Virtual-only note inside Book modal */
  .virtual-only-note {
    display: flex;
    gap: 0.85rem;
    align-items: flex-start;
    background: var(--off-white);
    border: 1px solid var(--border);
    border-radius: var(--r-card);
    padding: 0.95rem 1.1rem;
    font-family: 'Montserrat', sans-serif;
  }
  .virtual-only-note svg {
    width: 22px;
    height: 22px;
    color: var(--coral);
    flex-shrink: 0;
    margin-top: 2px;
  }
  .virtual-only-note strong {
    display: block;
    font-family: 'Manrope', sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: var(--navy-deep);
    letter-spacing: -0.005em;
    margin-bottom: 0.15rem;
  }
  .virtual-only-note span {
    display: block;
    font-size: 13.5px;
    line-height: 1.5;
    color: var(--slate);
  }

  /* ─────────────── Modal (matches Careers) ─────────────── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 300;
    background: rgba(10, 45, 82, 0.55);
    backdrop-filter: blur(4px);
    display: none;
    align-items: flex-start;
    justify-content: center;
    padding: 4rem 1.5rem;
    overflow-y: auto;
  }
  .modal-overlay.open {
    display: flex;
  }
  .modal-panel {
    background: #fff;
    max-width: 760px;
    width: 100%;
    border-radius: var(--r-card);
    box-shadow: 0 24px 64px rgba(10, 45, 82, 0.25);
    overflow: hidden;
    position: relative;
    animation: mpFade 0.25s ease-out;
  }
  @keyframes mpFade {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  .modal-close {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 38px;
    height: 38px;
    border-radius: var(--r-pill);
    background: rgba(255, 255, 255, 0.9);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--navy-deep);
    transition: background-color var(--t-hover);
    z-index: 5;
  }
  .modal-close:hover {
    background: #fff;
  }
  .modal-close svg {
    width: 18px;
    height: 18px;
  }

  .modal-header {
    padding: 2.25rem 2.5rem 1.5rem;
    background: var(--cream);
    border-bottom: 1px solid var(--border);
  }
  .modal-header.header-sage {
    background: var(--sage-light);
  }
  .modal-header.header-sage .eyebrow {
    color: var(--sage-hover);
  }
  .modal-header .eyebrow {
    margin-bottom: 0.85rem;
  }
  .modal-header h3 {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: clamp(1.4rem, 2.2vw, 1.75rem);
    color: var(--navy-deep);
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 0.65rem;
  }
  .modal-header .modal-sub {
    color: var(--slate);
    font-size: 15px;
    line-height: 1.55;
    margin-bottom: 1rem;
    max-width: 560px;
  }

  .modal-body {
    padding: 2rem 2.5rem 2.25rem;
    background: #fff;
  }

  /* Section divider in form */
  .form-section-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--slate);
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin: 1.5rem 0 1rem;
  }
  .form-section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }
  .form-section-label:first-child {
    margin-top: 0;
  }

  /* Success state */
  .form-success {
    text-align: center;
    padding: 2.5rem 1rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
  }
  .form-success-icon {
    width: 64px;
    height: 64px;
    border-radius: var(--r-pill);
    background: var(--sage-light);
    color: var(--sage-hover);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .form-success-icon svg {
    width: 28px;
    height: 28px;
  }
  .form-success h4 {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    color: var(--navy-deep);
    font-size: 1.4rem;
    letter-spacing: -0.01em;
  }
  .form-success p {
    color: var(--slate);
    font-size: 15px;
    line-height: 1.6;
    max-width: 440px;
  }
  .form-success .next-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 1rem;
  }

  /* ─────────────── Refer modal: tab UI ─────────────── */
  .refer-tabs {
    display: flex;
    border-bottom: 2px solid var(--border);
    margin-bottom: 1.75rem;
  }
  .refer-tab {
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 0.7rem 1.25rem;
    margin-bottom: -2px;
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: var(--slate);
    cursor: pointer;
    white-space: nowrap;
    transition:
      color var(--t-hover),
      border-color var(--t-hover);
  }
  .refer-tab:hover {
    color: var(--navy-deep);
  }
  .refer-tab.is-active {
    color: var(--navy-deep);
    border-bottom-color: var(--navy);
  }
  .refer-tab-pane {
    display: none;
  }
  .refer-tab-pane.is-active {
    display: block;
  }

  /* ─────────────── Upload zone (Tab 2) ─────────────── */
  .upload-intro {
    text-align: center;
    margin-bottom: 1.5rem;
  }
  .upload-intro h4 {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 1.2rem;
    color: var(--navy-deep);
    letter-spacing: -0.01em;
    margin-bottom: 0.4rem;
  }
  .upload-intro p {
    color: var(--slate);
    font-size: 14px;
    line-height: 1.55;
  }
  .upload-email-link {
    display: block;
    font-family: 'Manrope', sans-serif;
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--navy-deep);
    text-decoration: none;
    text-align: center;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
    transition: color var(--t-hover);
  }
  .upload-email-link:hover {
    color: var(--coral);
  }
  .upload-divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 1.25rem 0;
    font-size: 13px;
    color: var(--mist);
    font-weight: 500;
  }
  .upload-divider::before,
  .upload-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }
  .upload-zone {
    border: 2px dashed var(--border);
    border-radius: var(--r-card);
    padding: 2rem 1.5rem;
    text-align: center;
    cursor: pointer;
    transition:
      border-color var(--t-hover),
      background-color var(--t-hover);
    position: relative;
    margin-bottom: 1rem;
  }
  .upload-zone:hover,
  .upload-zone.drag-over {
    border-color: var(--navy);
    background: var(--off-white);
  }
  .upload-zone input[type='file'] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }
  .upload-zone-icon {
    width: 40px;
    height: 40px;
    margin: 0 auto 0.75rem;
    color: var(--mist);
  }
  .upload-zone .upload-main {
    font-weight: 600;
    color: var(--navy-deep);
    font-size: 15px;
    margin: 0;
  }
  .upload-zone .upload-sub {
    font-size: 12px;
    color: var(--mist);
    margin: 0.25rem 0 0;
  }
  .upload-file-list {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }
  .upload-file-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--off-white);
    border: 1px solid var(--border);
    border-radius: var(--r-btn);
    padding: 0.5rem 0.75rem;
    font-size: 13px;
    color: var(--navy-deep);
  }
  .upload-file-remove {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--mist);
    padding: 0 0.25rem;
    font-size: 18px;
    line-height: 1;
    transition: color var(--t-hover);
  }
  .upload-file-remove:hover {
    color: var(--coral);
  }
  .upload-fax-note {
    font-size: 12px;
    color: var(--mist);
    text-align: center;
    margin-top: 0.75rem;
  }

  /* ─────────────── Responsive ─────────────── */
  @media (max-width: 768px) {
    .modal-overlay {
      padding: 1rem;
    }
    .modal-header,
    .modal-body {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
    .form-row,
    .form-row-3 {
      grid-template-columns: 1fr;
    }
    .form-actions {
      flex-direction: column;
      align-items: stretch;
    }
    .form-actions .btn {
      width: 100%;
    }
  }
</style>

{/* CMS-SKIP: form field labels and structure */}
<!-- ═════════════════════════════════════════════════
     MODAL 1 — BOOK A SESSION
═════════════════════════════════════════════════ -->
<div
  class="modal-overlay"
  id="modal-book"
  data-form-id={bookId}
  onclick="if(event.target===this) closeModal('book')"
  role="dialog"
  aria-modal="true"
  aria-labelledby="bookTitle"
>
  <div class="modal-panel">
    <button class="modal-close" aria-label="Close" onclick="closeModal('book')">
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.2"
        stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"></path></svg
      >
    </button>

    <div class="modal-header">
      <p class="eyebrow">{bookEyebrow ?? 'Book a Virtual Session'}</p>
      <h3 id="bookTitle">
        {bookHeading ?? 'Get matched with a licensed therapist this week — by video.'}
      </h3>
      <p class="modal-sub">
        <strong>Virtual sessions only.</strong> All Better You Therapy bookings are secure online video
        visits with a Florida-licensed therapist. Our intake team confirms within one business day — usually
        faster.
      </p>
      <div class="trust-strip">
        <span
          ><svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"><path d="M20 6L9 17l-5-5"></path></svg
          >
          {bookValueProps?.[0]?.text ?? 'Florida-licensed therapists'}</span
        >
        <span
          ><svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"><path d="M20 6L9 17l-5-5"></path></svg
          >
          {bookValueProps?.[1]?.text ?? 'Most insurance accepted'}</span
        >
        <span
          ><svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"><path d="M20 6L9 17l-5-5"></path></svg
          >
          {bookValueProps?.[2]?.text ?? 'No waitlist'}</span
        >
      </div>
    </div>

    <div class="modal-body">
      <form id="bookForm" onsubmit="handleSubmit(event,'book')" novalidate>
        <!-- Who is this session for? -->
        <div class="form-section-label">Who's this session for?</div>
        <div class="form-field" style="margin-bottom:1.25rem">
          <div class="seg" role="radiogroup" aria-label="Who's this session for">
            {
              bookForOpts.map((opt, i) => (
                <label>
                  <>
                    <input
                      type="radio"
                      name="bookFor"
                      value={opt.value || opt.label}
                      checked={i === 0}
                    />
                    <span>{opt.label}</span>
                  </>
                </label>
              ))
            }
          </div>
        </div>

        <div class="form-row">
          <div class="form-field">
            <label for="bookFirst">First name <span class="req">*</span></label>
            <input id="bookFirst" name="firstName" type="text" required placeholder="Jane" />
          </div>
          <div class="form-field">
            <label for="bookLast">Last name <span class="req">*</span></label>
            <input id="bookLast" name="lastName" type="text" required placeholder="Doe" />
          </div>
        </div>
        <div class="form-row">
          <div class="form-field">
            <label for="bookEmail">Email <span class="req">*</span></label>
            <input id="bookEmail" name="email" type="email" required placeholder="jane@email.com" />
          </div>
          <div class="form-field">
            <label for="bookPhone">Phone <span class="req">*</span></label>
            <input id="bookPhone" name="phone" type="tel" required placeholder="(555) 555-5555" />
          </div>
        </div>

        <!-- Modality (virtual only) -->
        <div class="form-section-label">How you'll meet</div>
        <div class="form-field virtual-only-note" style="margin-bottom:1.25rem">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><polygon points="23 7 16 12 23 17 23 7"></polygon><rect
              x="1"
              y="5"
              width="15"
              height="14"
              rx="2"
              ry="2"></rect></svg
          >
          <div>
            <strong>Secure video session</strong>
            <span
              >You'll meet your therapist online, from anywhere in Florida. A link will be sent
              before your appointment.</span
            >
          </div>
          <input type="hidden" name="modality" value="tele" />
        </div>

        <!-- Reason -->
        <div class="form-row">
          <div class="form-field">
            <label for="bookReason">What brings you in? <span class="req">*</span></label>
            <select id="bookReason" name="reason" required>
              <option value="" disabled selected>Select what fits best</option>
              {
                conditionReasonOpts.map((opt) => (
                  <option value={opt.value || opt.label}>{opt.label}</option>
                ))
              }
            </select>
          </div>
          <div class="form-field">
            <label for="bookPayment">How will you pay? <span class="req">*</span></label>
            <select id="bookPayment" name="payment" required>
              <option value="" disabled selected>Select an option</option>
              {
                paymentMethodOpts.map((opt) => (
                  <option value={opt.value || opt.label}>{opt.label}</option>
                ))
              }
            </select>
          </div>
        </div>

        <!-- Availability -->
        <div class="form-field">
          <label>Best times to reach you</label>
          <div class="chip-group">
            {
              availabilitySlotOpts.map((opt) => (
                <label class="chip">
                  <>
                    <input type="checkbox" name="avail" value={opt.value || opt.label} />
                    <span>{opt.label}</span>
                  </>
                </label>
              ))
            }
          </div>
        </div>

        <div class="form-field">
          <label for="bookNotes"
            >Anything else we should know? <span
              style="color:var(--mist); font-weight:500; letter-spacing:0; text-transform:none"
              >(optional)</span
            ></label
          >
          <textarea
            id="bookNotes"
            name="notes"
            placeholder="Therapist preference (gender, language, specialty), accessibility needs, or anything that would help us match you well."
          ></textarea>
        </div>

        <label class="form-consent">
          <input type="checkbox" required />
          <span
            >{
              bookConsentText ??
                'I understand this form is not for emergencies and agree to be contacted by Better You Therapy by phone, email, or text.'
            }
            <a href="/privacy/" style="color:var(--coral); text-decoration:underline"
              >Privacy Policy</a
            ></span
          >
        </label>

        <div class="form-actions">
          <span class="form-fineprint"
            >{bookFinePrint ?? 'We respond within one business day.'}</span
          >
          <button type="submit" class="btn btn-coral">
            {bookSubmitLabel ?? 'Request my session'}
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
            >
          </button>
        </div>
      </form>

      <!-- Success -->
      <div class="form-success" id="bookSuccess" style="display:none">
        <div class="form-success-icon">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"><path d="M20 6L9 17l-5-5"></path></svg
          >
        </div>
        <h4>{bookSuccessHeading ?? "You're in good hands."}</h4>
        <p>
          {
            bookSuccessBody ??
              "Thanks — we'll reach out within one business day to match you with a licensed therapist and confirm your first session."
          }
        </p>
        <div class="next-row">
          <button class="btn btn-ghost-ink" onclick="closeModal('book')">Close</button>
        </div>
      </div>
    </div>
  </div>
</div>

{/* CMS-SKIP: form field labels and structure */}
<!-- ═════════════════════════════════════════════════
     MODAL 2 — REFER A RESIDENT
═════════════════════════════════════════════════ -->
<div
  class="modal-overlay"
  id="modal-refer"
  data-form-id={referralId}
  onclick="if(event.target===this) closeModal('refer')"
  role="dialog"
  aria-modal="true"
  aria-labelledby="referTitle"
>
  <div class="modal-panel">
    <button class="modal-close" aria-label="Close" onclick="closeModal('refer')">
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.2"
        stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"></path></svg
      >
    </button>

    <div class="modal-header">
      <p class="eyebrow">{referEyebrow ?? 'Refer a Resident'}</p>
      <h3 id="referTitle">
        {referHeading ?? 'Send us a referral — we handle the rest.'}
      </h3>
      <p class="modal-sub">
        {
          referSubhead ??
            'Fill out the form or email us your documents directly. We handle scheduling, Medicare credentialing, and all documentation — at zero cost to your facility.'
        }
      </p>
    </div>

    <div class="modal-body">
      <!-- Tab bar -->
      <div class="refer-tabs" role="tablist">
        <button
          class="refer-tab is-active"
          role="tab"
          aria-selected="true"
          aria-controls="refTab1"
          onclick="switchReferTab(1)">Fill Out Form</button
        >
        <button
          class="refer-tab"
          role="tab"
          aria-selected="false"
          aria-controls="refTab2"
          onclick="switchReferTab(2)">Upload Referral Documents</button
        >
      </div>

      <!-- TAB 1 — FILL OUT FORM -->
      <div class="refer-tab-pane is-active" id="refTab1" role="tabpanel">
        <form id="referForm" onsubmit="handleSubmit(event,'refer')" novalidate>
          <div class="form-field">
            <label for="refFacility">Facility Name <span class="req">*</span></label>
            <input
              id="refFacility"
              name="facilityName"
              type="text"
              required
              placeholder="Sunrise Senior Living of Boca Raton"
            />
          </div>
          <div class="form-field">
            <label for="refFacPhone">Facility Telephone Number <span class="req">*</span></label>
            <input
              id="refFacPhone"
              name="facilityPhone"
              type="tel"
              required
              placeholder="(555) 555-5555"
            />
          </div>
          <div class="form-row">
            <div class="form-field">
              <label for="refRefName">Referring Person's Name <span class="req">*</span></label>
              <input
                id="refRefName"
                name="referringName"
                type="text"
                required
                placeholder="Maria Hernandez"
              />
            </div>
            <div class="form-field">
              <label for="refRefEmail">Referring Person's Email <span class="req">*</span></label>
              <input
                id="refRefEmail"
                name="referringEmail"
                type="email"
                required
                placeholder="maria@facility.com"
              />
            </div>
          </div>
          <div class="form-field">
            <label for="refPatientName">Patient's Name <span class="req">*</span></label>
            <input
              id="refPatientName"
              name="patientName"
              type="text"
              required
              placeholder="First and last name"
            />
          </div>
          <div class="form-field">
            <label for="refPOA"
              >POA, Guardian or Healthcare Surrogate &mdash; Name &amp; Phone</label
            >
            <input id="refPOA" name="poaContact" type="text" placeholder="Name and phone number" />
            <span class="hint">If applicable</span>
          </div>
          <div class="form-field">
            <label for="refReason">Reason for Referral <span class="req">*</span></label>
            <textarea
              id="refReason"
              name="referralReason"
              rows="3"
              style="min-height:90px"
              required
              placeholder="Describe the patient's presenting concerns and reason for referral…"
            ></textarea>
          </div>
          <div class="form-field">
            <label>Currently on Skilled Nursing? <span class="req">*</span></label>
            <div class="seg" role="radiogroup" aria-label="Currently on Skilled Nursing">
              <label
                ><input type="radio" name="skilledNursing" value="yes" required /><span>Yes</span
                ></label
              >
              <label
                ><input type="radio" name="skilledNursing" value="no" required /><span>No</span
                ></label
              >
            </div>
          </div>

          {/* CMS-SKIP: regulatory consent text */}
          <label class="form-consent">
            <input type="checkbox" required />
            <span
              >I consent to receive SMS communications from Better You Therapy regarding this
              referral.</span
            >
          </label>
          {/* CMS-SKIP: regulatory consent text */}
          <label class="form-consent">
            <input type="checkbox" required />
            <span
              >I confirm I am authorized to submit this referral and that sharing this patient's
              information complies with applicable HIPAA requirements.</span
            >
          </label>

          <div class="form-actions" style="justify-content:flex-end">
            <button type="submit" class="btn btn-coral">
              {referSubmitLabel ?? 'Send Referral'}
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
              >
            </button>
          </div>
        </form>

        <div class="form-success" id="referSuccess" style="display:none">
          <div class="form-success-icon">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"><path d="M20 6L9 17l-5-5"></path></svg
            >
          </div>
          <h4>{referSuccessHeading ?? 'Referral received.'}</h4>
          <p>
            {
              referSuccessBody ??
                "We'll reach out to you within one business day to confirm receipt and next steps."
            }
          </p>
          <div class="next-row">
            <button class="btn btn-ghost-ink" onclick="closeModal('refer')">Close</button>
          </div>
        </div>
      </div>

      <!-- TAB 2 — UPLOAD REFERRAL DOCUMENTS -->
      <div class="refer-tab-pane" id="refTab2" role="tabpanel">
        <form id="referUploadForm" onsubmit="handleUploadSubmit(event)" novalidate>
          <div class="upload-intro">
            <h4>Send Us Your Referral Documents</h4>
            <p>
              Email your completed referral form, face sheet, and insurance cards directly to us.
            </p>
          </div>

          <a href={`mailto:${email}`} class="upload-email-link">{email}</a>

          <div class="upload-divider">or</div>

          <div class="upload-zone" id="uploadZone">
            <input
              type="file"
              id="refFiles"
              name="referralDocuments"
              accept=".pdf,.doc,.docx,.jpg,.jpeg,.png"
              multiple
            />
            <div class="upload-zone-icon">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="16 16 12 12 8 16"></polyline><line
                  x1="12"
                  y1="12"
                  x2="12"
                  y2="21"></line><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"
                ></path></svg
              >
            </div>
            <p class="upload-main">Drag files here or click to browse</p>
            <p class="upload-sub">PDF, Word, JPG, PNG — up to 10MB per file</p>
          </div>

          <div class="upload-file-list" id="uploadFileList"></div>

          <div class="form-row">
            <div class="form-field">
              <label for="upRefName">Referring Person's Name <span class="req">*</span></label>
              <input
                id="upRefName"
                name="referringName"
                type="text"
                required
                placeholder="Maria Hernandez"
              />
            </div>
            <div class="form-field">
              <label for="upRefEmail">Referring Person's Email <span class="req">*</span></label>
              <input
                id="upRefEmail"
                name="referringEmail"
                type="email"
                required
                placeholder="maria@facility.com"
              />
            </div>
          </div>

          <div class="form-actions" style="justify-content:flex-end">
            <button type="submit" class="btn btn-coral">
              Send Documents
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
              >
            </button>
          </div>
        </form>

        <p class="upload-fax-note">
          You can also fax referral documents to <strong>{referFaxNumber ?? '754-328-4344'}</strong>
        </p>

        <div class="form-success" id="referUploadSuccess" style="display:none">
          <div class="form-success-icon">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"><path d="M20 6L9 17l-5-5"></path></svg
            >
          </div>
          <h4>Documents received.</h4>
          <p>
            We'll reach out to the email you provided within one business day to confirm receipt.
          </p>
          <div class="next-row">
            <button class="btn btn-ghost-ink" onclick="closeModal('refer')">Close</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  /* eslint-disable @typescript-eslint/no-unused-vars */
  function openModal(which) {
    const m = document.getElementById('modal-' + which);
    if (!m) return;
    m.classList.add('open');
    document.body.style.overflow = 'hidden';
    setTimeout(function () {
      const f = m.querySelector(
        'input:not([type="hidden"]):not([type="checkbox"]):not([type="radio"]), select',
      );
      if (f) f.focus();
    }, 100);
  }
  function closeModal(which) {
    const m = document.getElementById('modal-' + which);
    if (!m) return;
    m.classList.remove('open');
    document.body.style.overflow = '';
  }
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      document.querySelectorAll('.modal-overlay.open').forEach(function (m) {
        m.classList.remove('open');
      });
      document.body.style.overflow = '';
    }
  });

  function switchReferTab(n) {
    const modal = document.getElementById('modal-refer');
    if (!modal) return;
    modal.querySelectorAll('.refer-tab').forEach(function (t, i) {
      const active = i + 1 === n;
      t.classList.toggle('is-active', active);
      t.setAttribute('aria-selected', String(active));
    });
    modal.querySelectorAll('.refer-tab-pane').forEach(function (p, i) {
      p.classList.toggle('is-active', i + 1 === n);
    });
  }

  async function handleSubmit(e, which) {
    e.preventDefault();
    const form = e.target;
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    const overlay = document.getElementById('modal-' + which);
    const formId = overlay ? overlay.dataset.formId : '';
    const btn = form.querySelector('[type="submit"]');
    const orig = btn.innerHTML;
    btn.disabled = true;
    btn.textContent = 'Sending…';
    try {
      const res = await fetch('https://formspree.io/f/' + formId, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });
      if (res.ok) {
        form.style.display = 'none';
        document.getElementById(which + 'Success').style.display = 'flex';
      } else {
        btn.disabled = false;
        btn.innerHTML = orig;
        alert('Something went wrong. Please try again or call us directly.');
      }
    } catch (err) {
      void err;
      btn.disabled = false;
      btn.innerHTML = orig;
      alert('Unable to submit. Please check your connection and try again.');
    }
  }

  async function handleUploadSubmit(e) {
    e.preventDefault();
    const form = e.target;
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    const overlay = document.getElementById('modal-refer');
    const formId = overlay ? overlay.dataset.formId : '';
    const btn = form.querySelector('[type="submit"]');
    const orig = btn.innerHTML;
    btn.disabled = true;
    btn.textContent = 'Sending…';
    try {
      const res = await fetch('https://formspree.io/f/' + formId, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });
      if (res.ok) {
        form.style.display = 'none';
        document.getElementById('referUploadSuccess').style.display = 'flex';
      } else {
        btn.disabled = false;
        btn.innerHTML = orig;
        alert('Something went wrong. Please try again or call us directly.');
      }
    } catch (err) {
      void err;
      btn.disabled = false;
      btn.innerHTML = orig;
      alert('Unable to submit. Please check your connection and try again.');
    }
  }

  function resetReferForm() {
    const form = document.getElementById('referForm');
    const upForm = document.getElementById('referUploadForm');
    if (form) {
      form.reset();
      form.style.display = 'block';
    }
    if (upForm) {
      upForm.reset();
      upForm.style.display = 'block';
    }
    const fl = document.getElementById('uploadFileList');
    if (fl) fl.innerHTML = '';
    const s1 = document.getElementById('referSuccess');
    const s2 = document.getElementById('referUploadSuccess');
    if (s1) s1.style.display = 'none';
    if (s2) s2.style.display = 'none';
    switchReferTab(1);
  }

  // File upload UI
  (function () {
    const fileInput = document.getElementById('refFiles');
    const uploadZone = document.getElementById('uploadZone');
    if (!fileInput || !uploadZone) return;

    fileInput.addEventListener('change', renderFileList);

    uploadZone.addEventListener('dragover', function (e) {
      e.preventDefault();
      uploadZone.classList.add('drag-over');
    });
    uploadZone.addEventListener('dragleave', function () {
      uploadZone.classList.remove('drag-over');
    });
    uploadZone.addEventListener('drop', function (e) {
      e.preventDefault();
      uploadZone.classList.remove('drag-over');
      const dt = new DataTransfer();
      Array.from(fileInput.files).forEach(function (f) {
        dt.items.add(f);
      });
      Array.from(e.dataTransfer.files).forEach(function (f) {
        dt.items.add(f);
      });
      fileInput.files = dt.files;
      renderFileList();
    });

    function renderFileList() {
      const list = document.getElementById('uploadFileList');
      if (!list) return;
      list.innerHTML = '';
      Array.from(fileInput.files).forEach(function (file, idx) {
        const item = document.createElement('div');
        item.className = 'upload-file-item';
        const name = document.createElement('span');
        name.textContent = file.name;
        const rm = document.createElement('button');
        rm.type = 'button';
        rm.className = 'upload-file-remove';
        rm.setAttribute('aria-label', 'Remove ' + file.name);
        rm.textContent = '\xD7';
        rm.addEventListener('click', function () {
          removeFile(idx);
        });
        item.appendChild(name);
        item.appendChild(rm);
        list.appendChild(item);
      });
    }

    function removeFile(idx) {
      const dt = new DataTransfer();
      Array.from(fileInput.files).forEach(function (f, i) {
        if (i !== idx) dt.items.add(f);
      });
      fileInput.files = dt.files;
      renderFileList();
    }
  })();
</script>
