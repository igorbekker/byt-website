---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb">
  <ol itemscope itemtype="https://schema.org/BreadcrumbList" class="breadcrumb-list">
    {
      items.map((item, index) => {
        const position = index + 1;
        const isCurrent = index === items.length - 1;
        return (
          <li
            itemprop="itemListElement"
            itemscope
            itemtype="https://schema.org/ListItem"
            class="breadcrumb-item"
          >
            {isCurrent ? (
              <span itemprop="name" aria-current="page" class="breadcrumb-current">
                {item.label}
              </span>
            ) : (
              <a itemprop="item" href={item.href} class="breadcrumb-link">
                <span itemprop="name">{item.label}</span>
              </a>
            )}
            <meta itemprop="position" content={String(position)} />
          </li>
        );
      })
    }
  </ol>
</nav>

<style>
  .breadcrumb-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0.75rem 5%;
    font-size: 0.8125rem;
    color: var(--slate, #5a7194);
    border-bottom: 1px solid var(--border, #e4eaf0);
    background: var(--off-white, #f8f9fb);
  }

  .breadcrumb-item {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .breadcrumb-item + .breadcrumb-item::before {
    content: '/';
    color: var(--mist, #8fa3bf);
    user-select: none;
  }

  .breadcrumb-link {
    color: var(--navy, #104378);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .breadcrumb-link:hover {
    color: var(--coral, #e05555);
    text-decoration: underline;
  }

  .breadcrumb-current {
    color: var(--slate, #5a7194);
    font-weight: 500;
  }
</style>
