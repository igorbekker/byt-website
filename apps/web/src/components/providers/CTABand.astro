---
/**
 * Purpose: Full-width navy CTA band for the bottom of the providers page
 * Context: Block 7 on Providers page — final conversion section
 * Source: design-source/styles/providers.css (.p-cta, .p-cta-inner)
 */

interface Props {
  title?: string;
  description?: string;
  ctaLabel?: string;
  ctaHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  title = 'Ready to Join the BYT Network?',
  description = 'Facility-based and teletherapy positions available now. Transparent split. We handle sourcing — you handle care.',
  ctaLabel = 'Apply Today',
  ctaHref = '/providers/apply/',
  secondaryLabel = 'Ask a Question',
  secondaryHref = '/contact/',
} = Astro.props;
---

<section class="p-cta">
  <div class="p-cta-inner fade-up">
    <h2>{title}</h2>
    <p>{description}</p>
    <div class="p-cta-actions">
      <a href={ctaHref} class="btn btn-spec-blue">{ctaLabel} &rarr;</a>
      {
        secondaryLabel && (
          <a href={secondaryHref} class="btn btn-outline-white">
            {secondaryLabel}
          </a>
        )
      }
    </div>
  </div>
</section>

<style>
  .p-cta {
    background: var(--navy);
    padding: 80px var(--pad-x);
    text-align: center;
    color: #fff;
  }

  .p-cta-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .p-cta h2 {
    color: #fff;
    font-size: clamp(2rem, 3.5vw, 2.6rem);
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
    text-wrap: balance;
  }

  .p-cta p {
    color: rgba(255, 255, 255, 0.78);
    font-size: 17px;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .p-cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .p-cta .btn-spec-blue {
    font-size: 16px;
    padding: 16px 32px;
  }

  @media (max-width: 720px) {
    .p-cta {
      padding: 64px var(--pad-x);
    }
  }
</style>
