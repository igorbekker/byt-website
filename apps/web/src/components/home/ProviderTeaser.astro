---
/**
 * Purpose: Full-bleed dark section recruiting licensed therapists, with photo background overlay
 * Context: Block 8 on Homepage — navy-deep background with blurred photo and centered content
 * Source: design-source/pages/Homepage.html (.provider, .provider-bg, .provider-overlay, .provider-inner, .provider-tags, .provider-actions)
 */

interface CtaLink {
  label: string;
  href: string;
  variant?: string;
}

interface ImageWithAlt {
  asset?: { url: string };
  alt?: string;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  body?: string;
  image?: ImageWithAlt;
  primaryCta?: CtaLink;
  secondaryCta?: CtaLink;
}

const { eyebrow, heading, body, image, primaryCta, secondaryCta } = Astro.props;

const primaryVariant = primaryCta?.variant ?? 'btn-coral';
const secondaryVariant = secondaryCta?.variant ?? 'btn-outline-white';

const bgStyle = image?.asset?.url ? `background-image:url('${image.asset.url}');` : '';
---

<section class="provider">
  <div class="provider-bg" style={bgStyle}></div>
  <div class="provider-overlay"></div>
  <div class="provider-inner fade-up">
    {
      eyebrow && (
        <p class="eyebrow" style="margin-bottom:1rem;color:rgba(255,255,255,.75)">
          {eyebrow}
        </p>
      )
    }
    {heading && <h2>{heading}</h2>}
    {body && <p>{body}</p>}
    <div class="provider-actions">
      {
        primaryCta?.label && primaryCta.href && (
          <a href={primaryCta.href} class={`btn ${primaryVariant}`}>
            {primaryCta.label}
          </a>
        )
      }
      {
        secondaryCta?.label && secondaryCta.href && (
          <a href={secondaryCta.href} class={`btn ${secondaryVariant}`}>
            {secondaryCta.label}
          </a>
        )
      }
    </div>
  </div>
</section>

<style>
  .provider {
    background: var(--navy-deep);
    padding: var(--pad-s) var(--pad-x);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .provider-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0.28;
  }

  .provider-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(10, 45, 82, 0.88) 0%, rgba(16, 67, 120, 0.82) 100%);
  }

  .provider-inner {
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .provider .eyebrow {
    color: rgba(255, 255, 255, 0.72);
    margin-bottom: 1rem;
  }

  .provider h2 {
    color: var(--white);
    margin-bottom: 1rem;
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    letter-spacing: -0.02em;
  }

  .provider p {
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.65;
    margin-bottom: 2rem;
    font-size: 17px;
  }

  .provider-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .provider-actions {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
