---
/**
 * Purpose: Full-bleed dark section recruiting licensed therapists, with photo background overlay
 * Context: Block 8 on Homepage — navy-deep background with blurred photo and centered content
 * Source: design-source/pages/Homepage.html (.provider, .provider-bg, .provider-overlay, .provider-inner, .provider-tags, .provider-actions)
 */
---

<section class="provider">
  <div
    class="provider-bg"
    style="background-image:url('https://images.unsplash.com/photo-1582750433449-648ed127bb54?w=1600&q=80&auto=format&fit=crop');"
  >
  </div>
  <div class="provider-overlay"></div>
  <div class="provider-inner fade-up">
    <p class="eyebrow" style="margin-bottom:1rem;color:rgba(255,255,255,.75)">Join the Team</p>
    <h2>Are You a Licensed Therapist in Florida?</h2>
    <p>
      Facility-based positions in Southeast Florida and teletherapy positions statewide. Transparent
      revenue split from day one. We source the patients &mdash; you deliver the clinical care.
    </p>
    <div class="provider-tags">
      <span class="provider-tag">Psychologists</span>
      <span class="provider-tag">LCSWs</span>
      <span class="provider-tag">LMHCs</span>
      <span class="provider-tag">LPCs</span>
      <span class="provider-tag">LMFTs</span>
      <span class="provider-tag">Facility-based</span>
      <span class="provider-tag">Teletherapy</span>
    </div>
    <div class="provider-actions">
      <a href="/providers/" class="btn btn-coral">See Open Positions &rarr;</a>
      <a href="/providers/" class="btn btn-outline-white">Learn More</a>
    </div>
  </div>
</section>

<style>
  .provider {
    background: var(--navy-deep);
    padding: var(--pad-s) var(--pad-x);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .provider-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0.28;
  }

  .provider-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(10, 45, 82, 0.88) 0%, rgba(16, 67, 120, 0.82) 100%);
  }

  .provider-inner {
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .provider .eyebrow {
    color: rgba(255, 255, 255, 0.72);
    margin-bottom: 1rem;
  }

  .provider h2 {
    color: #fff;
    margin-bottom: 1rem;
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    letter-spacing: -0.02em;
  }

  .provider p {
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.65;
    margin-bottom: 2rem;
    font-size: 17px;
  }

  .provider-tags {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2.25rem;
  }

  .provider-tag {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    padding: 0.45rem 1rem;
    border-radius: var(--r-pill);
    font-size: 13px;
    font-weight: 500;
    border: 1px solid rgba(255, 255, 255, 0.18);
    letter-spacing: 0.01em;
  }

  .provider-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .provider-actions {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
