---
/**
 * Purpose: Two-track step-by-step layout showing how to get started via teletherapy or in-facility
 * Context: Block 6 on Homepage — cream background with white track cards
 * Source: design-source/pages/Homepage.html (.howitworks, .howitworks-grid, .howitworks-track, .step, .step-num, .step-text, .track-cta)
 */

interface CtaLink {
  label: string;
  href: string;
  variant?: string;
}

interface ProcessStep {
  stepNumber: string;
  heading: string;
  body?: string;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  teletherapyTrackLabel?: string;
  teletherapySteps?: ProcessStep[];
  teletherapyCta?: CtaLink;
  facilityTrackLabel?: string;
  facilitySteps?: ProcessStep[];
  facilityCta?: CtaLink;
}

const {
  eyebrow,
  heading,
  teletherapyTrackLabel,
  teletherapySteps,
  teletherapyCta,
  facilityTrackLabel,
  facilitySteps,
  facilityCta,
} = Astro.props;

const teleCtaVariant = teletherapyCta?.variant ?? 'btn-sage';
const facilityCtaVariant = facilityCta?.variant ?? 'btn-coral';
---

<section class="howitworks">
  <div style="max-width:var(--max-w);margin:0 auto;">
    <div class="howitworks-header fade-up">
      {
        eyebrow && (
          <p class="eyebrow" style="margin-bottom:.75rem">
            {eyebrow}
          </p>
        )
      }
      {heading && <h2>{heading}</h2>}
    </div>

    <div class="howitworks-grid fade-up">
      <div class="howitworks-track howitworks-track-tele">
        {teletherapyTrackLabel && <div class="howitworks-track-label">{teletherapyTrackLabel}</div>}
        <div class="steps-wrap">
          {
            teletherapySteps?.map((step) => (
              <div class="step">
                <div class="step-num tele-num">{step.stepNumber}</div>
                <div class="step-text">
                  <h4>{step.heading}</h4>
                  {step.body && <p>{step.body}</p>}
                </div>
              </div>
            ))
          }
        </div>
        {
          teletherapyCta?.label && teletherapyCta.href && (
            <div class="track-cta">
              <a href={teletherapyCta.href} class={`btn ${teleCtaVariant}`}>
                {teletherapyCta.label}
              </a>
            </div>
          )
        }
      </div>

      <div class="howitworks-track howitworks-track-facility">
        {facilityTrackLabel && <div class="howitworks-track-label">{facilityTrackLabel}</div>}
        <div class="steps-wrap">
          {
            facilitySteps?.map((step) => (
              <div class="step">
                <div class="step-num facility-num">{step.stepNumber}</div>
                <div class="step-text">
                  <h4>{step.heading}</h4>
                  {step.body && <p>{step.body}</p>}
                </div>
              </div>
            ))
          }
        </div>
        {
          facilityCta?.label && facilityCta.href && (
            <div class="track-cta">
              <a href={facilityCta.href} class={`btn ${facilityCtaVariant}`}>
                {facilityCta.label}
              </a>
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  .howitworks {
    background: var(--cream);
    padding: var(--pad-s) var(--pad-x);
    border-top: 1px solid var(--border);
  }

  .howitworks-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }
  .howitworks-header .eyebrow {
    margin-bottom: 1rem;
  }
  .howitworks-header h2 {
    color: var(--navy-deep);
    margin-bottom: 1rem;
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    letter-spacing: -0.02em;
  }

  .howitworks-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .howitworks-track {
    display: flex;
    flex-direction: column;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--r-card);
    padding: 2.25rem 2rem;
    box-shadow: var(--shadow-sm);
    transition:
      box-shadow var(--t-hover),
      border-color var(--t-hover);
  }
  .howitworks-track:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--coral);
  }

  .howitworks-track .steps-wrap {
    flex: 1;
  }
  .howitworks-track .track-cta {
    margin-top: 1.75rem;
    text-align: center;
  }

  .tele-num {
    background: var(--sage);
    color: var(--white);
  }
  .facility-num {
    background: var(--coral);
    color: var(--white);
  }

  .howitworks-track-label {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 1.75rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .howitworks-track-tele .howitworks-track-label {
    color: var(--sage-hover);
  }
  .howitworks-track-facility .howitworks-track-label {
    color: var(--coral);
  }
  .howitworks-track-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: currentColor;
    opacity: 0.25;
  }

  .step {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.4rem;
    align-items: flex-start;
  }
  .step:last-child {
    margin-bottom: 0;
  }

  .step-num {
    width: 32px;
    height: 32px;
    border-radius: var(--r-pill);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 0.85rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .step-text h4 {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 800;
    color: var(--navy-deep);
    margin-bottom: 0.3rem;
    letter-spacing: -0.01em;
  }
  .step-text p {
    font-size: 14px;
    color: var(--slate);
    line-height: 1.6;
  }

  @media (max-width: 1024px) {
    .howitworks-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
