---
/**
 * Purpose: Two-track step-by-step layout showing how to get started via teletherapy or in-facility
 * Context: Block 6 on Homepage — cream background with white track cards
 * Source: design-source/pages/Homepage.html (.howitworks, .howitworks-grid, .howitworks-track, .step, .step-num, .step-text, .track-cta)
 */
---

<section class="howitworks">
  <div style="max-width:var(--max-w);margin:0 auto;">
    <div class="howitworks-header fade-up">
      <p class="eyebrow" style="margin-bottom:.75rem">The Process</p>
      <h2>Getting Started Is Simple &mdash; Either Way</h2>
    </div>

    <div class="howitworks-grid fade-up">
      <div class="howitworks-track howitworks-track-tele">
        <div class="howitworks-track-label">Online Therapy Track</div>
        <div class="steps-wrap">
          <div class="step">
            <div class="step-num tele-num">1</div>
            <div class="step-text">
              <h4>Tell Us What You're Looking For</h4>
              <p>
                A short intake &mdash; your needs, availability, and preferences. Under 5 minutes.
              </p>
            </div>
          </div>
          <div class="step">
            <div class="step-num tele-num">2</div>
            <div class="step-text">
              <h4>We Match You With a Licensed Therapist</h4>
              <p>We handle the matching. You get a therapist suited to your specific needs.</p>
            </div>
          </div>
          <div class="step">
            <div class="step-num tele-num">3</div>
            <div class="step-text">
              <h4>Your First Session Is Available This Week</h4>
              <p>No waitlist. Secure video sessions on your schedule.</p>
            </div>
          </div>
        </div>
        <div class="track-cta">
          <a href="/individual-therapy/" class="btn btn-sage">Book a Session &rarr;</a>
        </div>
      </div>

      <div class="howitworks-track howitworks-track-facility">
        <div class="howitworks-track-label">In-Facility Track</div>
        <div class="steps-wrap">
          <div class="step">
            <div class="step-num facility-num">1</div>
            <div class="step-text">
              <h4>You Refer a Resident</h4>
              <p>
                A simple referral form. We take it from there &mdash; no paperwork burden for your
                team.
              </p>
            </div>
          </div>
          <div class="step">
            <div class="step-num facility-num">2</div>
            <div class="step-text">
              <h4>We Handle Scheduling and Medicare Billing</h4>
              <p>Consent, credentialing, billing to Medicare Part B. All handled by BYT.</p>
            </div>
          </div>
          <div class="step">
            <div class="step-num facility-num">3</div>
            <div class="step-text">
              <h4>Your Therapist Arrives On-Site, Weekly</h4>
              <p>
                Your residents receive care in their own room. Weekly visits. Zero cost to the
                facility.
              </p>
            </div>
          </div>
        </div>
        <div class="track-cta">
          <a href="/referral/" class="btn btn-coral">Refer a Resident &rarr;</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .howitworks {
    background: var(--cream);
    padding: var(--pad-s) var(--pad-x);
    border-top: 1px solid var(--border);
  }

  .howitworks-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }
  .howitworks-header .eyebrow {
    margin-bottom: 1rem;
  }
  .howitworks-header h2 {
    color: var(--navy-deep);
    margin-bottom: 1rem;
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    letter-spacing: -0.02em;
  }

  .howitworks-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .howitworks-track {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--r-card);
    padding: 2.25rem 2rem;
    box-shadow: var(--shadow-sm);
    transition:
      box-shadow var(--t-hover),
      border-color var(--t-hover);
  }
  .howitworks-track:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--coral);
  }

  .howitworks-track .steps-wrap {
    flex: 1;
  }
  .howitworks-track .track-cta {
    margin-top: 1.75rem;
    text-align: center;
  }

  .tele-num {
    background: var(--sage);
    color: #fff;
  }
  .facility-num {
    background: var(--coral);
    color: #fff;
  }

  .howitworks-track-label {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 1.75rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .howitworks-track-tele .howitworks-track-label {
    color: var(--sage-hover);
  }
  .howitworks-track-facility .howitworks-track-label {
    color: var(--coral);
  }
  .howitworks-track-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: currentColor;
    opacity: 0.25;
  }

  .step {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.4rem;
    align-items: flex-start;
  }
  .step:last-child {
    margin-bottom: 0;
  }

  .step-num {
    width: 32px;
    height: 32px;
    border-radius: var(--r-pill);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 0.85rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .step-text h4 {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 800;
    color: var(--navy-deep);
    margin-bottom: 0.3rem;
    letter-spacing: -0.01em;
  }
  .step-text p {
    font-size: 14px;
    color: var(--slate);
    line-height: 1.6;
  }

  @media (max-width: 1024px) {
    .howitworks-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
