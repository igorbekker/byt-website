---
/**
 * Purpose: Sticky-scroll layout showing conditions BYT treats — left content scrolls, right image fades between sections
 * Context: Block 5 on Homepage — alternating white/off-white rows, sticky image panel on right
 * Source: design-source/pages/Homepage.html (.l349, .l349-left, .l349-section, .l349-right, .l349-img-wrap, .l349-img)
 */

interface ImageWithAlt {
  asset?: { url: string };
  alt?: string;
}

interface Condition {
  _id: string;
  tagline: string;
  heading: string;
  body?: string;
  image?: ImageWithAlt;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  subhead?: string;
  conditions?: Condition[];
}

const { eyebrow, heading, subhead, conditions } = Astro.props;

// Fallback booking/referral links — these are internal navigation, not editable copy
const BOOK_URL = '/individual-therapy/';
const REFER_URL = '/referral/';
---

<div class="l349-section-header fade-up">
  {
    eyebrow && (
      <p class="eyebrow" style="margin-bottom:.75rem">
        {eyebrow}
      </p>
    )
  }
  {heading && <h2>{heading}</h2>}
  {subhead && <p>{subhead}</p>}
</div>

{
  conditions && conditions.length > 0 && (
    <section class="l349" id="l349">
      <div class="l349-left">
        {conditions.map((condition, idx) => (
          <div class="l349-section" data-section={idx}>
            {condition.tagline && <p class="l349-tagline">{condition.tagline}</p>}
            {condition.heading && <h2 class="l349-h2">{condition.heading}</h2>}
            {condition.body && <p class="l349-body">{condition.body}</p>}
            <div class="l349-actions">
              <a href={BOOK_URL} class="l349-btn-outline">
                Book a session
              </a>
              <a href={REFER_URL} class="l349-btn-ghost">
                Refer a resident
                <svg
                  width="15"
                  height="15"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                >
                  <path d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>

      <div class="l349-right">
        <div class="l349-img-wrap" id="l349Images">
          {conditions.map((condition, idx) => (
            <div
              class={`l349-img${idx === 0 ? ' active' : ''}`}
              data-img={idx}
              style={
                condition.image?.asset?.url
                  ? `background:url('${condition.image.asset.url}') center/cover;`
                  : 'background:var(--off-white);'
              }
              role="img"
              aria-label={condition.image?.alt ?? condition.heading}
            />
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  .l349-section-header {
    text-align: center;
    padding: 2.5rem var(--pad-x) 2rem;
    background: var(--white);
  }
  .l349-section-header .eyebrow {
    margin-bottom: 1rem;
  }
  .l349-section-header h2 {
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    color: var(--navy-deep);
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }
  .l349-section-header p {
    color: var(--slate);
    max-width: 560px;
    margin: 0 auto;
    font-size: 17px;
    line-height: 1.6;
  }

  .l349 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
  }

  .l349-left {
    display: flex;
    flex-direction: column;
  }

  .l349-section {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px clamp(3rem, 6vw, 6rem) 80px var(--pad-x);
  }
  .l349-section:nth-child(odd) {
    background: var(--white);
  }
  .l349-section:nth-child(even) {
    background: var(--off-white);
  }

  .l349-tagline {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--coral);
    margin-bottom: 1rem;
  }

  .l349-h2 {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    color: var(--navy-deep);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 800;
    margin-bottom: 1.25rem;
  }

  .l349-body {
    font-size: 17px;
    color: var(--slate);
    line-height: 1.65;
    margin-bottom: 2rem;
    max-width: 460px;
  }

  .l349-actions {
    display: flex;
    gap: 20px;
    align-items: center;
    flex-wrap: wrap;
  }

  .l349-btn-outline {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    color: var(--navy-deep);
    border: 1.5px solid var(--navy-deep);
    padding: 12px 22px;
    border-radius: var(--r-btn);
    text-decoration: none;
    letter-spacing: 0.01em;
    transition:
      background-color var(--t-hover),
      color var(--t-hover);
  }
  .l349-btn-outline:hover {
    background: var(--navy-deep);
    color: var(--white);
  }

  .l349-btn-ghost {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    color: var(--coral);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: color var(--t-hover);
  }
  .l349-btn-ghost:hover {
    color: var(--coral-hover);
  }
  .l349-btn-ghost svg {
    transition: transform var(--t-hover);
  }
  .l349-btn-ghost:hover svg {
    transform: translateX(3px);
  }

  .l349-right {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0;
    background: var(--off-white);
    overflow: hidden;
  }

  .l349-img-wrap {
    position: relative;
    width: 100%;
    height: 100%;
    max-width: none;
  }

  .l349-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border-radius: 0;
    opacity: 0;
    transition: opacity 0.4s ease;
    box-shadow: none;
    background-size: cover;
    background-position: center;
  }
  .l349-img.active {
    opacity: 1;
  }

  @media (max-width: 1024px) {
    .l349 {
      grid-template-columns: 1fr;
    }
    .l349-right {
      display: none;
    }
    .l349-section {
      min-height: auto;
      padding: 72px var(--pad-x);
    }
  }

  @media (max-width: 768px) {
    .l349-section {
      padding: 56px var(--pad-x);
    }
  }
</style>

<script>
  const l349Imgs = document.querySelectorAll<HTMLElement>('[data-img]');

  function updateConditionImage(): void {
    const vh = window.innerHeight;
    const l349 = document.getElementById('l349');
    if (!l349) return;

    const rect = l349.getBoundingClientRect();
    const scrolledInto = -rect.top;
    if (scrolledInto < 0) return;

    const active = Math.min(Math.floor(scrolledInto / vh), l349Imgs.length - 1);
    l349Imgs.forEach((img, i) => {
      img.style.opacity = i === active ? '1' : '0';
      img.classList.toggle('active', i === active);
    });
  }

  l349Imgs.forEach((img, i) => {
    img.style.transition = 'opacity 0.35s ease';
    if (i > 0) img.style.opacity = '0';
  });

  window.addEventListener('scroll', updateConditionImage, { passive: true });
  updateConditionImage();
</script>
