---
/**
 * Purpose: Interactive accordion-style cards letting users self-select their audience path
 * Context: Block 2 on Homepage — navy background, three expanding audience cards
 * Source: design-source/pages/Homepage.html (.router-section, .router-row, .r-card, .r-card-wide, .r-card-narrow, .r-wide-content, .r-wide-image, .r-narrow-content, .r-tagline, .r-heading, .r-body, .r-icon, .r-cta)
 */

interface CtaLink {
  label: string;
  href: string;
  variant?: string;
}

interface ImageWithAlt {
  asset?: { url: string };
  alt?: string;
}

interface AudienceCard {
  tagline: string;
  heading: string;
  bodyCollapsed: string;
  bodyExpanded: string;
  image?: ImageWithAlt;
  cta?: CtaLink;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  subhead?: string;
  cards?: AudienceCard[];
}

const { eyebrow, heading, subhead, cards } = Astro.props;

// Arrow SVG shared across CTAs
const arrowSvg = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>`;
---

<section class="router-section">
  <div class="router-header fade-up">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    {heading && <h2>{heading}</h2>}
    {subhead && <p>{subhead}</p>}
  </div>

  {
    cards && cards.length > 0 && (
      <div class="router-row" id="routerRow">
        {cards.map((card, idx) => (
          <div
            class={`r-card ${idx === 0 ? 'r-card-wide r-active' : 'r-card-narrow r-inactive'}`}
            data-idx={idx}
          >
            {/* Wide (expanded) state */}
            <div class="r-wide-content" style={idx === 0 ? '' : 'display:none'}>
              <div>
                <p class="r-tagline">{card.tagline}</p>
                <h3 class="r-heading">{card.heading}</h3>
                <p class="r-body">{card.bodyExpanded}</p>
              </div>
              {card.cta?.label && card.cta.href && (
                <a href={card.cta.href} class="r-cta" set:html={card.cta.label + ' ' + arrowSvg} />
              )}
            </div>
            {card.image?.asset?.url && (
              <div
                class="r-wide-image"
                style={`background-image:url('${card.image.asset.url}');background-size:cover;background-position:center;${idx !== 0 ? 'display:none' : ''}`}
                role="img"
                aria-label={card.image.alt ?? ''}
              />
            )}

            {/* Narrow (collapsed) state */}
            <div class="r-narrow-content" style={idx === 0 ? 'display:none' : ''}>
              <div class="r-icon">
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                  <circle cx="12" cy="7" r="4" />
                </svg>
              </div>
              <div>
                <p class="r-tagline">{card.tagline}</p>
                <h3 class="r-heading">{card.heading}</h3>
                <p class="r-body">{card.bodyCollapsed}</p>
              </div>
              {card.cta?.label && card.cta.href && (
                <a href={card.cta.href} class="r-cta" set:html={card.cta.label + ' ' + arrowSvg} />
              )}
            </div>
          </div>
        ))}
      </div>
    )
  }
</section>

<style>
  .router-section {
    background: var(--navy-deep);
    padding: var(--pad-s) var(--pad-x);
  }

  .router-header {
    text-align: center;
    margin-bottom: 48px;
  }
  .router-header .eyebrow {
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: 1rem;
  }
  .router-header h2 {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    color: var(--white);
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }
  .router-header p {
    color: rgba(255, 255, 255, 0.72);
    max-width: 520px;
    margin: 0 auto;
    font-size: 17px;
    line-height: 1.6;
  }

  .router-row {
    display: flex;
    gap: 16px;
    align-items: stretch;
    height: 380px;
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .r-card {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--r-card);
    overflow: hidden;
    background: var(--white);
    cursor: pointer;
    transition:
      flex 0.45s cubic-bezier(0.4, 0, 0.2, 1),
      border-color var(--t-hover),
      box-shadow var(--t-hover);
    position: relative;
  }
  .r-card:hover {
    border-color: rgba(224, 85, 85, 0.5);
    box-shadow: var(--shadow-lg);
  }
  .r-card.r-active {
    border-color: var(--coral);
    box-shadow: 0 8px 24px rgba(224, 85, 85, 0.18);
  }

  .r-card-wide {
    flex: 0 0 580px;
    display: flex;
    flex-direction: row;
  }
  .r-card-wide.r-inactive {
    flex: 1 0 0;
    display: block;
  }
  .r-card-narrow {
    flex: 1 0 0;
    min-width: 0;
  }
  .r-card-narrow.r-active {
    flex: 0 0 580px;
  }

  .r-wide-content {
    flex: 1 0 0;
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-width: 0;
  }
  .r-wide-image {
    flex: 1 0 0;
    min-width: 0;
    background: var(--off-white) center / cover no-repeat;
  }
  .r-card-wide.r-inactive .r-wide-image {
    display: none;
  }
  .r-card-wide.r-inactive .r-wide-content {
    padding: 32px;
  }

  .r-narrow-content {
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    height: 100%;
    overflow: hidden;
  }

  .r-tagline {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--coral);
    margin-bottom: 0.5rem;
  }
  .r-heading {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--navy-deep);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 0.6rem;
  }
  .r-body {
    font-size: 15px;
    color: var(--slate);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .r-active .r-body {
    -webkit-line-clamp: unset;
    overflow: visible;
  }

  .r-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: var(--coral-light);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-bottom: 4px;
  }
  .r-icon svg {
    width: 24px;
    height: 24px;
    stroke: var(--coral);
  }

  .r-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    color: var(--white);
    background: var(--coral);
    letter-spacing: 0.01em;
    padding: 12px 20px;
    border-radius: var(--r-btn);
    border: 1.5px solid var(--coral);
    transition:
      background-color var(--t-hover),
      border-color var(--t-hover);
    text-decoration: none;
    white-space: nowrap;
    align-self: flex-start;
  }
  .r-cta:hover {
    background: var(--coral-hover);
    border-color: var(--coral-hover);
  }

  @media (max-width: 1024px) {
    .router-row {
      flex-direction: column;
      height: auto;
      gap: 14px;
    }
    .r-card-wide,
    .r-card-narrow {
      flex: none !important;
      width: 100% !important;
      min-width: 0 !important;
      display: block !important;
    }
    .r-wide-content {
      display: flex !important;
      flex-direction: column;
      padding: 28px;
      gap: 14px;
    }
    .r-wide-image {
      display: none !important;
    }
    .r-narrow-content {
      display: none !important;
    }
    .r-card.r-inactive .r-wide-content {
      display: flex !important;
    }
    .r-cta {
      margin-top: 16px;
      align-self: flex-start;
    }
  }

  @media (max-width: 768px) {
    .router-row {
      gap: 12px;
    }
    .r-wide-content {
      padding: 20px;
    }
    .r-cta {
      margin-top: 12px;
    }
  }
</style>

<script>
  function activateRouterCard(idx: number): void {
    const isMobile = window.innerWidth <= 768;
    document.querySelectorAll<HTMLElement>('.r-card').forEach((card, i) => {
      card.classList.remove('r-active', 'r-inactive');
      card.classList.add(i === idx ? 'r-active' : 'r-inactive');

      const wc = card.querySelector<HTMLElement>('.r-wide-content');
      const wi = card.querySelector<HTMLElement>('.r-wide-image');
      const nc = card.querySelector<HTMLElement>('.r-narrow-content');

      if (isMobile) {
        if (wc) wc.style.display = 'flex';
        if (wi) wi.style.display = 'none';
        if (nc) nc.style.display = 'none';
        card.style.display = 'block';
        card.style.flexDirection = '';
      } else if (i === idx) {
        if (wc) wc.style.display = 'flex';
        if (wi) wi.style.display = wi ? 'block' : 'none';
        if (nc) nc.style.display = 'none';
        card.style.display = 'flex';
        card.style.flexDirection = 'row';
      } else {
        if (wc) wc.style.display = 'none';
        if (wi) wi.style.display = 'none';
        if (nc) nc.style.display = 'flex';
        card.style.display = '';
        card.style.flexDirection = '';
      }
    });
  }

  // Wire click handlers
  document.querySelectorAll<HTMLElement>('.r-card').forEach((card, i) => {
    card.addEventListener('click', (e) => {
      // Don't activate if clicking a link inside
      if ((e.target as HTMLElement).closest('a')) return;
      activateRouterCard(i);
    });
  });

  // Initialize
  activateRouterCard(0);

  window.addEventListener('resize', () => {
    const activeIdx = [...document.querySelectorAll('.r-card')].findIndex((c) =>
      c.classList.contains('r-active'),
    );
    activateRouterCard(activeIdx >= 0 ? activeIdx : 0);
  });
</script>
