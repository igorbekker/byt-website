---
/**
 * Purpose: Interactive accordion-style cards letting users self-select their audience path
 * Context: Block 2 on Homepage — navy background, three expanding audience cards
 * Source: design-source/pages/Homepage.html (.router-section, .router-row, .r-card, .r-card-wide, .r-card-narrow, .r-wide-content, .r-wide-image, .r-narrow-content, .r-tagline, .r-heading, .r-body, .r-icon, .r-cta)
 */
---

<section class="router-section">
  <div class="router-header fade-up">
    <p class="eyebrow">Your path starts here</p>
    <h2>Who are you here to help?</h2>
    <p>Everyone deserves care that meets them where they are.</p>
  </div>

  <div class="router-row" id="routerRow">
    <!-- Card 1: Facilities — starts ACTIVE (wide) -->
    <div class="r-card r-card-wide r-active" data-idx="0">
      <div class="r-wide-content">
        <div>
          <p class="r-tagline">Facilities</p>
          <h3 class="r-heading">For Wellness Directors &amp; Facility Admins</h3>
          <p class="r-body">
            Your residents deserve mental health care. We make sure nothing stands in the way. Zero
            cost. We handle billing, scheduling, and documentation.
          </p>
        </div>
        <a href="/communities/" class="r-cta">
          Refer a Resident
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path d="M5 12h14M12 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
      <div
        class="r-wide-image"
        style="background-image:url('https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?w=700&q=85&auto=format&fit=crop');background-size:cover;background-position:center;"
      >
      </div>
      <div class="r-narrow-content" style="display:none">
        <div class="r-icon">
          <svg
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M3 21h18M5 21V7l7-4 7 4v14M9 9h1m4 0h1M9 13h1m4 0h1M9 17h1m4 0h1"></path>
          </svg>
        </div>
        <div>
          <p class="r-tagline">Facilities</p>
          <h3 class="r-heading">For Wellness Directors &amp; Facility Admins</h3>
          <p class="r-body">
            Zero cost to your facility. We handle billing, scheduling, and documentation.
          </p>
        </div>
        <a href="/communities/" class="r-cta">
          Refer a Resident
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path d="M5 12h14M12 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>

    <!-- Card 2: Patients -->
    <div class="r-card r-card-narrow r-inactive" data-idx="1">
      <div class="r-wide-content" style="display:none">
        <div>
          <p class="r-tagline">Patients &amp; Families</p>
          <h3 class="r-heading">For Adults, Families &amp; Caregivers</h3>
          <p class="r-body">
            You've decided it's time to get help — or someone you love has. Let's make that happen
            this week. No waitlist. No runaround.
          </p>
        </div>
        <a href="/patients/" class="r-cta">
          Book a Session
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path d="M5 12h14M12 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
      <div
        class="r-wide-image"
        style="display:none;background-image:url('https://images.unsplash.com/photo-1527137342181-19aab11a8ee8?w=700&q=85&auto=format&fit=crop');background-size:cover;background-position:center;"
      >
      </div>
      <div class="r-narrow-content">
        <div class="r-icon">
          <svg
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
          >
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
        </div>
        <div>
          <p class="r-tagline">Patients &amp; Families</p>
          <h3 class="r-heading">For Adults, Families &amp; Caregivers</h3>
          <p class="r-body">No waitlist. No runaround. Let's get you started this week.</p>
        </div>
        <a href="/patients/" class="r-cta">
          Book a Session
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path d="M5 12h14M12 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>

    <!-- Card 3: Providers -->
    <div class="r-card r-card-narrow r-inactive" data-idx="2">
      <div class="r-wide-content" style="display:none">
        <div>
          <p class="r-tagline">Providers</p>
          <h3 class="r-heading">For Licensed Therapists in Florida</h3>
          <p class="r-body">
            Facility-based positions in Southeast Florida and teletherapy statewide. Transparent
            revenue split from day one. We source the patients.
          </p>
        </div>
        <a href="/providers/" class="r-cta">
          See Open Positions
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path d="M5 12h14M12 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
      <div
        class="r-wide-image"
        style="display:none;background-image:url('https://images.unsplash.com/photo-1582750433449-648ed127bb54?w=700&q=85&auto=format&fit=crop');background-size:cover;background-position:center;"
      >
      </div>
      <div class="r-narrow-content">
        <div class="r-icon">
          <svg
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
          >
            <path d="M12 2a5 5 0 0 1 5 5v0a5 5 0 0 1-5 5 5 5 0 0 1-5-5v0a5 5 0 0 1 5-5z"></path>
            <path d="M2 21a8 8 0 0 1 16 0"></path>
          </svg>
        </div>
        <div>
          <p class="r-tagline">Providers</p>
          <h3 class="r-heading">For Licensed Therapists in Florida</h3>
          <p class="r-body">Transparent split. We source the patients — you deliver care.</p>
        </div>
        <a href="/providers/" class="r-cta">
          See Open Positions
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path d="M5 12h14M12 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .router-section {
    background: var(--navy-deep);
    padding: var(--pad-s) var(--pad-x);
  }

  .router-header {
    text-align: center;
    margin-bottom: 48px;
  }
  .router-header .eyebrow {
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: 1rem;
  }
  .router-header h2 {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    color: #fff;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }
  .router-header p {
    color: rgba(255, 255, 255, 0.72);
    max-width: 520px;
    margin: 0 auto;
    font-size: 17px;
    line-height: 1.6;
  }

  .router-row {
    display: flex;
    gap: 16px;
    align-items: stretch;
    height: 380px;
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .r-card {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--r-card);
    overflow: hidden;
    background: var(--white);
    cursor: pointer;
    transition:
      flex 0.45s cubic-bezier(0.4, 0, 0.2, 1),
      border-color var(--t-hover),
      box-shadow var(--t-hover);
    position: relative;
  }
  .r-card:hover {
    border-color: rgba(224, 85, 85, 0.5);
    box-shadow: var(--shadow-lg);
  }
  .r-card.r-active {
    border-color: var(--coral);
    box-shadow: 0 8px 24px rgba(224, 85, 85, 0.18);
  }

  .r-card-wide {
    flex: 0 0 580px;
    display: flex;
    flex-direction: row;
  }
  .r-card-wide.r-inactive {
    flex: 1 0 0;
    display: block;
  }
  .r-card-narrow {
    flex: 1 0 0;
    min-width: 0;
  }
  .r-card-narrow.r-active {
    flex: 0 0 580px;
  }

  .r-wide-content {
    flex: 1 0 0;
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-width: 0;
  }
  .r-wide-image {
    flex: 1 0 0;
    min-width: 0;
    background: var(--off-white) center / cover no-repeat;
  }
  .r-card-wide.r-inactive .r-wide-image {
    display: none;
  }
  .r-card-wide.r-inactive .r-wide-content {
    padding: 32px;
  }

  .r-narrow-content {
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    height: 100%;
    overflow: hidden;
  }

  .r-tagline {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--coral);
    margin-bottom: 0.5rem;
  }
  .r-heading {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--navy-deep);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 0.6rem;
  }
  .r-body {
    font-size: 15px;
    color: var(--slate);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .r-active .r-body {
    -webkit-line-clamp: unset;
    overflow: visible;
  }

  .r-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: var(--coral-light);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-bottom: 4px;
  }
  .r-icon svg {
    width: 24px;
    height: 24px;
    stroke: var(--coral);
  }

  .r-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    color: #fff;
    background: var(--coral);
    letter-spacing: 0.01em;
    padding: 12px 20px;
    border-radius: var(--r-btn);
    border: 1.5px solid var(--coral);
    transition:
      background-color var(--t-hover),
      border-color var(--t-hover);
    text-decoration: none;
    white-space: nowrap;
    align-self: flex-start;
  }
  .r-cta:hover {
    background: var(--coral-hover);
    border-color: var(--coral-hover);
  }

  @media (max-width: 1024px) {
    .router-row {
      flex-direction: column;
      height: auto;
      gap: 14px;
    }
    .r-card-wide,
    .r-card-narrow {
      flex: none !important;
      width: 100% !important;
      min-width: 0 !important;
      display: block !important;
    }
    .r-wide-content {
      display: flex !important;
      flex-direction: column;
      padding: 28px;
      gap: 14px;
    }
    .r-wide-image {
      display: none !important;
    }
    .r-narrow-content {
      display: none !important;
    }
    .r-card.r-inactive .r-wide-content {
      display: flex !important;
    }
    .r-cta {
      margin-top: 16px;
      align-self: flex-start;
    }
  }

  @media (max-width: 768px) {
    .router-row {
      gap: 12px;
    }
    .r-wide-content {
      padding: 20px;
    }
    .r-cta {
      margin-top: 12px;
    }
  }
</style>

<script>
  function activateRouterCard(idx: number): void {
    const isMobile = window.innerWidth <= 768;
    document.querySelectorAll<HTMLElement>('.r-card').forEach((card, i) => {
      card.classList.remove('r-active', 'r-inactive');
      card.classList.add(i === idx ? 'r-active' : 'r-inactive');

      const wc = card.querySelector<HTMLElement>('.r-wide-content');
      const wi = card.querySelector<HTMLElement>('.r-wide-image');
      const nc = card.querySelector<HTMLElement>('.r-narrow-content');

      if (isMobile) {
        if (wc) wc.style.display = 'flex';
        if (wi) wi.style.display = 'none';
        if (nc) nc.style.display = 'none';
        card.style.display = 'block';
        card.style.flexDirection = '';
      } else if (i === idx) {
        if (wc) wc.style.display = 'flex';
        if (wi) wi.style.display = 'block';
        if (nc) nc.style.display = 'none';
        card.style.display = 'flex';
        card.style.flexDirection = 'row';
      } else {
        if (wc) wc.style.display = 'none';
        if (wi) wi.style.display = 'none';
        if (nc) nc.style.display = 'flex';
        card.style.display = '';
        card.style.flexDirection = '';
      }
    });
  }

  // Wire click handlers
  document.querySelectorAll<HTMLElement>('.r-card').forEach((card, i) => {
    card.addEventListener('click', (e) => {
      // Don't activate if clicking a link inside
      if ((e.target as HTMLElement).closest('a')) return;
      activateRouterCard(i);
    });
  });

  // Initialize
  activateRouterCard(0);

  window.addEventListener('resize', () => {
    const activeIdx = [...document.querySelectorAll('.r-card')].findIndex((c) =>
      c.classList.contains('r-active'),
    );
    activateRouterCard(activeIdx >= 0 ? activeIdx : 0);
  });
</script>
