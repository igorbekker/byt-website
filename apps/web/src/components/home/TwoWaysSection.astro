---
/**
 * Purpose: Full-bleed photo cards showing two service tracks — teletherapy and in-facility
 * Context: Block 4 on Homepage — navy-deep background with photo overlay cards
 * Source: design-source/pages/Homepage.html (.twoways, .twoways-cards, .twoways-card, .twoways-card-bg, .twoways-card-overlay, .twoways-card-content, .twoways-card-label)
 */

interface CtaLink {
  label: string;
  href: string;
  variant?: string;
}

interface ImageWithAlt {
  asset?: { url: string };
  alt?: string;
}

interface ServiceTrack {
  label: string;
  heading: string;
  body?: string;
  image?: ImageWithAlt;
  cta?: CtaLink;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  subhead?: string;
  tracks?: ServiceTrack[];
}

const { eyebrow, heading, subhead, tracks } = Astro.props;
---

<section class="twoways">
  <div style="max-width:var(--max-w);margin:0 auto;">
    <div class="twoways-header fade-up">
      {
        eyebrow && (
          <p class="eyebrow" style="margin-bottom:.75rem">
            {eyebrow}
          </p>
        )
      }
      {heading && <h2>{heading}</h2>}
      {subhead && <p>{subhead}</p>}
    </div>

    {
      tracks && tracks.length > 0 && (
        <div class="twoways-cards fade-up">
          {tracks.map((track, idx) => {
            const ctaVariant =
              track.cta?.variant ?? (idx === 0 ? 'btn-white' : 'btn-white-outline');
            const bgStyle = track.image?.asset?.url
              ? `background-image:url('${track.image.asset.url}');background-color:var(--navy-deep);`
              : 'background-color:var(--navy-deep);';
            return (
              <div class={`twoways-card${idx === 0 ? ' twoways-card-lead' : ''}`}>
                <div class="twoways-card-bg" style={bgStyle} />
                <div class="twoways-card-overlay" />
                <div class="twoways-card-content">
                  {track.label && <div class="twoways-card-label">{track.label}</div>}
                  {track.heading && <h3>{track.heading}</h3>}
                  {track.body && <p>{track.body}</p>}
                  {track.cta?.label && track.cta.href && (
                    <a href={track.cta.href} class={`btn ${ctaVariant}`}>
                      {track.cta.label}
                    </a>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      )
    }
  </div>
</section>

<style>
  .twoways {
    background: var(--navy-deep);
    padding: var(--pad-s) var(--pad-x) 4rem;
  }

  .twoways-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .twoways-header .eyebrow {
    color: rgba(255, 255, 255, 0.65);
  }
  .twoways-header h2 {
    color: var(--white);
    max-width: 900px;
    margin: 0 auto 1rem;
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    letter-spacing: -0.02em;
  }
  .twoways-header p {
    color: rgba(255, 255, 255, 0.72);
    max-width: 560px;
    margin: 0 auto;
    font-size: 17px;
    line-height: 1.6;
  }

  .twoways-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .twoways-card {
    position: relative;
    border-radius: var(--r-card);
    overflow: hidden;
    height: 440px;
    cursor: pointer;
    transition:
      transform 0.3s ease,
      box-shadow var(--t-hover);
  }
  .twoways-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .twoways-card-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transition: transform 0.5s ease;
  }
  .twoways-card:hover .twoways-card-bg {
    transform: scale(1.04);
  }

  .twoways-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10, 45, 82, 0.96) 30%, rgba(10, 45, 82, 0.25) 100%);
  }

  .twoways-card-content {
    position: absolute;
    inset: 0;
    padding: 2.25rem 2rem;
    color: var(--white);
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }
  .twoways-card-content > .twoways-card-label {
    margin-top: auto;
    margin-bottom: 0.75rem;
  }

  .twoways-card-label {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.72);
    margin-bottom: 0.75rem;
  }

  .twoways-card h3 {
    color: var(--white);
    font-size: 1.75rem;
    margin-bottom: 0.75rem;
    line-height: 1.15;
    letter-spacing: -0.02em;
    font-weight: 800;
  }
  .twoways-card p {
    color: rgba(255, 255, 255, 0.82);
    font-size: 15px;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    max-width: 90%;
  }

  @media (max-width: 1024px) {
    .twoways-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
