---
/**
 * Purpose: Centered quote/belief statement section with coral rule accent
 * Context: Block 3 on Homepage — cream background, between router and two-ways
 * Source: design-source/pages/Homepage.html (.belief, .belief-inner, .belief-rule)
 */

interface Props {
  quote?: string;
  body?: string;
}

const { quote, body } = Astro.props;
---

<section class="belief">
  <div class="belief-inner fade-up">
    <div class="belief-rule"></div>
    {quote && <h2>&ldquo;{quote}&rdquo;</h2>}
    {body && <p>{body}</p>}
  </div>
</section>

<style>
  .belief {
    background: var(--cream);
    padding: var(--pad-s) var(--pad-x);
    text-align: center;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .belief-inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .belief-rule {
    width: 48px;
    height: 2px;
    background: var(--coral);
    margin: 0 auto 1.75rem;
    border-radius: 2px;
  }

  .belief h2 {
    color: var(--navy-deep);
    font-size: clamp(1.9rem, 3.2vw, 2.6rem);
    font-weight: 800;
    margin-bottom: 1.25rem;
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .belief p {
    color: var(--slate);
    font-size: 17px;
    line-height: 1.7;
    font-weight: 400;
  }
</style>
