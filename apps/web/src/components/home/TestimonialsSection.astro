---
/**
 * Purpose: 2-column testimonial card grid with coral quote marks and attribution
 * Context: Block 7 on Homepage — white background
 * Source: design-source/pages/Homepage.html (.testimonials, .testimonials-grid, .testimonial-card, .testimonial-quote-mark, .testimonial-text, .testimonial-attribution, .testimonial-avatar)
 */
---

<section class="testimonials">
  <div style="max-width:var(--max-w);margin:0 auto;">
    <div class="testimonials-header fade-up">
      <p class="eyebrow" style="margin-bottom:.75rem">Real Voices</p>
      <h2>What Our Clients and Partners Are Saying</h2>
      <p>From the families and facilities we serve &mdash; in their own words.</p>
    </div>

    <div class="testimonials-grid fade-up">
      <div class="testimonial-card">
        <div class="testimonial-quote-mark">&ldquo;</div>
        <p class="testimonial-text">
          Better You placed a licensed clinician on-site within two weeks. No billing burden on our
          team, and our residents have weekly continuity of care they didn't have before. [Sample
          testimonial]
        </p>
        <div class="testimonial-attribution">
          <div class="testimonial-avatar">WD</div>
          <div>
            <div class="testimonial-name">Director of Wellness</div>
            <div class="testimonial-role">Assisted Living &middot; Palm Beach County</div>
          </div>
        </div>
      </div>

      <div class="testimonial-card">
        <div class="testimonial-quote-mark">&ldquo;</div>
        <p class="testimonial-text">
          My mom had been on a waitlist for months. One call to Better You and she had her first
          session that same week &mdash; right from her apartment. [Sample testimonial]
        </p>
        <div class="testimonial-attribution">
          <div class="testimonial-avatar">FM</div>
          <div>
            <div class="testimonial-name">Adult Daughter</div>
            <div class="testimonial-role">Family member &middot; Southeast Florida</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .testimonials {
    background: var(--white);
    padding: var(--pad-s) var(--pad-x);
  }

  .testimonials-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .testimonials-header .eyebrow {
    margin-bottom: 1rem;
  }
  .testimonials-header h2 {
    color: var(--navy-deep);
    margin-bottom: 0.75rem;
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    letter-spacing: -0.02em;
  }
  .testimonials-header p {
    color: var(--slate);
    font-size: 17px;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .testimonial-card {
    background: var(--white);
    border-radius: var(--r-card);
    padding: 2.25rem;
    border: 1px solid var(--border);
    position: relative;
    box-shadow: var(--shadow-sm);
    transition:
      box-shadow var(--t-hover),
      border-color var(--t-hover);
  }
  .testimonial-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--coral);
  }

  .testimonial-quote-mark {
    font-family: var(--font-heading);
    font-size: 6rem;
    line-height: 0.5;
    color: var(--coral);
    opacity: 0.35;
    position: absolute;
    top: 1.25rem;
    left: 1.75rem;
    font-weight: 800;
  }

  .testimonial-text {
    color: var(--slate);
    font-size: 17px;
    line-height: 1.65;
    margin-bottom: 1.75rem;
    padding-top: 2rem;
    font-style: italic;
  }

  .testimonial-attribution {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .testimonial-avatar {
    width: 44px;
    height: 44px;
    border-radius: var(--r-pill);
    background: var(--off-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 800;
    color: var(--navy-deep);
    flex-shrink: 0;
  }

  .testimonial-name {
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 800;
    color: var(--navy-deep);
  }

  .testimonial-role {
    font-size: 13px;
    color: var(--slate);
  }

  @media (max-width: 1024px) {
    .testimonials-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
