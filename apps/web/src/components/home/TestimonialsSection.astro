---
/**
 * Purpose: 2-column testimonial card grid with coral quote marks and attribution
 * Context: Block 7 on Homepage — white background
 * Source: design-source/pages/Homepage.html (.testimonials, .testimonials-grid, .testimonial-card, .testimonial-quote-mark, .testimonial-text, .testimonial-attribution, .testimonial-avatar)
 */

interface Testimonial {
  _id: string;
  quote: string;
  authorName: string;
  authorRole?: string;
  authorOrg?: string;
  authorInitials?: string;
  audienceType?: string;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  subhead?: string;
  testimonials?: Testimonial[];
}

const { eyebrow, heading, subhead, testimonials } = Astro.props;

function deriveInitials(name: string): string {
  return name
    .split(' ')
    .slice(0, 2)
    .map((w) => w[0] ?? '')
    .join('')
    .toUpperCase();
}
---

<section class="testimonials">
  <div style="max-width:var(--max-w);margin:0 auto;">
    <div class="testimonials-header fade-up">
      {
        eyebrow && (
          <p class="eyebrow" style="margin-bottom:.75rem">
            {eyebrow}
          </p>
        )
      }
      {heading && <h2>{heading}</h2>}
      {subhead && <p>{subhead}</p>}
    </div>

    {
      testimonials && testimonials.length > 0 && (
        <div class="testimonials-grid fade-up">
          {testimonials.map((t) => {
            const initials = t.authorInitials ?? deriveInitials(t.authorName);
            const attribution = [t.authorRole, t.authorOrg].filter(Boolean).join(' · ');
            return (
              <div class="testimonial-card">
                <div class="testimonial-quote-mark">&ldquo;</div>
                <p class="testimonial-text">{t.quote}</p>
                <div class="testimonial-attribution">
                  <div class="testimonial-avatar">{initials}</div>
                  <div>
                    <div class="testimonial-name">{t.authorName}</div>
                    {attribution && <div class="testimonial-role">{attribution}</div>}
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      )
    }
  </div>
</section>

<style>
  .testimonials {
    background: var(--white);
    padding: var(--pad-s) var(--pad-x);
  }

  .testimonials-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .testimonials-header .eyebrow {
    margin-bottom: 1rem;
  }
  .testimonials-header h2 {
    color: var(--navy-deep);
    margin-bottom: 0.75rem;
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    letter-spacing: -0.02em;
  }
  .testimonials-header p {
    color: var(--slate);
    font-size: 17px;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .testimonial-card {
    background: var(--white);
    border-radius: var(--r-card);
    padding: 2.25rem;
    border: 1px solid var(--border);
    position: relative;
    box-shadow: var(--shadow-sm);
    transition:
      box-shadow var(--t-hover),
      border-color var(--t-hover);
  }
  .testimonial-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--coral);
  }

  .testimonial-quote-mark {
    font-family: var(--font-heading);
    font-size: 6rem;
    line-height: 0.5;
    color: var(--coral);
    opacity: 0.35;
    position: absolute;
    top: 1.25rem;
    left: 1.75rem;
    font-weight: 800;
  }

  .testimonial-text {
    color: var(--slate);
    font-size: 17px;
    line-height: 1.65;
    margin-bottom: 1.75rem;
    padding-top: 2rem;
    font-style: italic;
  }

  .testimonial-attribution {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .testimonial-avatar {
    width: 44px;
    height: 44px;
    border-radius: var(--r-pill);
    background: var(--off-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 800;
    color: var(--navy-deep);
    flex-shrink: 0;
  }

  .testimonial-name {
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 800;
    color: var(--navy-deep);
  }

  .testimonial-role {
    font-size: 13px;
    color: var(--slate);
  }

  @media (max-width: 1024px) {
    .testimonials-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
