---
/**
 * Purpose: Root layout wrapping every page — imports global CSS, renders Nav, slot, Footer, MobileCTABar
 * Context: All pages extend this layout
 * Source: design-source/styles/base.css (tokens + reset), design-source/partials/nav.html, footer.html, mobile-bar.html
 */

import { sanityClient } from 'sanity:client';
import Nav from '../components/nav/Nav.astro';
import Footer from '../components/ui/Footer.astro';
import MobileCTABar from '../components/ui/MobileCTABar.astro';
import ModalForms from '../components/ui/ModalForms.astro';
import { SITE_SETTINGS_QUERY } from '../lib/queries';
import '../styles/global.css';

interface SeoFields {
  metaTitle?: string;
  metaDescription?: string;
  ogImage?: { asset?: { url?: string }; alt?: string } | null;
  robotsDirective?: string;
}

interface NavLink {
  label: string;
  href: string;
  children?: Array<{ label: string; href: string }>;
}

interface FooterColumn {
  heading: string;
  links: Array<{ label: string; href: string }>;
}

interface SiteSettings {
  businessName: string;
  phone: string;
  email: string;
  fax?: string;
  address?: { street?: string; city?: string; state?: string; zip?: string };
  bookingUrl?: string;
  referralUrl?: string;
  navCtaLabel?: string;
  navCtaSecondaryLabel?: string;
  footerTagline?: string;
  copyrightEntity?: string;
  newsletterHeading?: string;
  newsletterBody?: string;
  gtmContainerId?: string;
  robotsTxt?: string;
  navLinks?: NavLink[];
  footerColumns?: FooterColumn[];
  seo?: SeoFields;
}

interface Props {
  title: string;
  description?: string;
  seo?: SeoFields | null;
}

const { title, description, seo: pageSeo } = Astro.props;

const siteSettings = await sanityClient.fetch<SiteSettings>(SITE_SETTINGS_QUERY);

const resolvedDescription =
  description ??
  siteSettings?.seo?.metaDescription ??
  'Licensed mental health care placed on-site at assisted living and skilled nursing facilities across Southeast Florida. Teletherapy statewide.';

const resolvedSeo: SeoFields = pageSeo ?? siteSettings?.seo ?? {};

const canonicalUrl = (() => {
  const base = (import.meta.env.PUBLIC_SITE_URL ?? 'https://getbetteryou.com').replace(/\/$/, '');
  const pathname = Astro.url.pathname;
  return `${base}${pathname}`;
})();

const robotsDirective = resolvedSeo.robotsDirective ?? 'index, follow';
const gtmId = siteSettings?.gtmContainerId ?? '';
const ogTitle = resolvedSeo.metaTitle ?? title;
const ogDescription = resolvedDescription;
const ogUrl = canonicalUrl;
const ogType = Astro.url.pathname === '/' ? 'website' : 'website';
const ogImageUrl = resolvedSeo.ogImage?.asset?.url ?? '';
const ogImageAlt = resolvedSeo.ogImage?.alt ?? ogTitle;

const FONT_URL =
  'https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Montserrat:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={resolvedDescription} />
    <meta name="robots" content={robotsDirective} />
    <meta name="theme-color" content="#104378" />
    <title>{resolvedSeo.metaTitle ?? title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Open Graph -->
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Better You Therapy" />
    <meta property="og:locale" content="en_US" />
    {
      ogImageUrl && (
        <>
          <meta property="og:image" content={ogImageUrl} />
          <meta property="og:image:width" content="1200" />
          <meta property="og:image:height" content="630" />
          <meta property="og:image:alt" content={ogImageAlt} />
        </>
      )
    }

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

    <!-- Fonts — non-render-blocking; display=swap in URL prevents FOUT -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href={FONT_URL} />
    <link rel="stylesheet" href={FONT_URL} media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href={FONT_URL} /></noscript>

    <!-- Sanity CDN -->
    <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />
    <link rel="dns-prefetch" href="https://cdn.sanity.io" />

    <!-- GTM -->
    {
      gtmId && (
        <>
          <script is:inline>window.dataLayer = window.dataLayer || [];</script>
          <script async src={`https://www.googletagmanager.com/gtm.js?id=${gtmId}`} />
        </>
      )
    }

    <!-- TEMP GA4 DIRECT TEST -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-JW2XB9Q7B3"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      // eslint-disable-next-line prefer-rest-params
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-JW2XB9Q7B3');
    </script>
    <!-- END TEMP GA4 DIRECT TEST -->
  </head>
  <body>
    {
      gtmId && (
        <noscript>
          <iframe
            src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
            height="0"
            width="0"
            style="display:none;visibility:hidden"
          />
        </noscript>
      )
    }
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Nav
      navCtaLabel={siteSettings?.navCtaLabel ?? 'Book a Session'}
      navCtaSecondaryLabel={siteSettings?.navCtaSecondaryLabel ?? 'Refer a Facility'}
      bookingUrl={siteSettings?.bookingUrl ?? '/individual-therapy/'}
      referralUrl={siteSettings?.referralUrl ?? '/referral/'}
      navLinks={siteSettings?.navLinks ?? []}
    />
    <main id="main-content">
      <slot />
    </main>
    <Footer
      footerTagline={siteSettings?.footerTagline ?? ''}
      copyrightEntity={siteSettings?.copyrightEntity ?? ''}
      newsletterHeading={siteSettings?.newsletterHeading ?? 'Stay in touch'}
      newsletterBody={siteSettings?.newsletterBody ?? ''}
      footerColumns={siteSettings?.footerColumns ?? []}
    />
    <MobileCTABar
      navCtaLabel={siteSettings?.navCtaLabel ?? 'Book a Session'}
      navCtaSecondaryLabel={siteSettings?.navCtaSecondaryLabel ?? 'Refer a Facility'}
      bookingUrl={siteSettings?.bookingUrl ?? '/individual-therapy/'}
      referralUrl={siteSettings?.referralUrl ?? '/referral/'}
    />
    <ModalForms
      bookId={import.meta.env.PUBLIC_FORMSPREE_BOOK_ID ?? ''}
      referralId={import.meta.env.PUBLIC_FORMSPREE_REFERRAL_ID ?? ''}
      phone={siteSettings?.phone ?? '754-999-0011'}
      email={siteSettings?.email ?? 'hello@getbetteryou.com'}
      hours={'Mon–Fri, 9am–6pm ET'}
    />
  </body>
</html>
