---
/**
 * Purpose: Root layout wrapping every page — imports global CSS, renders Nav, slot, Footer, MobileCTABar
 * Context: All pages extend this layout
 * Source: design-source/styles/base.css (tokens + reset), design-source/partials/nav.html, footer.html, mobile-bar.html
 */

import { sanityClient } from 'sanity:client';
import Nav from '../components/nav/Nav.astro';
import Footer from '../components/ui/Footer.astro';
import MobileCTABar from '../components/ui/MobileCTABar.astro';
import { SITE_SETTINGS_QUERY } from '../lib/queries';
import '../styles/global.css';

interface SeoFields {
  metaTitle?: string;
  metaDescription?: string;
  ogImage?: unknown;
}

interface SiteSettings {
  businessName: string;
  phone: string;
  email: string;
  fax?: string;
  address?: { street?: string; city?: string; state?: string; zip?: string };
  bookingUrl?: string;
  referralUrl?: string;
  navCtaLabel?: string;
  navCtaSecondaryLabel?: string;
  footerTagline?: string;
  copyrightEntity?: string;
  newsletterHeading?: string;
  newsletterBody?: string;
  seo?: SeoFields;
}

interface Props {
  title: string;
  description?: string;
  seo?: SeoFields | null;
}

const { title, description, seo: pageSeo } = Astro.props;

const siteSettings = await sanityClient.fetch<SiteSettings>(SITE_SETTINGS_QUERY);

const resolvedDescription =
  description ??
  siteSettings?.seo?.metaDescription ??
  'Licensed mental health care placed on-site at assisted living and skilled nursing facilities across Southeast Florida. Teletherapy statewide.';

const resolvedSeo: SeoFields = pageSeo ?? siteSettings?.seo ?? {};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={resolvedDescription} />
    <title>{resolvedSeo.metaTitle ?? title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <Nav
      navCtaLabel={siteSettings?.navCtaLabel ?? 'Book a Session'}
      navCtaSecondaryLabel={siteSettings?.navCtaSecondaryLabel ?? 'Refer a Resident'}
      bookingUrl={siteSettings?.bookingUrl ?? '/individual-therapy/'}
      referralUrl={siteSettings?.referralUrl ?? '/referral/'}
    />
    <main>
      <slot />
    </main>
    <Footer
      phone={siteSettings?.phone ?? ''}
      email={siteSettings?.email ?? ''}
      fax={siteSettings?.fax ?? ''}
      address={siteSettings?.address ?? {}}
      footerTagline={siteSettings?.footerTagline ?? ''}
      copyrightEntity={siteSettings?.copyrightEntity ?? ''}
      newsletterHeading={siteSettings?.newsletterHeading ?? 'Stay in touch'}
      newsletterBody={siteSettings?.newsletterBody ?? ''}
    />
    <MobileCTABar
      navCtaLabel={siteSettings?.navCtaLabel ?? 'Book a Session'}
      navCtaSecondaryLabel={siteSettings?.navCtaSecondaryLabel ?? 'Refer a Resident'}
      bookingUrl={siteSettings?.bookingUrl ?? '/individual-therapy/'}
      referralUrl={siteSettings?.referralUrl ?? '/referral/'}
    />
    <script>
      const obs = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              obs.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' },
      );
      document.querySelectorAll('.fade-up').forEach((el) => obs.observe(el));
    </script>
  </body>
</html>
