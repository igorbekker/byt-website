{
  "permissions": {
    "ask": [
      "Write(CLAUDE.md)",
      "Write(.claude/agents/*)",
      "Write(.claude/skills/*)",
      "Write(.claude/settings.json)",
      "Write(.claude/rules/*)",
      "Edit(CLAUDE.md)",
      "Edit(.claude/agents/*)",
      "Edit(.claude/skills/*)",
      "Edit(.claude/settings.json)",
      "Edit(.claude/rules/*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/personal/projects/byt-website/.claude/hooks/check-console-log.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/personal/projects/byt-website/.claude/hooks/check-triad.sh"
          }
        ]
      }
    ]
  }
}
